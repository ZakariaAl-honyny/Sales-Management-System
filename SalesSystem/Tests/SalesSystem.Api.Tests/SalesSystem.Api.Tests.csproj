    <PackageReference Include="Moq" Version="4.20.72" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.0" />
  </ItemGroup>

  <!-- Project References -->
  <ItemGroup>
    <ProjectReference Include="..\..\SalesSystem.Api\SalesSystem.Api.csproj" />
    <ProjectReference Include="..\..\SalesSystem.Contracts\SalesSystem.Contracts.csproj" />
