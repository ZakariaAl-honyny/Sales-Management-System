<Window x:Class="SalesSystem.DesktopPWF.Services.App.Toast.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast"
        Width="320"
        Height="Auto"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="Height"
        FlowDirection="RightToLeft">

    <Border x:Name="BackBorder"
            CornerRadius="8"
            Margin="10"
            Padding="12,10"
            HorizontalAlignment="Right">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.4" Color="#333333"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="IconText"
                       Grid.Column="0"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <TextBlock x:Name="MessageText"
                       Grid.Column="1"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="250"
                       TextAlignment="Right"/>

            <Button Grid.Column="2"
                    Content="✕"
                    FontSize="12"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Top"
                    Margin="8,0,0,0"
                    Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>