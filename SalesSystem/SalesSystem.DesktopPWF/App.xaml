<Application x:Class="SalesSystem.DesktopPWF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SalesSystem.DesktopPWF"
             xmlns:converters="clr-namespace:SalesSystem.DesktopPWF"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             Startup="Application_Startup"
             Exit="Application_Exit"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <sys:Byte x:Key="SaleModeRetail">1</sys:Byte>
            <sys:Byte x:Key="SaleModeWholesale">2</sys:Byte>

            <!-- Arabic RTL FlowDirection for all controls -->
            <Style TargetType="Window">
                <Setter Property="FlowDirection" Value="RightToLeft"/>
            </Style>

            <Style TargetType="Page">
                <Setter Property="FlowDirection" Value="RightToLeft"/>
            </Style>

            <!-- Default Typography -->
            <Style TargetType="Control">
                <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- Converters -->
            <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:CountToVisibilityConverter x:Key="CountToVisibility"/>
            <converters:LowStockConverter x:Key="LowStockConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
            <converters:InvoiceStatusToBrushConverter x:Key="InvoiceStatusToBrushConverter"/>
            <converters:InvoiceStatusToStringConverter x:Key="InvoiceStatusToStringConverter"/>
            <converters:SaleModeToBrushConverter x:Key="SaleModeToBrushConverter"/>
            <converters:SaleModeToStringConverter x:Key="SaleModeToStringConverter"/>
            <converters:StringListJoinConverter x:Key="StringListJoinConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>