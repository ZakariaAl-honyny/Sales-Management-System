<UserControl x:Class="SalesSystem.DesktopPWF.Views.Customers.CustomerContactEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Background="{StaticResource BackgroundBrush}"
        FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Padding="16">
                <StackPanel>
                    <!-- Customer Display -->
                    <TextBlock Text="العميل" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                    <TextBox Text="{Binding CustomerName}"
                             Style="{StaticResource ModernTextBox}"
                             IsReadOnly="True"
                             TabIndex="1"
                             ToolTip="اسم العميل المرتبط بهذه الجهة"/>
                    <Border Height="12"/>

                    <!-- Name -->
                    <TextBlock Text="الاسم *" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                             Style="{StaticResource ModernTextBox}"
                             Tag="أدخل اسم جهة الاتصال"
                             TabIndex="2"
                             helpers:FocusHelper.AdvanceOnEnter="True"
                             ToolTip="أدخل اسم جهة الاتصال — هذا الحقل إلزامي"/>
                    <Border Height="12"/>

                    <!-- Phone & Email -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="رقم الهاتف" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="05xxxxxxxx"
                                     TabIndex="3"
                                     helpers:FocusHelper.AdvanceOnEnter="True"
                                     ToolTip="رقم هاتف جهة الاتصال"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="البريد الإلكتروني" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="example@domain.com"
                                     TabIndex="4"
                                     helpers:FocusHelper.AdvanceOnEnter="True"
                                     ToolTip="البريد الإلكتروني لجهة الاتصال"/>
                        </StackPanel>
                    </Grid>
                    <Border Height="12"/>

                    <!-- Position -->
                    <TextBlock Text="المنصب / المسمى الوظيفي" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                    <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Tag="مثال: مدير مبيعات"
                             TabIndex="5"
                             helpers:FocusHelper.AdvanceOnEnter="True"
                             ToolTip="المنصب أو المسمى الوظيفي لجهة الاتصال"/>
                    <Border Height="12"/>

                    <!-- Notes -->
                    <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Tag="ملاحظات إضافية"
                             Height="60"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             TabIndex="6"
                             ToolTip="ملاحظات إضافية حول جهة الاتصال"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F8FAFC" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="120"
                        IsDefault="True"
                        TabIndex="7"
                        Margin="0,0,12,0"
                        ToolTip="حفظ بيانات جهة الاتصال">
                    <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                </Button>
                <Button Content="إلغاء"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        TabIndex="8"
                        ToolTip="إلغاء والعودة"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CCFFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="180" Height="4" Background="#E2E8F0" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" FontWeight="SemiBold" Margin="0,16,0,0" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
