<UserControl x:Class="SalesSystem.DesktopPWF.Views.Customers.CustomerGroupsListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Customers"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24,24,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="👥  إدارة مجموعات العملاء"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="CustomerGroupsPageTitle"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnAddCustomerGroup"
                            ToolTip="إضافة مجموعة جديدة لتصنيف العملاء">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إضافة مجموعة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" 
                            Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل المجموعة المختارة">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteCommand}" 
                            Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnDeleteCustomerGroup"
                            ToolTip="إيقاف نشاط المجموعة المختارة — لن يتم حذف العملاء المرتبطين بها">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حذف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            AutomationProperties.AutomationId="BtnRefreshCustomerGroups"
                            ToolTip="تحديث قائمة مجموعات العملاء">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding Groups}"
                          SelectedItem="{Binding SelectedGroup}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutomationProperties.AutomationId="DgCustomerGroups">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" Command="{Binding EditCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="✏️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="حذف" Command="{Binding DeleteCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🗑️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المعرف" 
                                            Binding="{Binding Id}" 
                                            Width="80" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="اسم المجموعة" 
                                            Binding="{Binding Name}" 
                                            Width="2*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="الوصف" 
                                            Binding="{Binding Description}" 
                                            Width="3*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTemplateColumn Header="الحالة" Width="120" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Setter Property="Text" Value="نشط"/>
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text" Value="غير نشط"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="👥" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                        <TextBlock Text="لا توجد مجموعات عملاء حالياً" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="قم بإضافة مجموعات لتصنيف العملاء (مثل: موزعين، تجزئة، جملة)" 
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إضافة أول مجموعة" Command="{Binding AddCommand}" Margin="0,12,0,0"
                                ToolTip="إضافة مجموعة جديدة لتصنيف العملاء"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Error Message -->
        <Border Grid.Row="2"
                VerticalAlignment="Top"
                Background="{StaticResource ErrorLightBrush}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"
                Padding="8" Margin="8,4" CornerRadius="4">
            <Grid>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"/>
                <Button HorizontalAlignment="Left" Content="✕" 
                        Command="{Binding RefreshCommand}" 
                        ToolTip="إخفاء رسالة الخطأ"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل مجموعات العملاء..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
