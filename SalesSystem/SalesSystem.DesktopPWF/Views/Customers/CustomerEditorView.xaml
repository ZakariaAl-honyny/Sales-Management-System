<Window x:Class="SalesSystem.DesktopPWF.Views.Customers.CustomerEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="600" Width="550"
        MinHeight="500" MinWidth="500"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconUser}" Fill="White" Width="24" Height="24" Margin="0,0,16,0" Stretch="Uniform"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>

                        <!-- Name -->
                        <TextBlock Text="اسم العميل *" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="أدخل الاسم الكامل للعميل" 
                                 TabIndex="2"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtCustomerName"
                               ToolTip="الاسم الكامل للعميل — هذا الحقل إلزامي ولا يمكن أن يكون فارغاً"/>
                        <Border Height="12"/>

                        <!-- Phone -->
                        <TextBlock Text="رقم الهاتف" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="05xxxxxxxx (10 أرقام)" 
                                 TabIndex="3"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtCustomerPhone"
                              ToolTip="رقم جوال العميل — يُستخدم للتواصل وإرسال إشعارات الفواتير"/>
                        <TextBlock Text="مثال: 0512345678 - سيتم استخدامه للتواصل وإرسال الفواتير" Style="{StaticResource HelperTextStyle}"/>
                        <Border Height="12"/>

                        <!-- Address -->
                        <TextBlock Text="العنوان (اختياري)" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="المدينة، الحي، الشارع، أو اسم معلم قريب" 
                                 Height="60" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 VerticalContentAlignment="Top" 
                                 TabIndex="4"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtCustomerAddress"
                              ToolTip="العنوان التفصيلي ليس إلزامياً ولكن يساعد في التوصيل"/>
                        <TextBlock Text="أدخل تفاصيل مكان سكن أو عمل العميل ليتمكن موظفو التوصيل من العثور عليه بسهولة." Style="{StaticResource HelperTextStyle}"/>
                        <Border Height="12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="الرقم الضريبي" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding TaxNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                          Style="{StaticResource ModernTextBox}" 
                                          Tag="15 رقم"
                                          TabIndex="5"
                                          helpers:FocusHelper.AdvanceOnEnter="True"
                                          AutomationProperties.AutomationId="TxtCustomerTaxNumber"
                              ToolTip="الرقم الضريبي للعميل — يستخدم في إصدار الفواتير الضريبية"/>
                                <TextBlock Text="الرقم الضريبي الخاص بالمنشأة" Style="{StaticResource HelperTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="البريد الإلكتروني" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                          Style="{StaticResource ModernTextBox}" 
                                          Tag="example@domain.com"
                                          TabIndex="6"
                                          helpers:FocusHelper.AdvanceOnEnter="True"
                                          AutomationProperties.AutomationId="TxtCustomerEmail"
                              ToolTip="البريد الإلكتروني الرسمي للعميل للمراسلة"/>
                                <TextBlock Text="البريد الإلكتروني الرسمي للمراسلة" Style="{StaticResource HelperTextStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="12"/>

                        <!-- Credit Limit -->
                        <TextBlock Text="الحد الائتماني" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding CreditLimit, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}" 
                                  Style="{StaticResource ModernTextBox}" 
                                  Tag="0.00"
                                  TabIndex="7"
                                  helpers:FocusHelper.AdvanceOnEnter="True"
                                  AutomationProperties.AutomationId="TxtCustomerCreditLimit"
                              ToolTip="أقصى مبلغ يمكن أن يدين به العميل — أدخل 0 إذا كنت لا تريد تحديد حد"/>
                        <TextBlock Text="أقصى مبلغ مديونية مسموح به — 0 يعني بدون حد ائتماني" Style="{StaticResource HelperTextStyle}"/>
                        <Border Height="12"/>

                        <!-- Opening Balance -->
                        <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="الرصيد الافتتاحي (رصيد سابق)" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding OpeningBalance, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}" 
                                      Style="{StaticResource ModernTextBox}" 
                                      Tag="0.00"
                                      TabIndex="8"
                                      helpers:FocusHelper.AdvanceOnEnter="True"
                                      AutomationProperties.AutomationId="TxtCustomerOpeningBalance"
                              ToolTip="الرصيد السابق للعميل — المبلغ المستحق عليك (بالسالب) أو المستحق له (بالموجب)"/>
                            <TextBlock Text="المبلغ المستحق على العميل (بالموجب) أو المستحق له (بالسالب) قبل استخدام النظام" Style="{StaticResource HelperTextStyle}"/>
                            <Border Height="12"/>
                        </StackPanel>

                        <!-- Account - Auto-created by system -->
                        <Border Height="12"/>
                        <Border Background="#E3F2FD" CornerRadius="6" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="الحساب المحاسبي" FontWeight="SemiBold" FontSize="13" Foreground="#1565C0"/>
                                <TextBlock Text="سيتم إنشاء حساب محاسبي تلقائياً تحت حساب العملاء في دليل الحسابات" 
                                           FontSize="11" Foreground="#1565C0" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Status -->
                        <Border Height="12"/>
                        <CheckBox Content="عميل نشط" IsChecked="{Binding IsActive}" FontSize="14" 
                                  Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}" 
                                  TabIndex="9"
                                  AutomationProperties.AutomationId="ChkCustomerActive"
                                  ToolTip="تفعيل أو إلغاء تنشيط العميل — العميل غير النشط لن يظهر في قوائم الاختيار"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="140"
                            Margin="0,0,12,0"
                            IsDefault="True"
                            TabIndex="10"
                            AutomationProperties.AutomationId="BtnSaveCustomer"
                            ToolTip="حفظ بيانات العميل — سيتم التحقق من صحة الحقول الإلزامية قبل الحفظ">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSave}" Fill="White" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="حفظ البيانات"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ManageContactsCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="140"
                            Margin="0,0,12,0"
                            TabIndex="11"
                            ToolTip="إدارة جهات اتصال العميل">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="جهات الاتصال"/>
                        </StackPanel>
                    </Button>
                    <Button Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100"
                            TabIndex="12"
                            AutomationProperties.AutomationId="BtnCancelCustomer"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري الحفظ..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
