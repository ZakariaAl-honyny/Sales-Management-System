<UserControl x:Class="SalesSystem.DesktopPWF.Views.Party.PartyEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Background="{StaticResource BackgroundBrush}"
        FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

                <!-- Header -->
                <Border Background="{StaticResource PrimaryBrush}" Padding="12,6" CornerRadius="4">
                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                </Border>

                <!-- Form -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel>

                        <!-- Name (required) -->
                        <TextBlock Text="الاسم *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                 ToolTip="أدخل اسم الشخص — هذا الحقل إلزامي"
                                 Style="{StaticResource ModernTextBox}"/>

                        <!-- Party Type -->
                        <TextBlock Text="نوع الشخص" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                        <ComboBox SelectedValue="{Binding PartyType}"
                                  SelectedValuePath="Tag"
                                  ToolTip="اختر نوع الشخص"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,6">
                            <ComboBoxItem Tag="0">بائع</ComboBoxItem>
                            <ComboBoxItem Tag="1">عميل</ComboBoxItem>
                            <ComboBoxItem Tag="2">مورد</ComboBoxItem>
                            <ComboBoxItem Tag="3">آخر</ComboBoxItem>
                        </ComboBox>

                        <!-- NameAr -->
                        <TextBlock Text="الاسم (إنجليزي)" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding NameAr, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="أدخل اسم الشخص باللغة الإنجليزية — اختياري"
                                 Style="{StaticResource ModernTextBox}"/>

                        <!-- Phone + Mobile -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="الهاتف" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="رقم الهاتف الثابت"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="الجوال" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Mobile, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="رقم الجوال"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Email + TaxNumber -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="البريد الإلكتروني" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="البريد الإلكتروني — اختياري"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="الرقم الضريبي" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding TaxNumber, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="الرقم الضريبي — اختياري"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Address -->
                        <TextBlock Text="العنوان" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="العنوان — اختياري"
                                 Style="{StaticResource ModernTextBox}"
                                 TextWrapping="Wrap" MaxHeight="80" AcceptsReturn="True"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Error Message -->
                <Border Grid.Row="2" Margin="0,8,0,0"
                        Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}, TargetNullValue=Collapsed, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="8">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#991B1B" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Footer Buttons -->
                <Border Grid.Row="3" Background="White" Padding="12,8" BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BorderBrush}" CornerRadius="0,0,4,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="💾 حفظ"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                ToolTip="حفظ بيانات الشخص"/>
                        <Button Content="🚫 إلغاء"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0"
                                ToolTip="إلغاء وإغلاق نافذة التحرير"/>
                    </StackPanel>
                </Border>
        </Grid>
</UserControl>
