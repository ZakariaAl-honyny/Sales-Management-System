<UserControl x:Class="SalesSystem.DesktopPWF.Views.CompanySettings.CompanySettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.CompanySettings"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:CompanySettingsViewModel, IsDesignTimeCreatable=False}"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="إعدادات الشركة" Style="{StaticResource HeaderStyle}"/>

        <!-- Error Message -->
        <Border Grid.Row="1" Background="{StaticResource ErrorLightBrush}" Padding="12,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToVisibility}}"
                Margin="0,8,0,0">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="2" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardStyle}" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Company Name -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="اسم الشركة *" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="أدخل اسم الشركة — هذا الحقل إلزامي"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>

                    <!-- Row 1: Phone -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="رقم الهاتف" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="رقم الهاتف الرئيسي للشركة"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>

                    <!-- Row 2: Email -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="البريد الإلكتروني" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="البريد الإلكتروني الرسمي للشركة"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>

                    <!-- Row 3: Address -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="العنوان" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="العنوان الفعلي للشركة"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>

                    <!-- Row 4: Tax Number -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="الرقم الضريبي" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding TaxNumber, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="الرقم الضريبي للشركة — يظهر في الفواتير والتقارير الضريبية"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>

                    <!-- Row 5: Logo Path -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="مسار الشعار" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding LogoPath, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="مسار ملف صورة الشعار — يظهر في الفواتير المطبوعة"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>

                    <!-- Row 6: Default Currency -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="العملة الافتراضية *" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="6" Grid.Column="1"
                              ItemsSource="{Binding Currencies}"
                              SelectedValue="{Binding DefaultCurrencyId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              ToolTip="اختر العملة الافتراضية للنظام — تستخدم في جميع المعاملات المالية"
                              Style="{StaticResource ModernComboBox}" Margin="0,0,0,8"/>

                    <!-- Row 7: Hint text -->
                    <TextBlock Grid.Row="7" Grid.Column="1" 
                               Text="— الحقول التي تحمل علامة * إلزامية"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                               Margin="0,4,0,0"/>
                </Grid>
            </Border>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Style="{StaticResource FooterStyle}" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                        ToolTip="حفظ إعدادات الشركة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding CloseCommand}" Style="{StaticResource SecondaryButton}"
                        ToolTip="إغلاق شاشة إعدادات الشركة">
                    <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#80FFFFFF" Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل إعدادات الشركة..." FontSize="14" Margin="0,12,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
