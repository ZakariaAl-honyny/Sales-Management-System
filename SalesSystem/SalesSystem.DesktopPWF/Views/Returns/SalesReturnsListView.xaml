<Page x:Class="SalesSystem.DesktopPWF.Views.Returns.SalesReturnsListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
      Title="مرتجعات المبيعات"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="Auto"/> <!-- Error Notification -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="مرتجعات المبيعات"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="SalesReturnsPageTitle"/>

        <!-- Toolbar -->
        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Section -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="200"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="رقم المرتجع، العميل..."
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding RefreshCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>

                <!-- Date Range Section -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="من" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker Style="{StaticResource ModernDatePicker}" Width="130"
                                SelectedDate="{Binding DateFrom}"/>

                    <TextBlock Text="إلى" VerticalAlignment="Center" Margin="12,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker Style="{StaticResource ModernDatePicker}" Width="130"
                                SelectedDate="{Binding DateTo}"/>
                </StackPanel>

                <!-- Actions Section -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding SearchInvoiceForReturnCommand}" Style="{StaticResource PrimaryButton}" Height="36" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <CheckBox Content="عرض الملغاة" 
                               IsChecked="{Binding IncludeInactive}" 
                               VerticalAlignment="Center" 
                               Margin="20,0,20,0"
                               FontSize="12"/>

                    <Button Command="{Binding NewCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,8,0" Height="36" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="مرتجع جديد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Height="36" Padding="12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Notification Banner -->
        <Border Grid.Row="2" 
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1" 
                CornerRadius="6" 
                Padding="12,8" 
                Margin="{StaticResource StandardSectionMargin}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" VerticalAlignment="Center" FontSize="12"/>
                <Button Grid.Column="2" Content="✕" 
                        Command="{Binding RefreshCommand}" 
                        Background="Transparent" BorderThickness="0" 
                        Foreground="{StaticResource ErrorTextBrush}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid x:Name="ReturnsGrid"
                          ItemsSource="{Binding ReturnsView}"
                          SelectedItem="{Binding SelectedReturn}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          AutomationProperties.AutomationId="DgReturns">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ViewCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم المرتجع" 
                                            Binding="{Binding ReturnNo}" 
                                            Width="140" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="التاريخ" 
                                            Binding="{Binding ReturnDate, StringFormat=yyyy/MM/dd}" 
                                            Width="110" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="رقم الفاتورة" 
                                            Binding="{Binding SalesInvoiceId}" 
                                            Width="110" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="العميل" 
                                            Binding="{Binding CustomerName}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="المستودع" 
                                            Binding="{Binding WarehouseName}" 
                                            Width="140" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="الإجمالي" 
                                            Binding="{Binding TotalAmount, StringFormat=N2}" 
                                            Width="130" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="الحالة" Width="110" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="1"> <!-- Draft -->
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="2"> <!-- Posted -->
                                                        <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3"> <!-- Cancelled -->
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Text" Value="مسودة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Text" Value="مرحل"/>
                                                            <Setter Property="Foreground" Value="{StaticResource InfoTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Text" Value="ملغي"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🔄" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد مرتجعات مبيعات حالياً" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="سجل عمليات استرجاع المنتجات من العملاء لإدارتها هنا" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إضافة مرتجع جديد" Command="{Binding NewCommand}" Style="{StaticResource PrimaryButton}" Margin="0,20,0,0" Width="160" Height="36"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource FooterBarStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="إجمالي المرتجعات: " Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding ReturnsView.Count, FallbackValue=0}" Style="{StaticResource FooterBarTextStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل البيانات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
