<Window x:Class="SalesSystem.DesktopPWF.Views.Returns.PurchaseReturnEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="720" Width="1024"
        MinHeight="550" MinWidth="900"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Scrollable Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconInvoice}" Fill="White" Width="20" Height="20" Margin="0,0,12,0" Stretch="Uniform"/>
                    <TextBlock Text="↩️ " FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="{Binding Status, Converter={StaticResource InvoiceStatusToBrushConverter}}" 
                        CornerRadius="4" Padding="8,4"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- Main: Items Grid -->
                <ColumnDefinition Width="340"/>    <!-- Side: Info, Impact, Notes -->
            </Grid.ColumnDefinitions>

            <!-- Main Panel -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- DataGrid -->
                    <RowDefinition Height="Auto"/> <!-- Footer totals -->
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 الأصناف القابلة للإرجاع" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="15"/>
                                <TextBlock Text="{Binding Items.Count, StringFormat=({0} أصناف)}" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <DataGrid ItemsSource="{Binding Items}"
                                  Style="{StaticResource ModernDataGrid}"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="اسم المنتج" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="نظام الشراء" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Mode, Converter={StaticResource SaleModeToBrushConverter}}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Mode, Converter={StaticResource SaleModeToStringConverter}}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الكمية المشتراة" Binding="{Binding OriginalQuantity}" Width="100" IsReadOnly="True" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                <DataGridTemplateColumn Header="كمية المرتجع" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}" 
                                                     Padding="8,4" 
                                                     FontWeight="Bold"
                                                     HorizontalContentAlignment="Center"
                                                     ToolTip="أدخل كمية المرتجع — يجب أن لا تتجاوز الكمية المسموحة"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="التكلفة" Binding="{Binding UnitPrice, StringFormat=N2}" Width="90" IsReadOnly="True" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, StringFormat=N2}" Width="100" IsReadOnly="True" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Proportional totals footer -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="8,6" Margin="0,6,0,0"
                        Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding Impact.HasImpact, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="خصم متناسب: " FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Impact.ReturnedDiscountAmount, StringFormat=N2}" FontSize="12" FontWeight="Bold" Foreground="#E65100" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="ضريبة متناسبة: " FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Impact.ReturnedTaxAmount, StringFormat=N2}" FontSize="12" FontWeight="Bold" Foreground="#7C3AED" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="رسوم متناسبة: " FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Impact.ReturnedChargeAmount, StringFormat=N2}" FontSize="12" FontWeight="Bold" Foreground="#2563EB" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Side Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Mode Toggle Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8"
                            Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="🔄 نوع المرتجع" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="مرتجع من فاتورة"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStandaloneMode}" Value="True">
                                                    <Setter Property="Text" Value="مرتجع مستقل"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ToggleButton Grid.Column="1" 
                                              IsChecked="{Binding IsStandaloneMode}"
                                              Command="{Binding ToggleStandaloneModeCommand}"
                                              Content="تبديل" 
                                              Style="{StaticResource SecondaryButton}"
                                              FontSize="12" Padding="8,4"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Info Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="ℹ️ معلومات" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>

                            <!-- Invoice-linked mode: search invoice -->
                            <StackPanel Visibility="{Binding IsInvoiceLinked, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="بحث عن فاتورة" Style="{StaticResource LabelStyle}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource ModernTextBox}"
                                             ToolTip="ابحث عن صنف بالاسم أو الباركود">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding ProcessBarcodeCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button Grid.Column="1" Content="🔍" 
                                            Command="{Binding SearchInvoiceCommand}"
                                            Style="{StaticResource SecondaryButton}" 
                                            Width="36" Margin="4,0,0,0" ToolTip="البحث عن فاتورة"/>
                                </Grid>

                                <TextBlock Text="رقم الفاتورة" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding SelectedInvoice.Id}" IsReadOnly="True" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8" Background="#F8FAFC"/>

                                <TextBlock Text="المورد" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding SelectedInvoice.SupplierName}" IsReadOnly="True" Style="{StaticResource ModernTextBox}" Margin="0,0,0,8" Background="#F8FAFC"/>
                            </StackPanel>

                            <!-- Standalone mode: supplier selector -->
                            <StackPanel Visibility="{Binding IsStandaloneMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="المورد *" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Suppliers}"
                                          SelectedValue="{Binding StandaloneSupplierId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          Margin="0,0,0,8"
                                          ToolTip="اختر المورد لهذا المرتجع المستقل"/>
                            </StackPanel>

                            <TextBlock Text="المستودع" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Warehouses}"
                                      SelectedValue="{Binding SelectedWarehouseId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,8"
                                      ToolTip="اختر المخزن الذي سيتم إرجاع البضاعة إليه"/>

                            <!-- Currency -->
                            <TextBlock Text="العملة" Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Currencies}"
                                          SelectedValue="{Binding SelectedCurrencyId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          ToolTip="اختر عملة فاتورة المرتجع"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrencyName}" 
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </Grid>

                            <!-- Exchange Rate -->
                            <TextBlock Text="سعر الصرف" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ExchangeRate, StringFormat=N4, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBox}" 
                                     Margin="0,0,0,8"
                                     ToolTip="سعر صرف العملة مقابل العملة الأساسية"
                                     IsReadOnly="{Binding IsBaseCurrency}"/>

                            <!-- Discount Type -->
                            <TextBlock Text="نوع الخصم" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding DiscountTypeOptions}"
                                      SelectedValue="{Binding SelectedDiscountType}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Display"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,8"/>

                            <!-- Discount Rate (visible when percentage) -->
                            <StackPanel Visibility="{Binding IsPercentageDiscount, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="نسبة الخصم" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding DiscountRate, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         Margin="0,0,0,8"
                                         ToolTip="نسبة الخصم (مثلاً 10 = 10%)"/>
                            </StackPanel>

                            <TextBlock Text="تاريخ المرتجع" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding ReturnDate}" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,8"
                                       ToolTip="تاريخ عملية الإرجاع"/>
                        </StackPanel>
                    </Border>

                    <!-- Impact Analysis Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Background="#FFF1F2" BorderBrush="#FECDD3"
                            Visibility="{Binding Impact.HasImpact, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="📊 تحليل الأثر" FontWeight="Bold" Foreground="#BE123C" Margin="0,0,0,12"/>

                            <Border Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="📦 المخزون" Style="{StaticResource LabelStyle}" FontSize="11"/>
                                    <TextBlock Text="{Binding Impact.StockQuantityImpact, StringFormat={}{0} قطعة ستخرج}" Foreground="#DC2626" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Impact.WarehouseName}" FontSize="10" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="💰 مديونية المورد" Style="{StaticResource LabelStyle}" FontSize="11"/>
                                    <TextBlock Text="{Binding Impact.BalanceImpact, StringFormat={}- {0:N2} ريال}" Foreground="#2563EB" FontWeight="Bold" FontSize="14"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="6" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="🧾 الضريبة المستردة" Style="{StaticResource LabelStyle}" FontSize="11"/>
                                    <TextBlock Text="{Binding Impact.TaxImpact, StringFormat='{}{0:N2} ريال'}" Foreground="#7C3AED" FontWeight="Bold" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Currency & Discount Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="💰 العملة والخصم" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>

                            <TextBlock Text="العملة" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Currencies}"
                                      SelectedValue="{Binding SelectedCurrencyId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,6"
                                      ToolTip="اختر عملة المرتجع — إذا كانت غير العملة الأساسية سيظهر حقل سعر الصرف"/>
                            <Grid Margin="0,0,0,8"
                                  Visibility="{Binding IsForeignCurrency, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="سعر الصرف:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                                <TextBox Grid.Column="1" Text="{Binding ExchangeRate, StringFormat=N2}"
                                         Style="{StaticResource ModernTextBox}"
                                         ToolTip="سعر صرف العملة المختارة مقابل العملة الأساسية"/>
                            </Grid>

                            <Border Background="#F8FAFC" CornerRadius="4" Padding="6,4" Margin="0,0,0,6"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="نوع الخصم" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <RadioButton Content="مبلغ" IsChecked="{Binding IsAmountDiscount}" GroupName="ReturnDiscountType"
                                                 Margin="0,0,0,2" FontSize="11" ToolTip="خصم بقيمة مالية ثابتة"/>
                                    <RadioButton Content="نسبة %" IsChecked="{Binding IsPercentageDiscount}" GroupName="ReturnDiscountType"
                                                 FontSize="11" ToolTip="خصم بنسبة مئوية من إجمالي المرتجع"/>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,4"
                                  Visibility="{Binding IsPercentageDiscount, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="نسبة الخصم (%)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding DiscountRate, StringFormat=N2}"
                                         Width="80" HorizontalAlignment="Right" TextAlignment="Center"
                                         ToolTip="نسبة الخصم من إجمالي المرتجع"/>
                            </Grid>
                            <Grid Margin="0,0,0,4"
                                  Visibility="{Binding IsAmountDiscount, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="قيمة الخصم" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding DiscountAmount, StringFormat=N2}"
                                         Width="100" HorizontalAlignment="Right" TextAlignment="Left"
                                         ToolTip="قيمة الخصم على المرتجع"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Notes -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="📝 ملاحظات" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBox Text="{Binding Notes}" 
                                     Style="{StaticResource ModernTextBox}" 
                                     Height="80" 
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top" Padding="8,4"
                                     ToolTip="ملاحظات إضافية حول عملية الإرجاع"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="🚢 ترحيل المرتجع"
                            Command="{Binding PostCommand}"
                            Style="{StaticResource SuccessButton}"
                            Margin="0,0,12,0"
                            Visibility="{Binding IsDraft, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="ترحيل العملية نهائياً — سيتم تحديث المخزون والرصيد"/>

                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="140"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsDraft, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="حفظ كمسودة دون ترحيل">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,8,0"/>
                            <TextBlock Text="حفظ المرتجع"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding PrintA4Command}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,12,0"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="طباعة فاتورة بصيغة A4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖨️" Margin="0,0,8,0"/>
                            <TextBlock Text="طباعة A4"/>
                        </StackPanel>
                    </Button>

                    <Button Content="🚫 إلغاء المرتجع"
                            Command="{Binding CancelReturnCommand}"
                            Style="{StaticResource DangerButton}"
                            Margin="0,0,12,0"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="إلغاء العملية (للحالات غير المرحلة)"/>

                    <Button Content="إغلاق"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100"
                            ToolTip="إغلاق النافذة دون حفظ"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" 
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
