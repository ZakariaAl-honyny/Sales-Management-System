<Window x:Class="SalesSystem.DesktopPWF.Views.Returns.SalesReturnEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="680" Width="950"
        MinHeight="550" MinWidth="900"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Scrollable Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="16,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconInvoice}" Fill="White" Width="20" Height="20" Margin="0,0,12,0" Stretch="Uniform"/>
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="{Binding Status, Converter={StaticResource InvoiceStatusToBrushConverter}}" 
                        CornerRadius="4" Padding="8,4"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- Main: Items Grid -->
                <ColumnDefinition Width="320"/>    <!-- Side: Info, Impact, Notes -->
            </Grid.ColumnDefinitions>

            <!-- Main Panel (Right side in RTL) -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 المنتجات المرتجعة" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="15"/>
                                <TextBlock Text="{Binding Items.Count, StringFormat=({0} أصناف)}" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <DataGrid ItemsSource="{Binding Items}"
                                  Style="{StaticResource ModernDataGrid}"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="اسم المنتج" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="نظام البيع" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Mode, Converter={StaticResource SaleModeToBrushConverter}}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Mode, Converter={StaticResource SaleModeToStringConverter}}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الكمية المشتراة" Binding="{Binding OriginalQuantity}" Width="110" IsReadOnly="True" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                <DataGridTemplateColumn Header="كمية المرتجع" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernTextBox}" 
                                                     Height="32" Padding="8,4" 
                                                     FontWeight="Bold"
                                                     HorizontalContentAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100" IsReadOnly="True" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, StringFormat=N2}" Width="110" IsReadOnly="True" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Side Panel (Left side in RTL) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Info Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="ℹ️ معلومات الفاتورة" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="بحث عن فاتورة" Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         Height="36">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding ProcessBarcodeCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1" Content="🔍" 
                                        Command="{Binding SearchInvoiceCommand}"
                                        Style="{StaticResource SecondaryButton}" 
                                        Width="36" Margin="4,0,0,0" ToolTip="البحث عن فاتورة"/>
                            </Grid>

                            <TextBlock Text="رقم الفاتورة" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedInvoice.InvoiceNo}" IsReadOnly="True" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Background="#F8FAFC"/>

                            <TextBlock Text="العميل" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedInvoice.CustomerName}" IsReadOnly="True" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Background="#F8FAFC"/>

                            <TextBlock Text="المستودع" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Warehouses}"
                                      SelectedValue="{Binding SelectedWarehouseId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>
                    </Border>

                    <!-- Impact Analysis Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16" Background="#EEF2FF" BorderBrush="#C7D2FE"
                            Visibility="{Binding Impact.HasImpact, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="📊 تحليل الأثر" FontWeight="Bold" Foreground="#4338CA" Margin="0,0,0,12"/>
                            
                            <Border Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="📦 المخزون" Style="{StaticResource LabelStyle}" FontSize="11"/>
                                    <TextBlock Text="{Binding Impact.StockQuantityImpact, StringFormat={}{0} قطعة ستعود}" Foreground="#059669" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Impact.WarehouseName}" FontSize="10" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="💰 مديونية العميل" Style="{StaticResource LabelStyle}" FontSize="11"/>
                                    <TextBlock Text="{Binding Impact.BalanceImpact, StringFormat={}- {0:N2} ريال}" Foreground="#2563EB" FontWeight="Bold" FontSize="14"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="6" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="🧾 الضريبة المستردة" Style="{StaticResource LabelStyle}" FontSize="11"/>
                                    <TextBlock Text="{Binding Impact.TaxImpact, StringFormat='{}{0:N2} ريال'}" Foreground="#7C3AED" FontWeight="Bold" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Notes -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="📝 ملاحظات" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBox Text="{Binding Notes}" 
                                     Style="{StaticResource ModernTextBox}" 
                                     Height="80" 
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top" Padding="8,4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="20,12" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Totals Summary -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="إجمالي قيمة المرتجع:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat=N2}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="12,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ريال" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="🚢 ترحيل المرتجع"
                                Command="{Binding PostCommand}"
                                Style="{StaticResource SuccessButton}"
                                Margin="0,0,12,0"
                                Visibility="{Binding IsDraft, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="ترحيل العملية نهائياً — سيتم تحديث المخزون والرصيد"/>

                        <Button Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="140"
                                Margin="0,0,8,0"
                                Visibility="{Binding IsDraft, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="حفظ كمسودة دون ترحيل">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" Margin="0,0,8,0"/>
                                <TextBlock Text="حفظ المرتجع"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding PrintA4Command}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="طباعة فاتورة بصيغة A4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖨️" Margin="0,0,8,0"/>
                                <TextBlock Text="طباعة A4"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding PrintReceiptCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,12,0"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="طباعة إيصال حراري">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧾" Margin="0,0,8,0"/>
                                <TextBlock Text="طباعة إيصال"/>
                            </StackPanel>
                        </Button>

                        <Button Content="🚫 إلغاء المرتجع"
                                Command="{Binding CancelReturnCommand}"
                                Style="{StaticResource DangerButton}"
                                Margin="0,0,12,0"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="إلغاء العملية (للحالات غير المرحلة)"/>
                                
                        <Button Content="إغلاق"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                ToolTip="إغلاق النافذة دون حفظ"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center" 
                           TextWrapping="Wrap" 
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
