<UserControl x:Class="SalesSystem.DesktopPWF.Views.Sales.SalesQuotationsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16,16,16,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📄  عروض الأسعار" Style="{StaticResource HeaderStyle}" Margin="0,0,0,12"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="200"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             helpers:FocusHelper.AdvanceOnEnter="True">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Command="{Binding SearchCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            ToolTip="اضغط هنا للبحث عن عروض الأسعار حسب البيانات التي أدخلتها">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="الحالة" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedValue="{Binding FilterStatus}"
                              DisplayMemberPath="Display"
                              SelectedValuePath="Value"
                              Width="120"
                              Style="{StaticResource ModernComboBox}"
                              ToolTip="اختر حالة لعرض عروض الأسعار حسب الحالة"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="اضغط هنا لفتح شاشة إنشاء عرض سعر جديد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="عرض سعر جديد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل عرض السعر المختار (للمسودات فقط)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ConfirmCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                            ToolTip="تأكيد عرض السعر المختار — لا يمكن التراجع عن هذه العملية">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تأكيد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExpireCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="إنهاء صلاحية عرض السعر المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏰" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إنهاء" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ConvertToInvoiceCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                            ToolTip="تحويل عرض السعر المؤكد إلى فاتورة بيع">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛒" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تحويل لفاتورة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            ToolTip="حذف عرض السعر المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حذف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة البيانات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="10,6"
                Margin="0,0,0,16"
                CornerRadius="8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorTextBrush}" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding Quotations}"
                          SelectedItem="{Binding SelectedQuotation}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل عرض السعر" Command="{Binding EditCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="📝"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="تأكيد عرض السعر" Command="{Binding ConfirmCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="✅"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="إنهاء عرض السعر" Command="{Binding ExpireCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="⏰"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="تحويل لفاتورة بيع" Command="{Binding ConvertToInvoiceCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🛒"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="حذف" Command="{Binding DeleteCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🗑️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="تحديث" Command="{Binding RefreshCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🔄"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم عرض السعر" 
                                            Binding="{Binding QuotationNo}" 
                                            Width="120" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="العميل" 
                                            Binding="{Binding CustomerName}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>

                        <DataGridTextColumn Header="التاريخ" 
                                            Binding="{Binding QuotationDate, StringFormat=yyyy-MM-dd}" 
                                            Width="100" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="تاريخ الانتهاء" 
                                            Binding="{Binding ExpiryDate, StringFormat=yyyy-MM-dd}" 
                                            Width="100" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTemplateColumn Header="الحالة" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="2"> <!-- Confirmed -->
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="1"> <!-- Draft -->
                                                        <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3"> <!-- Expired -->
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="4"> <!-- Converted -->
                                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Text" Value="مؤكد"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Text" Value="مسودة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource InfoTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Text" Value="منتهي"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="4">
                                                            <Setter Property="Text" Value="محول"/>
                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="الإجمالي" 
                                            Binding="{Binding TotalAmount, StringFormat=N2}" 
                                            Width="120" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="0,0,12,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="تاريخ الإنشاء" 
                                            Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" 
                                            Width="130" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="بواسطة" 
                                            Binding="{Binding CreatedByUserName}" 
                                            Width="100" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📄" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                        <TextBlock Text="لا توجد عروض أسعار حالياً" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="ابدأ بإنشاء عرض سعر جديد للعملاء" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إنشاء أول عرض سعر" Command="{Binding AddCommand}" Margin="0,12,0,0"
                                ToolTip="إنشاء عرض سعر جديد"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource FooterBarStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="عدد عروض الأسعار: " Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding Quotations.Count, FallbackValue=0}" Style="{StaticResource FooterBarTextStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل عروض الأسعار..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
