<UserControl x:Class="SalesSystem.DesktopPWF.Views.Sales.SalesQuotationEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Sales"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance local:SalesQuotationEditorViewModel, IsDesignTimeCreatable=False}">

    <Grid>
        <!-- Loading Overlay -->
        <Border Background="#80FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                Grid.ZIndex="10" IsHitTestVisible="True">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,8"/>
                <TextBlock Text="جاري التحميل..." FontSize="14" Foreground="#666"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <!-- Header -->
                <Border Background="{StaticResource PrimaryBrush}" Padding="12,6"
                        CornerRadius="4" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="HeaderTitle" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Error Message -->
                <Border Background="#FFF3F3" BorderBrush="#EF4444" BorderThickness="1"
                        CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                    <Grid>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C"
                                   FontSize="11" VerticalAlignment="Center"/>
                        <Button Content="✕" FontSize="11" Foreground="#B91C1C"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Left" Cursor="Hand"
                                ToolTip="إخفاء رسالة الخطأ"
                                Command="{Binding DismissErrorCommand}"/>
                    </Grid>
                </Border>

                <!-- Main Form Sections -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Right Column: Customer + Warehouse + Dates -->
                    <StackPanel Grid.Column="0">
                        <!-- Customer & Warehouse Section -->
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="0,0,0,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="بيانات العميل والمستودع" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="العميل" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Customers}"
                                          SelectedValue="{Binding SelectedCustomerId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          Margin="0,0,0,6"
                                          ToolTip="اختر العميل المستهدف بعرض السعر — يمكنك تركه فارغاً لعرض سعر عام"/>
                                <TextBlock Text="المستودع *" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Warehouses}"
                                          SelectedValue="{Binding SelectedWarehouseId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          Margin="0,0,0,6"
                                          ToolTip="اختر المستودع الذي ستتوفر منه المنتجات — هذا الحقل إلزامي"/>
                            </StackPanel>
                        </Border>

                        <!-- Dates Section -->
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="0,0,0,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="التواريخ" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="تاريخ عرض السعر" Style="{StaticResource LabelStyle}"/>
                                <DatePicker SelectedDate="{Binding QuotationDate}"
                                            Style="{StaticResource ModernDatePicker}"
                                            Margin="0,0,0,6"
                                            ToolTip="تاريخ إصدار عرض السعر"/>
                                <TextBlock Text="تاريخ انتهاء الصلاحية" Style="{StaticResource LabelStyle}"/>
                                <DatePicker SelectedDate="{Binding ExpiryDate}"
                                            Style="{StaticResource ModernDatePicker}"
                                            Margin="0,0,0,6"
                                            ToolTip="تاريخ انتهاء صلاحية عرض السعر — اختياري"/>
                            </StackPanel>
                        </Border>

                        <!-- Notes Section -->
                        <StackPanel>
                            <TextBlock Text="ملاحظات" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Notes}"
                                     Style="{StaticResource ModernTextBox}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="60" MaxHeight="120"
                                     ToolTip="ملاحظات إضافية حول عرض السعر — اختياري"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Left Column: Items -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="الأصناف" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Command="{Binding AddItemCommand}"
                                    Content="+ إضافة صنف"
                                    Style="{StaticResource SmallPrimaryButton}"
                                    Margin="8,0,0,0"
                                    ToolTip="إضافة صنف جديد إلى قائمة أصناف عرض السعر"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Items}"
                                      Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:SalesQuotationItemLineViewModel}">
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="6,4" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Product -->
                                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                <TextBlock Text="المنتج *" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                                <ComboBox ItemsSource="{Binding AvailableProducts}"
                                                          SelectedItem="{Binding SelectedProduct}"
                                                          DisplayMemberPath="Name"
                                                          Style="{StaticResource ModernComboBox}"
                                                          ToolTip="اختر المنتج لهذا البند — اكتب للبحث"/>
                                            </StackPanel>

                                            <!-- Quantity -->
                                            <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                                <TextBlock Text="الكمية *" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                                <TextBox Text="{Binding Quantity, StringFormat=N3}"
                                                         Style="{StaticResource ModernTextBox}"
                                                         ToolTip="أدخل الكمية — يجب أن تكون أكبر من صفر"/>
                                            </StackPanel>

                                            <!-- Unit Price -->
                                            <StackPanel Grid.Column="2" Margin="0,0,4,0">
                                                <TextBlock Text="السعر" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                                <TextBox Text="{Binding UnitPrice, StringFormat=N2}"
                                                         Style="{StaticResource ModernTextBox}"
                                                         ToolTip="سعر الوحدة من المنتج"/>
                                            </StackPanel>

                                            <!-- Discount -->
                                            <StackPanel Grid.Column="3" Margin="0,0,4,0">
                                                <TextBlock Text="الخصم" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                                <TextBox Text="{Binding DiscountAmount, StringFormat=N2}"
                                                         Style="{StaticResource ModernTextBox}"
                                                         ToolTip="قيمة الخصم على هذا البند"/>
                                            </StackPanel>

                                            <!-- Line Total -->
                                            <StackPanel Grid.Column="4" Margin="0,0,4,0">
                                                <TextBlock Text="الإجمالي" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                                <TextBlock Text="{Binding LineTotal, StringFormat=N2}"
                                                           FontWeight="Bold" FontSize="12"
                                                           VerticalAlignment="Center" Margin="0,2,0,0"
                                                           ToolTip="إجمالي قيمة البند = (الكمية × السعر) - الخصم"/>
                                            </StackPanel>

                                            <!-- Remove Button -->
                                            <Button Grid.Column="5"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                    CommandParameter="{Binding}"
                                                    Content="✕"
                                                    FontSize="11"
                                                    Margin="2,8,0,0"
                                                    VerticalAlignment="Top"
                                                    ToolTip="حذف هذا الصنف من عرض السعر">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- Totals -->
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="0,8,0,0" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="المجموع الفرعي:" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding SubTotal, StringFormat=N2}"
                                           FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="الخصم:" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding DiscountAmount, StringFormat=N2}"
                                           FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Right"
                                           Foreground="#EF4444"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="الإجمالي:" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Left"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat=N2}"
                                           FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,16,0,0">
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            ToolTip="حفظ عرض السعر — سيتم التحقق من صحة البيانات قبل الحفظ">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,4,0"/>
                            <TextBlock Text="حفظ"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="8,0,0,0"
                            ToolTip="إلغاء وإغلاق نافذة تحرير عرض السعر">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚫" Margin="0,0,4,0"/>
                            <TextBlock Text="إلغاء"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
