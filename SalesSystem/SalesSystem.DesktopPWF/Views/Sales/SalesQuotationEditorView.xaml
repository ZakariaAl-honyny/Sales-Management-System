<Window x:Class="SalesSystem.DesktopPWF.Views.Sales.SalesQuotationEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SalesSystem.DesktopPWF.Views.Sales"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="عرض سعر"
        Height="720" Width="1000"
        MinHeight="550" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <Style x:Key="ValidationTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ValidationComboBoxStyle" TargetType="ComboBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#80FFFFFF" 
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="1000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="📋  تحرير عرض سعر" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{StaticResource PrimaryLightBrush}" CornerRadius="6" Padding="16,4">
                    <TextBlock Text="{Binding QuotationNo, FallbackValue='جديد'}" Foreground="White" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <!-- Error Message Bar -->
                <Border 
                        Background="{StaticResource ErrorLightBrush}" 
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        Padding="10,6"
                        Margin="0,0,0,8"
                        CornerRadius="8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="{StaticResource ErrorTextBrush}" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Header Info Section -->
                <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,0,8" Background="#F8FAFC">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Customer -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="العميل *" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      SelectedValue="{Binding SelectedCustomerId}"
                                      Style="{StaticResource ModernComboBox}"
                                      ToolTip="اختر العميل المستهدف بعرض السعر"
                                      IsEditable="True" TextSearch.TextPath="Name"/>
                        </StackPanel>

                        <!-- Warehouse -->
                        <StackPanel Grid.Column="1" Margin="8,0,8,0">
                            <TextBlock Text="المستودع *" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Warehouses}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      SelectedValue="{Binding SelectedWarehouseId}"
                                      Style="{StaticResource ModernComboBox}"
                                      ToolTip="اختر المستودع الافتراضي للأصناف في عرض السعر"/>
                        </StackPanel>

                        <!-- Quotation Date -->
                        <StackPanel Grid.Column="2" Margin="8,0,8,0">
                            <TextBlock Text="تاريخ العرض *" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding QuotationDate}" 
                                        Style="{StaticResource ModernDatePicker}"
                                        ToolTip="تاريخ إصدار عرض السعر"/>
                        </StackPanel>

                        <!-- Valid Until -->
                        <StackPanel Grid.Column="3" Margin="8,0,0,0">
                            <TextBlock Text="صالح حتى *" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding ValidUntil}" 
                                        Style="{StaticResource ModernDatePicker}"
                                        ToolTip="تاريخ انتهاء صلاحية عرض السعر — يجب أن يكون بعد تاريخ العرض"/>
                        </StackPanel>

                        <!-- Currency -->
                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,6,8,0">
                            <TextBlock Text="العملة" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Currencies}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      SelectedValue="{Binding SelectedCurrencyId}"
                                      Style="{StaticResource ModernComboBox}"
                                      ToolTip="اختر العملة لعرض السعر"/>
                        </StackPanel>

                        <!-- Exchange Rate -->
                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="8,6,8,0"
                                    Visibility="{Binding IsForeignCurrency, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="سعر الصرف" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ExchangeRate}" 
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="سعر صرف العملة المحددة مقابل العملة الأساسية"
                                     helpers:InputHelper.NumericOnly="True"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Items Section Header -->
                <TextBlock Text="📦  أصناف عرض السعر" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>

                <!-- Items Toolbar -->
                <Border Style="{StaticResource CardStyle}" Padding="6,4" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="➕ إضافة صنف" Command="{Binding AddLineCommand}" 
                                Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                                ToolTip="إضافة صنف جديد لعرض السعر"/>
                        <Button Content="🗑 حذف الصنف المحدد" Command="{Binding RemoveLineCommand}" 
                                Style="{StaticResource DangerButton}"
                                ToolTip="حذف الصنف المحدد من عرض السعر"/>
                    </StackPanel>
                </Border>

                <!-- Items DataGrid -->
                <DataGrid ItemsSource="{Binding Items}" 
                          AutoGenerateColumns="False"
                          Style="{StaticResource ModernDataGrid}"
                          Height="200"
                          Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName, TargetNullValue=''}" Width="2*" MinWidth="120"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity, StringFormat='N3'}" Width="80"/>
                        <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName, TargetNullValue=''}" Width="60"/>
                        <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, StringFormat='N2'}" Width="100"/>
                        <DataGridTextColumn Header="الخصم" Binding="{Binding DiscountAmount, StringFormat='N2'}" Width="80"/>
                        <DataGridTextColumn Header="الضريبة" Binding="{Binding TaxAmount, StringFormat='N2'}" Width="80"/>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, StringFormat='N2'}" Width="100"/>
                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes, TargetNullValue=''}" Width="*" MinWidth="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Summary Section -->
                <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,0,8" Background="#F8FAFC">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Width="300" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="الإجمالي قبل الخصم:" 
                                       FontWeight="SemiBold" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SubTotal, StringFormat='N2'}" 
                                       FontWeight="Bold" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="الخصم:" 
                                       FontWeight="SemiBold" Margin="0,0,12,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DiscountAmount}" 
                                     Style="{StaticResource ModernTextBox}" Width="100" HorizontalAlignment="Right"
                                     ToolTip="قيمة الخصم على عرض السعر"
                                     helpers:InputHelper.NumericOnly="True"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding DiscountAmount, StringFormat='N2'}" 
                                       FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="الإجمالي النهائي" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2} ريال'}" 
                                       FontWeight="Bold" FontSize="22" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Terms & Conditions -->
                <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="الشروط والأحكام" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBox Grid.Row="1" Text="{Binding TermsAndConditions}" 
                                 Style="{StaticResource ModernTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                 ToolTip="شروط وأحكام عرض السعر — تظهر في الطباعة"/>
                    </Grid>
                </Border>

                <!-- Notes -->
                <Border Style="{StaticResource CardStyle}" Padding="12,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="ملاحظات" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBox Grid.Row="1" Text="{Binding Notes}" 
                                 Style="{StaticResource ModernTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                 ToolTip="ملاحظات داخلية لعرض السعر"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="💾 حفظ" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                        ToolTip="حفظ عرض السعر — سيتم حفظ البيانات كمسودة"/>
                <Button Content="❌ إلغاء" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}"
                        ToolTip="إلغاء التعديلات والعودة لقائمة عروض السعر"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
