<UserControl x:Class="SalesSystem.DesktopPWF.Views.Sales.TouchPosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Sales"
             xmlns:converters="clr-namespace:SalesSystem.DesktopPWF"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:TouchPosViewModel}"
             FlowDirection="RightToLeft"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <!-- Style for category tile buttons -->
        <Style x:Key="TouchCategoryTileStyle" TargetType="ListBoxItem">
            <Setter Property="MinHeight" Value="50"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="عرض المنتجات في هذا التصنيف"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                MinHeight="{TemplateBinding MinHeight}"
                                MinWidth="{TemplateBinding MinWidth}"
                                Effect="{StaticResource SubtleShadow}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for product touch buttons -->
        <Style x:Key="TouchProductButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="100"/>
            <Setter Property="Margin" Value="7"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="ToolTip" Value="إضافة المنتج إلى سلة المشتريات"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                MinHeight="{TemplateBinding MinHeight}"
                                Effect="{StaticResource SubtleShadow}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Border" Property="Effect" Value="{StaticResource DeepShadow}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E2E8F0"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- TOP ROW: Categories                                          -->
        <!-- ============================================================ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="16,12"
                Margin="0,0,0,2"
                CornerRadius="0"
                Effect="{StaticResource SubtleShadow}">
            <Grid>
                <!-- Section header -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="📂" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="التصنيفات"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Category tiles -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource TouchCategoryTileStyle}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Categories empty state -->
                <TextBlock Grid.Row="1"
                           Text="لا توجد تصنيفات متاحة"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,8"
                           Visibility="{Binding Categories.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}"/>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- BOTTOM ROW: Products                                         -->
        <!-- ============================================================ -->
        <Border Grid.Row="1"
                Background="{StaticResource BackgroundBrush}"
                CornerRadius="0">
            <Grid Margin="12,8,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Section header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="📦" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="المنتجات"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Product grid -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ItemsControl ItemsSource="{Binding Products}"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource TouchProductButtonStyle}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Product Image (lazy loaded, hidden when null) -->
                                        <Image Source="{Binding ImagePath, IsAsync=True}"
                                               MaxHeight="55"
                                               MaxWidth="80"
                                               Margin="0,0,0,6"
                                               Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibility}}"/>

                                        <!-- Product Name -->
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   LineHeight="18"
                                                   MaxHeight="36"
                                                   Margin="0,0,0,4"/>

                                        <!-- Price -->
                                        <TextBlock Text="{Binding RetailPrice, StringFormat=N2}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Products empty state -->
                <Border Grid.Row="1"
                        Background="Transparent"
                        Visibility="{Binding Products.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center" Opacity="0.4" Margin="0,0,0,10"/>
                        <TextBlock Text="لا توجد منتجات في هذا التصنيف"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="اختر تصنيفاً آخر أو أضف منتجات جديدة"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"
                                   Opacity="0.7"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- Loading Overlay (spans across all rows)                      -->
        <!-- ============================================================ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#CCFFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="240" Height="5"
                             Background="{StaticResource BorderBrush}"
                             Foreground="{StaticResource AccentBrush}"
                             Margin="0,0,0,16"/>
                <TextBlock Text="جاري تحميل البيانات..."
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- Initial Empty State (no categories loaded at all)            -->
        <!-- ============================================================ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{StaticResource SurfaceBrush}"
                Panel.ZIndex="500"
                Visibility="{Binding Categories.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🏪" FontSize="72" HorizontalAlignment="Center" Opacity="0.3" Margin="0,0,0,16"/>
                <TextBlock Text="نقطة البيع"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="لا توجد تصنيفات متاحة حالياً"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <TextBlock Text="يرجى إضافة تصنيفات ومنتجات من شاشة الإدارة"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Opacity="0.7"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
