<UserControl x:Class="SalesSystem.DesktopPWF.Views.Settings.SystemSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
              mc:Ignorable="d"
              FlowDirection="RightToLeft"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="إعدادات النظام"
                   FontSize="14" FontWeight="Bold"
                   Foreground="#333"
                   Margin="0,0,0,12"
                   ToolTip="إدارة جميع إعدادات النظام المخزنة في قاعدة البيانات"/>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ════════════════════════════════════════════ -->
                <!-- Card 1: Inventory (المخزون) -->
                <!-- ════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="المخزون" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                        <!-- CostingMethod -->
                        <TextBlock Text="طريقة احتساب التكلفة" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                   ToolTip="تحدد كيف يحتسب النظام تكلفة البضاعة في المخزن"/>
                        <RadioButton Content="متوسط التكلفة المرجح (Weighted Average)"
                                     IsChecked="{Binding IsWeightedAverageSelected}"
                                     GroupName="SysCostingMethod"
                                     Margin="0,0,0,4"
                                     ToolTip="يجمع بين سعر البضاعة القديمة في المخزن والجديدة ليعطيك تكلفة موحدة ومتوازنة"/>
                        <RadioButton Content="آخر سعر توريد (Last Purchase Price)"
                                     IsChecked="{Binding IsLastPurchasePriceSelected}"
                                     GroupName="SysCostingMethod"
                                     Margin="0,0,0,4"
                                     ToolTip="يستبدل تكلفة المنتج بسعر آخر فاتورة شراء مباشرةً"/>
                        <RadioButton Content="سعر المورد (Supplier Catalog Price)"
                                     IsChecked="{Binding IsSupplierPriceSelected}"
                                     GroupName="SysCostingMethod"
                                     Margin="0,0,0,8"
                                     ToolTip="يعتمد على السعر المدخل في بطاقة الصنف من قائمة المورد ولا يتغير تلقائياً"/>

                        <!-- AllowNegativeStock -->
                        <CheckBox Content="السماح بالمخزون السالب"
                                  IsChecked="{Binding AllowNegativeStock}"
                                  Margin="0,0,0,6"
                                  ToolTip="السماح بجعل كمية المخزون أقل من صفر — قد يؤدي إلى أخطاء في التقارير المحاسبية"/>

                        <!-- EnableFefo -->
                        <CheckBox Content="استخدام FEFO (الصادر أولاً حسب تاريخ الانتهاء)"
                                  IsChecked="{Binding EnableFefo}"
                                  Margin="0,0,0,6"
                                  ToolTip="استخدام طريقة الصادر أولاً حسب تاريخ انتهاء الصلاحية — مناسبة للمواد الغذائية والأدوية"/>

                        <!-- StockAlertDays -->
                        <StackPanel Margin="0,0,0,2">
                            <TextBlock Text="تحذير المخزون (أيام)" Style="{StaticResource LabelStyle}"
                                       ToolTip="عدد الأيام قبل النفاد التي يبدأ فيها النظام بعرض تحذيرات المخزون"/>
                            <TextBox Text="{Binding StockAlertDays, TargetNullValue=5}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="عدد الأيام للتحذير قبل نفاد المخزون — مثال: 5 أيام"
                                     helpers:InputHelper.NumericOnly="True"/>
                        </StackPanel>

                        <CheckBox Content="إلزامية رقم الدفعة عند الشراء"
                                  IsChecked="{Binding RequireBatchOnPurchase}"
                                  Margin="0,0,0,6"
                                  ToolTip="إجبارية إدخال رقم الدفعة عند إنشاء فاتورة شراء"/>

                        <CheckBox Content="إلزامية تاريخ الانتهاء عند الشراء"
                                  IsChecked="{Binding RequireExpiryOnPurchase}"
                                  Margin="0,0,0,6"
                                  ToolTip="إجبارية إدخال تاريخ الانتهاء للمنتجات ذات الصلاحية"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════ -->
                <!-- Card 2: Sales (المبيعات) -->
                <!-- ════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="المبيعات" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                        <CheckBox Content="الترحيل التلقائي فور الحفظ"
                                  IsChecked="{Binding AutoPostInvoices}"
                                  Margin="0,0,0,6"
                                  ToolTip="عند حفظ فاتورة البيع، يتم ترحيلها مباشرة بدون الحاجة لضغط زر الترحيل"/>

                        <CheckBox Content="السماح بالمسودات"
                                  IsChecked="{Binding AllowDrafts}"
                                  Margin="0,0,0,6"
                                  ToolTip="السماح بحفظ فاتورة البيع كمسودة دون ترحيل — يمكن العودة إليها لاحقاً"/>

                        <CheckBox Content="إظهار الربح في شاشة البيع"
                                  IsChecked="{Binding ShowProfitInInvoice}"
                                  Margin="0,0,0,6"
                                  ToolTip="إظهار هامش الربح (سعر البيع - التكلفة) في شاشة البيع للمساعدة في اتخاذ قرارات التسعير"/>

                        <CheckBox Content="منع البيع بأقل من السعر الرسمي"
                                  IsChecked="{Binding PreventBelowRetailPrice}"
                                  Margin="0,0,0,6"
                                  ToolTip="منع إتمام عملية البيع إذا كان سعر البيع أقل من السعر الرسمي للمنتج"/>

                        <CheckBox Content="السماح بالبيع بأقل من التكلفة"
                                  IsChecked="{Binding AllowBelowCostSale}"
                                  Margin="0,0,0,6"
                                  ToolTip="السماح بالبيع بسعر أقل من التكلفة مع عرض تحذير — قد يؤدي إلى خسارة"/>

                        <CheckBox Content="إخفاء الضريبة في فواتير البيع"
                                  IsChecked="{Binding HideTaxInSales}"
                                  Margin="0,0,0,6"
                                  ToolTip="إخفاء خيار الضريبة عند إنشاء فاتورة بيع جديدة"/>

                        <StackPanel Margin="0,0,0,2">
                            <TextBlock Text="العميل الافتراضي للمبيعات النقدية" Style="{StaticResource LabelStyle}"
                                       ToolTip="رقم العميل الافتراضي الذي يتم استخدامه تلقائياً في فواتير البيع النقدي"/>
                            <TextBox Text="{Binding DefaultCashCustomerId, TargetNullValue=1}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="أدخل رقم العميل الافتراضي — مثال: 1 للمبيعات النقدية"/>
                        </StackPanel>

                        <CheckBox Content="طباعة تلقائية بعد الترحيل"
                                  IsChecked="{Binding AutoPrintAfterPosting}"
                                  Margin="0,0,0,6"
                                  ToolTip="طباعة الفاتورة تلقائياً بعد الترحيل"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════ -->
                <!-- Card 3: Purchases (المشتريات) -->
                <!-- ════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="المشتريات" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                        <CheckBox Content="الترحيل التلقائي للمشتريات"
                                  IsChecked="{Binding PurchaseAutoPost}"
                                  Margin="0,0,0,6"
                                  ToolTip="عند حفظ فاتورة الشراء، يتم ترحيلها مباشرة بدون الحاجة لضغط زر الترحيل"/>

                        <CheckBox Content="إخفاء الضريبة في فواتير الشراء"
                                  IsChecked="{Binding HideTaxInPurchases}"
                                  Margin="0,0,0,6"
                                  ToolTip="إخفاء خيار الضريبة عند إنشاء فاتورة شراء جديدة"/>

                        <StackPanel Margin="0,0,0,2">
                            <TextBlock Text="المورد الافتراضي للمشتريات النقدية" Style="{StaticResource LabelStyle}"
                                       ToolTip="رقم المورد الافتراضي الذي يتم استخدامه تلقائياً في فواتير الشراء النقدي"/>
                            <TextBox Text="{Binding DefaultCashSupplierId, TargetNullValue=1}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="أدخل رقم المورد الافتراضي — مثال: 1 للمشتريات النقدية"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════ -->
                <!-- Card 4: Barcode (الباركود) -->
                <!-- ════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="الباركود" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                        <CheckBox Content="توليد باركود تلقائي للمنتجات الجديدة"
                                  IsChecked="{Binding AutoGenerateBarcode}"
                                  Margin="0,0,0,6"
                                  ToolTip="عند إضافة منتج جديد بدون باركود، يقوم النظام بتوليد باركود فريد تلقائياً"/>

                        <CheckBox Content="السماح بتكرار الباركود"
                                  IsChecked="{Binding AllowDuplicateBarcode}"
                                  Margin="0,0,0,6"
                                  ToolTip="السماح باستخدام نفس الباركود لمنتجات مختلفة"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════ -->
                <!-- Card 5: Accounting (المحاسبة) -->
                <!-- ════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="المحاسبة" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                        <CheckBox Content="إنشاء قيود محاسبية تلقائياً"
                                  IsChecked="{Binding AutoCreateJournalEntry}"
                                  Margin="0,0,0,2"
                                  ToolTip="عند ترحيل كل فاتورة بيع أو شراء، يتم إنشاء قيد محاسبي تلقائي في دفتر الأستاذ"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════ -->
                <!-- Card 5: Print (الطباعة) -->
                <!-- ════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="الطباعة" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                        <CheckBox IsChecked="{Binding ShowLogo}" Content="إظهار الشعار في الفاتورة"
                                  Margin="0,0,0,6"
                                  ToolTip="عرض شعار المتجر على الفاتورة المطبوعة"/>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="ملاحظة أسفل الفاتورة" Style="{StaticResource LabelStyle}"
                                       ToolTip="نص يظهر أسفل الفاتورة (مثال: شكراً لتعاملكم)"/>
                            <TextBox Text="{Binding FooterNote, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="نص يظهر أسفل الفاتورة المطبوعة"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="حجم الورق" Style="{StaticResource LabelStyle}"
                                       ToolTip="حجم ورق الطباعة"/>
                            <ComboBox SelectedItem="{Binding PaperSize}"
                                      Style="{StaticResource ModernComboBox}"
                                      ToolTip="A4 = ورق عادي، Letter = ورق أمريكي، Thermal = رول حراري">
                                <ComboBoxItem Content="A4"/>
                                <ComboBoxItem Content="Letter"/>
                                <ComboBoxItem Content="Thermal"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="عدد النسخ" Style="{StaticResource LabelStyle}"
                                       ToolTip="عدد النسخ المطبوعة لكل فاتورة"/>
                            <TextBox Text="{Binding PrintCopies, TargetNullValue=1}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="عدد النسخ المطبوعة لكل فاتورة (1-10)"
                                     helpers:InputHelper.NumericOnly="True"/>
                        </StackPanel>

                        <CheckBox IsChecked="{Binding ShowBalanceOnPrint}" Content="إظهار الرصيد على الفاتورة"
                                  Margin="0,0,0,6"
                                  ToolTip="عرض المبلغ المستحق على الفاتورة المطبوعة"/>

                        <CheckBox IsChecked="{Binding PrintSignature}" Content="إظهار خط التوقيع"
                                  Margin="0,0,0,6"
                                  ToolTip="إظهار خانة التوقيع أسفل الفاتورة"/>

                        <CheckBox IsChecked="{Binding PrintBarcode}" Content="طباعة الباركود على الفاتورة"
                                  Margin="0,0,0,6"
                                  ToolTip="إظهار الباركود أسفل كل منتج في الفاتورة المطبوعة"/>

                        <CheckBox IsChecked="{Binding PrintQRCode}" Content="طباعة رمز QR على الفاتورة"
                                  Margin="0,0,0,6"
                                  ToolTip="إظهار رمز QR في أسفل الفاتورة المطبوعة"/>

                        <CheckBox IsChecked="{Binding PrintCompanyAddress}" Content="طباعة عنوان الشركة"
                                  Margin="0,0,0,6"
                                  ToolTip="إظهار عنوان المتجر في رأس الفاتورة المطبوعة"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════ -->
                <!-- Card 7: General (العامة) -->
                <!-- ════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="العامة" FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                        <CheckBox Content="تفعيل المرفقات"
                                  IsChecked="{Binding EnableAttachments}"
                                  Margin="0,0,0,6"
                                  ToolTip="إظهار خيار إرفاق الملفات بالفواتير"/>

                        <CheckBox Content="تفعيل التنبيهات"
                                  IsChecked="{Binding EnableNotifications}"
                                  Margin="0,0,0,6"
                                  ToolTip="تشغيل أو إيقاف جميع التنبيهات"/>

                        <CheckBox Content="السماح بالسداد من الصندوق للسالب"
                                  IsChecked="{Binding AllowNegativeCash}"
                                  Margin="0,0,0,10"
                                  ToolTip="السماح بخروج الصندوق للسالب عند السداد"/>

                        <!-- Invoice Defaults -->
                        <TextBlock Text="القيم الافتراضية للفواتير" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"
                                   ToolTip="القيم الافتراضية المستخدمة عند إنشاء فواتير جديدة"/>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="الضريبة الافتراضية للمبيعات %" Style="{StaticResource LabelStyle}"
                                       ToolTip="نسبة الضريبة الافتراضية لفواتير البيع (0-100)"/>
                            <TextBox Text="{Binding DefaultSalesTax, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="نسبة الضريبة الافتراضية لفواتير البيع — مثال: 15"
                                     helpers:InputHelper.NumericOnly="True"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="الضريبة الافتراضية للمشتريات %" Style="{StaticResource LabelStyle}"
                                       ToolTip="نسبة الضريبة الافتراضية لفواتير الشراء (0-100)"/>
                            <TextBox Text="{Binding DefaultPurchaseTax, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="نسبة الضريبة الافتراضية لفواتير الشراء — مثال: 15"
                                     helpers:InputHelper.NumericOnly="True"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="الفرع الافتراضي" Style="{StaticResource LabelStyle}"
                                       ToolTip="رقم الفرع الافتراضي عند إنشاء الفواتير"/>
                            <TextBox Text="{Binding DefaultBranch, TargetNullValue=1}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="رقم الفرع الافتراضي — مثال: 1"
                                     helpers:InputHelper.NumericOnly="True"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="المستودع الافتراضي" Style="{StaticResource LabelStyle}"
                                       ToolTip="رقم المستودع الافتراضي عند إنشاء الفواتير"/>
                            <TextBox Text="{Binding DefaultWarehouse, TargetNullValue=1}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="رقم المستودع الافتراضي — مثال: 1"
                                     helpers:InputHelper.NumericOnly="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="0,8,0,0" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="#4CAF50"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="حفظ الإعدادات"
                            Command="{Binding SaveCommand}"
                            ToolTip="حفظ جميع إعدادات النظام — سيتم تطبيق التغييرات فوراً على جميع المستخدمين"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="100"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ الإعدادات..." FontSize="14" Margin="0,12,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
