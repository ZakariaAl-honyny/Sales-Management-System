<Page x:Class="SalesSystem.DesktopPWF.Views.Settings.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
      Title="إعدادات النظام"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24,24,24,24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="إعدادات النظام"
                   Style="{StaticResource HeaderStyle}"
                   Margin="0,0,0,24"
                   AutomationProperties.AutomationId="SettingsPageTitle"/>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Company Info -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="🏢 بيانات الشركة" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="اسم المنشأة *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CompanyName}" TabIndex="1" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyName"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="الرقم الضريبي" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding TaxNumber}" TabIndex="2" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyTaxNo"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="رقم الهاتف" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Phone}" TabIndex="3" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyPhone"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="البريد الإلكتروني" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Email}" TabIndex="4" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyEmail"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                <TextBlock Text="العنوان" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Address}" TextWrapping="Wrap" AcceptsReturn="True" TabIndex="5" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyAddress"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Invoice Settings -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📄 إعدادات الفواتير" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="نسبة الضريبة الافتراضية (%)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding DefaultTaxRate, StringFormat=N2}" TabIndex="6" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtDefaultTaxRate"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="بادئة رقم الفاتورة" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding InvoicePrefix}" TabIndex="7" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtInvoicePrefix"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- System Options -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="⚙️ خيارات النظام" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>
                        
                        <CheckBox Content="تفعيل نظام تنبيهات المخزون" IsChecked="{Binding EnableStockAlerts}" Margin="0,0,0,12" TabIndex="8" AutomationProperties.AutomationId="ChkEnableStockAlerts"/>
                        <CheckBox Content="السماح بالبيع بالسالب" IsChecked="{Binding AllowNegativeStock}" Margin="0,0,0,12" TabIndex="9" AutomationProperties.AutomationId="ChkAllowNegativeStock"/>
                        <CheckBox Content="تحديث الأسعار تلقائياً عند الشراء" IsChecked="{Binding AutoUpdatePrices}" TabIndex="10" AutomationProperties.AutomationId="ChkAutoUpdatePrices"/>
                    </StackPanel>
                </Border>

                <!-- Costing Method -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="💰 طريقة احتساب تكلفة المخزون" Style="{StaticResource HeaderStyle}" Margin="0,0,0,16"/>
                        
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="16" Margin="0,4" Background="#F1F8E9">
                            <StackPanel>
                                <RadioButton Content="متوسط التكلفة المرجح  (Weighted Average)"
                                             IsChecked="{Binding IsWeightedAverageSelected}"
                                             GroupName="CostingMethod"
                                             FontSize="14" FontWeight="Bold"
                                             ToolTip="يجمع بين سعر البضاعة القديمة في المخزن والجديدة ليعطيك تكلفة موحدة ومتوازنة"/>
                                <TextBlock Margin="28,6,0,0" TextWrapping="Wrap" Foreground="#555" FontSize="12"
                                           Text="يجمع بين سعر البضاعة القديمة في المخزن والجديدة ليعطيك تكلفة موحدة ومتوازنة. الأنسب للتقارير الضريبية الدقيقة وللمحاسبة القياسية."/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="16" Margin="0,4">
                            <StackPanel>
                                <RadioButton Content="آخر سعر توريد  (Last Purchase Price)"
                                             IsChecked="{Binding IsLastPriceSelected}"
                                             GroupName="CostingMethod"
                                             FontSize="14" FontWeight="Bold"
                                             ToolTip="يستبدل تكلفة المنتج بسعر آخر فاتورة شراء مباشرةً"/>
                                <TextBlock Margin="28,6,0,0" TextWrapping="Wrap" Foreground="#555" FontSize="12"
                                           Text="يستبدل تكلفة المنتج بسعر آخر فاتورة شراء مباشرةً. مناسب للأسواق المتقلبة حيث تريد دائماً أن يعكس السعر الواقع الحالي."/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                                Padding="16" Margin="0,4">
                            <StackPanel>
                                <RadioButton Content="سعر المورد  (Supplier Catalog Price)"
                                             IsChecked="{Binding IsSupplierPriceSelected}"
                                             GroupName="CostingMethod"
                                             FontSize="14" FontWeight="Bold"
                                             ToolTip="يعتمد على السعر المدخل في بطاقة الصنف من قائمة المورد ولا يتغير تلقائياً عند الشراء"/>
                                <TextBlock Margin="28,6,0,0" TextWrapping="Wrap" Foreground="#555" FontSize="12"
                                           Text="يعتمد على السعر المدخل في بطاقة الصنف من قائمة المورد ولا يتغير تلقائياً عند الشراء. مناسب عندما تتفاوض على سعر ثابت مع المورد لفترة طويلة."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Print Settings -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="🖨️ إعدادات الطباعة" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="طابعة A4" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding InstalledPrinters}"
                                          SelectedItem="{Binding A4PrinterName}"
                                          AutomationProperties.AutomationId="CmbA4Printer"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="الطابعة الحرارية (80mm)" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding InstalledPrinters}"
                                          SelectedItem="{Binding ThermalPrinterName}"
                                          AutomationProperties.AutomationId="CmbThermalPrinter"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,16">
                                <TextBlock Text="الرقم الضريبي (للفاتورة)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding StoreTaxNumber}" AutomationProperties.AutomationId="TxtStoreTaxNumber"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="شعار المتجر" Style="{StaticResource LabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding LogoPath}" IsReadOnly="True" AutomationProperties.AutomationId="TxtLogoPath"/>
                                    <Button Grid.Column="1" Content="تصفح..." Command="{Binding BrowseLogoCommand}" Margin="8,0,0,0" AutomationProperties.AutomationId="BtnBrowseLogo" ToolTip="اختيار ملف"/>
                                </Grid>
                            </StackPanel>

                            <Button Grid.Row="3" Grid.ColumnSpan="2"
                                    Command="{Binding TestPrintCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,8,0,0"
                                    Height="36"
                                    Padding="16,0"
                                    HorizontalAlignment="Right"
                                    ToolTip="إرسال أمر طباعة اختبارية للطابعة">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖨️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="طباعة اختبارية" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Database Maintenance -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="💾 صيانة قاعدة البيانات (النسخ الاحتياطي)" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="تنبيه: ينصح بإجراء نسخة احتياطية بشكل دوري لضمان سلامة البيانات." 
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="النسخ الاحتياطية المتوفرة" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Backups}" 
                                          SelectedItem="{Binding SelectedBackup}" 
                                          AutomationProperties.AutomationId="CmbBackups"/>
                            </StackPanel>

                            <Button Grid.Column="1" 
                                    Content="🔄 استعادة النسخة المختارة" 
                                    Command="{Binding RestoreBackupCommand}"
                                    Style="{StaticResource DangerButton}"
                                    VerticalAlignment="Bottom"
                                    Width="180"
                                    AutomationProperties.AutomationId="BtnRestoreBackup"
                                    ToolTip="استعادة النسخة الاحتياطية المحددة"/>
                        </Grid>

                        <Button Content="📦 إنشاء نسخة احتياطية جديدة الآن" 
                                Command="{Binding CreateBackupCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left"
                                Padding="20,10"
                                AutomationProperties.AutomationId="BtnCreateBackup"
                                ToolTip="إنشاء نسخة احتياطية فورية"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Margin="0,24,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="💾 حفظ الإعدادات"
                            Command="{Binding SaveCommand}"
                            IsDefault="True"
                            TabIndex="11"
                            AutomationProperties.AutomationId="BtnSaveSettings"
                            ToolTip="حفظ إعدادات النظام"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ الإعدادات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>

