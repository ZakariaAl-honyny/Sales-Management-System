<UserControl x:Class="SalesSystem.DesktopPWF.Views.Settings.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24,24,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="⚙️  إعدادات النظام"
                   Style="{StaticResource HeaderStyle}"
                   Margin="0,0,0,24"
                   AutomationProperties.AutomationId="SettingsPageTitle"/>

        <!-- Error Message Bar -->
        <Border Grid.Row="1"
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="0,0,0,8"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorTextBrush}" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Company Info -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="🏢 بيانات الشركة" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="اسم المنشأة *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CompanyName}" TabIndex="1" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyName"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="الرقم الضريبي" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding TaxNumber}" TabIndex="2" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyTaxNo"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="رقم الهاتف" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Phone}" TabIndex="3" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyPhone"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="البريد الإلكتروني" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Email}" TabIndex="4" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyEmail"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                <TextBlock Text="العنوان" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Address}" TextWrapping="Wrap" AcceptsReturn="True" TabIndex="5" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtCompanyAddress"/>
                            </StackPanel>

                            <!-- Signature Path -->
                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                <TextBlock Text="ملف التوقيع (للطباعة على الفواتير)" Style="{StaticResource LabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding SignaturePath}" IsReadOnly="True"
                                             AutomationProperties.AutomationId="TxtSignaturePath"
                                             ToolTip="مسار ملف صورة التوقيع الذي سيظهر على الفواتير المطبوعة"/>
                                    <Button Grid.Column="1" Content="تصفح..." Margin="8,0,0,0"
                                            Command="{Binding BrowseSignatureCommand}"
                                            AutomationProperties.AutomationId="BtnBrowseSignature"
                                            ToolTip="اختيار ملف التوقيع لطباعته على الفواتير"/>
                                    <Button Grid.Column="2" Content="✕" Margin="4,0,0,0"
                                            Command="{Binding ClearSignatureCommand}"
                                            AutomationProperties.AutomationId="BtnClearSignature"
                                            ToolTip="إزالة التوقيع المحدد"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Invoice Settings -->
                <!-- DEPRECATED: DefaultTaxRate and InvoicePrefix are hidden. Tax entity is the source of truth. Remove in Phase 20. -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="📄 إعدادات الفواتير (ملغية)" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="نسبة الضريبة الافتراضية (%)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding DefaultTaxRate, StringFormat=N2}" TabIndex="6" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtDefaultTaxRate"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="بادئة رقم الفاتورة" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding InvoicePrefix}" TabIndex="7" helpers:FocusHelper.AdvanceOnEnter="True" AutomationProperties.AutomationId="TxtInvoicePrefix"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- System Options -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="⚙️ خيارات النظام" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>
                        
                        <CheckBox Content="تفعيل نظام تنبيهات المخزون" IsChecked="{Binding EnableStockAlerts}" Margin="0,0,0,12" TabIndex="8" AutomationProperties.AutomationId="ChkEnableStockAlerts"/>
                        <CheckBox Content="تحديث الأسعار تلقائياً عند الشراء" IsChecked="{Binding AutoUpdatePrices}" TabIndex="9" AutomationProperties.AutomationId="ChkAutoUpdatePrices"/>

                        <!-- Costing Method -->
                        <TextBlock Text="طريقة تقييم المخزون" Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                        <RadioButton Content="المتوسط المرجح (Weighted Average)"
                                     IsChecked="{Binding IsWeightedAverageSelected}"
                                     ToolTip="المتوسط المرجح — طريقة تقييم المخزون الافتراضية"
                                     GroupName="CostingMethod" Margin="0,4,0,2"/>
                        <RadioButton Content="آخر سعر شراء (Last Purchase Price)"
                                     IsChecked="{Binding IsLastPriceSelected}"
                                     ToolTip="استخدام آخر سعر شراء كتكلفة للمخزون"
                                     GroupName="CostingMethod" Margin="0,2,0,2"/>
                        <RadioButton Content="سعر المورد (Supplier Price)"
                                     IsChecked="{Binding IsSupplierPriceSelected}"
                                     ToolTip="استخدام سعر المورد المدرج في كرت الصنف"
                                     GroupName="CostingMethod" Margin="0,2,0,6"/>
                    </StackPanel>
                </Border>

                <!-- Print Settings -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="🖨️ إعدادات الطباعة" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="طابعة A4" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding InstalledPrinters}"
                                          SelectedItem="{Binding A4PrinterName}"
                                          AutomationProperties.AutomationId="CmbA4Printer"
                                          ToolTip="اختيار طابعة A4 لطباعة الفواتير — يجب أن تكون الطابعة مثبتة على هذا الجهاز"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="الطابعة الحرارية (80mm)" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding InstalledPrinters}"
                                          SelectedItem="{Binding ThermalPrinterName}"
                                          AutomationProperties.AutomationId="CmbThermalPrinter"
                                          ToolTip="اختيار الطابعة الحرارية (80mm) لإيصالات البيع — تأكد من تعريف الطابعة في النظام"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="رأس الإيصال الحراري" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding ReceiptHeader, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="200"
                                         ToolTip="يظهر في أعلى الإيصال الحراري (مثال: أهلاً بكم في متجر النجمة)"
                                         AutomationProperties.AutomationId="TxtReceiptHeader"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="تذييل الإيصال الحراري" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding ReceiptFooter, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="200"
                                         ToolTip="يظهر في أسفل الإيصال الحراري (مثال: شكراً لتسوقكم معنا)"
                                         AutomationProperties.AutomationId="TxtReceiptFooter"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="كود صفحة ESC/POS" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding EscPosCodePage, TargetNullValue=22}"
                                         ToolTip="كود الصفحة للطابعة الحرارية — 22 = IBM864 يدعم اللغة العربية"
                                         AutomationProperties.AutomationId="TxtEscPosCodePage"/>
                            </StackPanel>

                            <CheckBox Grid.Row="3" Grid.ColumnSpan="2"
                                      Content="🖨️ طباعة إيصال حراري تلقائياً بعد الترحيل"
                                      IsChecked="{Binding AutoPrintOnPost}"
                                      Margin="0,0,0,16"
                                      ToolTip="عند ترحيل فاتورة بيع، يتم إرسال إيصال حراري تلقائياً إلى الطابعة المحددة"
                                      AutomationProperties.AutomationId="ChkAutoPrintOnPost"/>

                            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,16">
                                <TextBlock Text="الرقم الضريبي (للفاتورة)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding StoreTaxNumber}" AutomationProperties.AutomationId="TxtStoreTaxNumber"
                                         ToolTip="الرقم الضريبي للمنشأة — يظهر على الفواتير والإيصالات المطبوعة"/>
                            </StackPanel>

                            <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="شعار المتجر" Style="{StaticResource LabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding LogoPath}" IsReadOnly="True" AutomationProperties.AutomationId="TxtLogoPath"/>
                                    <Button Grid.Column="1" Content="تصفح..." Command="{Binding BrowseLogoCommand}" Margin="8,0,0,0" AutomationProperties.AutomationId="BtnBrowseLogo" ToolTip="اختيار ملف"/>
                                </Grid>
                            </StackPanel>

                            <Button Grid.Row="6" Grid.ColumnSpan="2"
                                    Command="{Binding TestPrintCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Right"
                                    ToolTip="إرسال أمر طباعة اختبارية للطابعة">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖨️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="طباعة اختبارية" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Paper Size -->
                            <StackPanel Grid.Row="7" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="حجم الورق" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding PaperSize}" ToolTip="حجم الورق الافتراضي للطباعة (A4, A5, أو مخصص)"/>
                            </StackPanel>

                            <!-- Print Copies -->
                            <StackPanel Grid.Row="7" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="عدد النسخ" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding PrintCopies}" ToolTip="عدد نسخ الطباعة الافتراضية"/>
                            </StackPanel>

                            <!-- Show Balance -->
                            <CheckBox Grid.Row="8" Grid.ColumnSpan="2"
                                      Content="إظهار الرصيد في الفاتورة"
                                      IsChecked="{Binding ShowBalanceOnPrint}"
                                      Margin="0,0,0,12"
                                      ToolTip="عرض رصيد الحساب في الفاتورة المطبوعة"/>

                            <!-- Print Signature -->
                            <CheckBox Grid.Row="9" Grid.ColumnSpan="2"
                                      Content="طباعة التوقيع"
                                      IsChecked="{Binding PrintSignature}"
                                      Margin="0,0,0,12"
                                      ToolTip="طباعة صورة التوقيع في أسفل الفاتورة"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Note: Backup & Database Maintenance moved to BackupView -->
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Margin="0,24,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="💾 حفظ الإعدادات"
                            Command="{Binding SaveCommand}"
                            IsDefault="True"
                            TabIndex="11"
                            AutomationProperties.AutomationId="BtnSaveSettings"
                            ToolTip="حفظ جميع إعدادات النظام بما في ذلك إعدادات الطباعة وطريقة احتساب التكلفة — سيتم تطبيق التغييرات فوراً"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ الإعدادات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

