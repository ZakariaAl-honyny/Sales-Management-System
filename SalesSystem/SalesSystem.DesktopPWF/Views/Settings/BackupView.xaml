<UserControl x:Class="SalesSystem.DesktopPWF.Views.Settings.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             d:DesignHeight="500" d:DesignWidth="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="النسخ الاحتياطي واستعادة البيانات"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#333"/>
            <TextBlock Text="إنشاء واستعادة النسخ الاحتياطية لقاعدة البيانات"
                       FontSize="12"
                       Foreground="#666"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Create Backup Button -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <Button Content="إنشاء نسخة احتياطية الآن"
                    Command="{Binding CreateBackupCommand}"
                    ToolTip="إنشاء نسخة احتياطية جديدة من قاعدة البيانات"
                    Padding="20,10"
                    Background="#1976D2"
                    Foreground="White"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Right"
                    Width="220"/>
        </StackPanel>

        <!-- Backup Path Info -->
        <Border Grid.Row="2"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="مسار النسخ: " FontWeight="SemiBold" Foreground="#555"/>
                <TextBlock Text="{Binding BackupPath}" Foreground="#777"/>
            </StackPanel>
        </Border>

        <!-- Backups List -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="النسخ المتاحة:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding BackupFiles}"
                      SelectedItem="{Binding SelectedBackupFile}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      AlternatingRowBackground="#F9F9F9"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="#E0E0E0"
                      BorderThickness="1">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Background" Value="#F0F0F0"/>
                        <Setter Property="Padding" Value="8,6"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم الملف"
                                        Binding="{Binding FileName}"
                                        Width="*"
                                        MinWidth="200"/>
                    <DataGridTextColumn Header="الحجم"
                                        Binding="{Binding DisplaySize}"
                                        Width="100"/>
                    <DataGridTextColumn Header="التاريخ"
                                        Binding="{Binding CreatedAt}"
                                        Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Restore Button -->
        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <Button Content="استعادة من النسخة المحددة"
                    Command="{Binding RestoreBackupCommand}"
                    ToolTip="استعادة قاعدة البيانات من النسخة المحددة — سيتم إغلاق النظام"
                    Padding="20,10"
                    Background="#E65100"
                    Foreground="White"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Right"
                    Width="240"/>
        </StackPanel>

        <!-- Status Bar -->
        <Border Grid.Row="5"
                Background="#FFF8E1"
                BorderBrush="#FFC107"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                Margin="0,12,0,0"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#F57F17"
                       TextWrapping="Wrap"
                       FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
