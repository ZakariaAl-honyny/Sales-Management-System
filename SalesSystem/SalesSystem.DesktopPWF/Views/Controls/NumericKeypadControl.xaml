<UserControl x:Class="SalesSystem.DesktopPWF.Views.Controls.NumericKeypadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views.Controls"
             FlowDirection="LeftToRight">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Row 1: 1, 2, 3 -->
        <Button Grid.Row="0" Grid.Column="0"
                Content="1"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 1" />
        <Button Grid.Row="0" Grid.Column="1"
                Content="2"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 2" />
        <Button Grid.Row="0" Grid.Column="2"
                Content="3"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 3" />

        <!-- Row 2: 4, 5, 6 -->
        <Button Grid.Row="1" Grid.Column="0"
                Content="4"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 4" />
        <Button Grid.Row="1" Grid.Column="1"
                Content="5"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 5" />
        <Button Grid.Row="1" Grid.Column="2"
                Content="6"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 6" />

        <!-- Row 3: 7, 8, 9 -->
        <Button Grid.Row="2" Grid.Column="0"
                Content="7"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 7" />
        <Button Grid.Row="2" Grid.Column="1"
                Content="8"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 8" />
        <Button Grid.Row="2" Grid.Column="2"
                Content="9"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 9" />

        <!-- Row 4: 0 (span 2 columns), ⌫ (Backspace), مسح (Clear) -->
        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                Content="0"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="NumberButton_Click"
                ToolTip="إدخال الرقم 0" />
        <Button Grid.Row="3" Grid.Column="2"
                Content="⌫"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="BackspaceButton_Click"
                ToolTip="حذف آخر رقم" />
        <Button Grid.Row="3" Grid.Column="3"
                Content="مسح"
                MinHeight="50" MinWidth="60"
                FontSize="20"
                Click="ClearButton_Click"
                ToolTip="مسح جميع الأرقام" />
    </Grid>
</UserControl>
