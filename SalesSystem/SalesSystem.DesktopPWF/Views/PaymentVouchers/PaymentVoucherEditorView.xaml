<UserControl x:Class="SalesSystem.DesktopPWF.Views.PaymentVouchers.PaymentVoucherEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📤" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>
                        <!-- Voucher No (read-only) -->
                        <TextBlock Text="رقم السند" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding VoucherNo, Mode=OneWay}" Style="{StaticResource ModernTextBox}"
                                 IsReadOnly="True" Tag="يُحدد تلقائياً"
                                 ToolTip="رقم السند — يُحدد تلقائياً بواسطة النظام"/>
                        <Border Height="12"/>

                        <!-- Date -->
                        <TextBlock Text="التاريخ *" Style="{StaticResource LabelStyle}"/>
                        <DatePicker SelectedDate="{Binding VoucherDate}" Style="{StaticResource ModernDatePicker}"
                                    ToolTip="تاريخ سند الصرف"/>
                        <Border Height="12"/>

                        <!-- CashBox + Account -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="رقم الصندوق *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CashBoxId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource ModernTextBox}" Tag="أدخل رقم الصندوق"
                                         ToolTip="أدخل رقم الصندوق — هذا الحقل إلزامي"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="رقم الحساب *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding AccountId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource ModernTextBox}" Tag="أدخل رقم الحساب"
                                         ToolTip="أدخل رقم الحساب المحاسبي — هذا الحقل إلزامي"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="12"/>

                        <!-- Currency + Amount -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="رقم العملة *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CurrencyId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource ModernTextBox}" Tag="أدخل رقم العملة"
                                         ToolTip="أدخل رقم العملة (مثال: 1 للعملة الأساسية)"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="المبلغ *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding TotalAmount, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}"
                                         Style="{StaticResource ModernTextBox}" Tag="0.00"
                                         ToolTip="مبلغ سند الصرف — يجب أن يكون أكبر من صفر"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="12"/>

                        <!-- Notes -->
                        <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"
                                 Tag="ملاحظات إضافية" TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                 ToolTip="ملاحظات إضافية حول سند الصرف"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Width="140" Margin="0,0,12,0"
                            ToolTip="حفظ سند الصرف — سيتم التحقق من صحة الحقول قبل الحفظ">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}" Width="100"
                            ToolTip="إلغاء وإغلاق النافذة">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                           FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap"
                           Margin="0,8,0,0" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#80FFFFFF" Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري الحفظ..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
