<UserControl x:Class="SalesSystem.DesktopPWF.Views.PaymentVouchers.PaymentVoucherListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.PaymentVouchers"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:PaymentVoucherListViewModel}"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📤  سندات الصرف" Style="{StaticResource HeaderStyle}"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="بحث" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="180" Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="رقم السند أو الصندوق...">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>

                <!-- Date Filters -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="من" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker SelectedDate="{Binding FromDate}" Style="{StaticResource ModernDatePicker}" Width="130"
                                ToolTip="تصفية من تاريخ"/>
                    <TextBlock Text="إلى" VerticalAlignment="Center" Margin="8,0,6,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker SelectedDate="{Binding ToDate}" Style="{StaticResource ModernDatePicker}" Width="130"
                                ToolTip="تصفية إلى تاريخ"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="إنشاء سند صرف جديد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="سند صرف جديد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل سند الصرف المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding PostCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                            ToolTip="ترحيل سند الصرف — سيتم إنشاء القيد المحاسبي وتحديث الرصيد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ترحيل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelCommand}" Style="{StaticResource WarningButton}" Margin="0,0,4,0"
                            ToolTip="إلغاء سند الصرف — عكس القيد المحاسبي إن كان مرحلة">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚫" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            ToolTip="حذف سند الصرف المحدد (المسودات فقط)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حذف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ClearFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="مسح جميع الفلاتر وإعادة التحميل">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="مسح الفلاتر" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة سندات الصرف">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message -->
        <Border Grid.Row="2" Background="{StaticResource ErrorLightBrush}" BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1" Padding="12,8" Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" FontWeight="SemiBold"
                           VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding VouchersView}" SelectedItem="{Binding SelectedVoucher}"
                          Style="{StaticResource ModernDataGrid}" IsReadOnly="True" BorderThickness="0"
                          MouseDoubleClick="VouchersDataGrid_MouseDoubleClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" Command="{Binding EditCommand}">
                                <MenuItem.Icon><TextBlock Text="✏️"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="ترحيل" Command="{Binding PostCommand}">
                                <MenuItem.Icon><TextBlock Text="🚀"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="إلغاء" Command="{Binding CancelCommand}">
                                <MenuItem.Icon><TextBlock Text="🚫"/></MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم السند" Binding="{Binding VoucherNo}" Width="80" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding VoucherDate, StringFormat=yyyy/MM/dd}" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="الصندوق" Binding="{Binding CashBoxName}" Width="120" CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="الحساب" Binding="{Binding AccountName}" Width="*" CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="المبلغ" Binding="{Binding TotalAmount, StringFormat=N2}" Width="120" CellStyle="{StaticResource DataGridCellNumberStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="0,0,12,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="العملة" Binding="{Binding CurrencyCode}" Width="70" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTemplateColumn Header="الحالة" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3">
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Setter Property="Text" Value="مسودة"/>
                                                    <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Text" Value="مرحل"/>
                                                            <Setter Property="Foreground" Value="{StaticResource InfoTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Text" Value="ملغي"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📤" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد سندات صرف" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="انقر على 'سند صرف جديد' للبدء" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ سند صرف جديد" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="140"
                                ToolTip="فتح شاشة إضافة سند صرف جديد"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource FooterBarStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="إجمالي سندات الصرف: " Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding VouchersCount}" Style="{StaticResource FooterBarTextStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5" Background="#80FFFFFF" Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل البيانات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
