<UserControl x:Class="SalesSystem.DesktopPWF.Views.InventoryAdjustment.InventoryAdjustmentEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚖️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>
                        <!-- Adjustment No -->
                        <TextBlock Text="رقم التسوية" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding AdjustmentNo, Mode=OneWay}" Style="{StaticResource ModernTextBox}"
                                 IsReadOnly="True" Tag="يُحدد تلقائياً"
                                 ToolTip="رقم التسوية — يُحدد تلقائياً بواسطة النظام"/>
                        <Border Height="12"/>

                        <!-- Warehouse + Date -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="رقم المستودع *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding WarehouseId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource ModernTextBox}" Tag="أدخل رقم المستودع"
                                         ToolTip="أدخل رقم المستودع — هذا الحقل إلزامي"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="تاريخ التسوية *" Style="{StaticResource LabelStyle}"/>
                                <DatePicker SelectedDate="{Binding AdjustmentDate}" Style="{StaticResource ModernDatePicker}"
                                            ToolTip="تاريخ التسوية"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="12"/>

                        <!-- Adjustment Type + Account -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="نوع التسوية *" Style="{StaticResource LabelStyle}"/>
                                <ComboBox SelectedIndex="{Binding AdjustmentType, Converter={StaticResource ByteToIndexConverter}}"
                                          Style="{StaticResource ModernComboBox}"
                                          ToolTip="اختر نوع التسوية (إضافة، خصم، تصحيح)">
                                    <ComboBoxItem Content="إضافة" Tag="1"/>
                                    <ComboBoxItem Content="خصم" Tag="2"/>
                                    <ComboBoxItem Content="تصحيح" Tag="3"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="رقم الحساب المحاسبي *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding AccountId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource ModernTextBox}" Tag="أدخل رقم الحساب"
                                         ToolTip="أدخل رقم الحساب المحاسبي المقابل للتسوية"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="16"/>

                        <!-- Lines Section -->
                        <TextBlock Text="بنود التسوية" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                        <Border Background="{StaticResource InfoLightBrush}" Padding="12,8" CornerRadius="6" Margin="0,0,0,12">
                            <TextBlock Text="الكمية: أدخل كمية التسوية وتكلفة الوحدة. سيتم حساب الإجمالي تلقائياً."
                                       FontSize="11" Foreground="{StaticResource InfoTextBrush}" TextWrapping="Wrap"/>
                        </Border>

                        <DataGrid ItemsSource="{Binding Lines}" SelectedItem="{Binding SelectedLine}"
                                  Style="{StaticResource ModernDataGrid}" IsReadOnly="True" Height="200"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity, StringFormat=N3}" Width="80" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                <DataGridTextColumn Header="تكلفة الوحدة" Binding="{Binding UnitCost, StringFormat=N2}" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, StringFormat=N2}" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Width="140" Margin="0,0,12,0" IsDefault="True"
                            ToolTip="حفظ التسوية — سيتم التحقق من صحة الحقول قبل الحفظ">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حفظ"/>
                        </StackPanel>
                    </Button>
                    <Button Content="إلغاء" Command="{Binding CancelDialogCommand}" Style="{StaticResource SecondaryButton}" Width="100"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                           FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap"
                           Margin="0,8,0,0" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#80FFFFFF" Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري الحفظ..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
