<UserControl x:Class="SalesSystem.DesktopPWF.Views.Accounts.AccountEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1E293B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📒" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource HeaderStyle}" Foreground="White"/>
                    </StackPanel>
                    <TextBlock Text="إدارة دليل الحسابات المحاسبية" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Form Content -->
        <ScrollViewer Grid.Row="1">
            <Border Padding="16">
                <StackPanel>
                    <!-- Account Code (Only visible in Edit Mode / ReadOnly) -->
                    <TextBlock Text="رمز الحساب" Style="{StaticResource LabelStyle}" Margin="4,0,0,8" 
                               Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBox Text="{Binding AccountCode, Mode=OneWay}"
                             Style="{StaticResource ModernTextBox}"
                             IsReadOnly="True"
                             Background="#F1F5F9"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                             ToolTip="رمز الحساب يتم توليده تلقائياً من قبل النظام"/>
                    <TextBlock Text="رمز الحساب يُولد تلقائياً"
                               Style="{StaticResource HelperTextStyle}"
                               Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Parent Account -->
                    <TextBlock Text="الحساب الأب *" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"/>
                    <ComboBox ItemsSource="{Binding ParentAccountOptions}"
                              SelectedValue="{Binding SelectedParentId}"
                              SelectedValuePath="Key"
                              DisplayMemberPath="Value"
                              IsEditable="True"
                              IsReadOnly="False"
                              TextSearch.TextPath="Value"
                              TabIndex="1"
                              IsEnabled="{Binding IsCreating}"
                              Style="{StaticResource ModernComboBox}"
                              ToolTip="اختر الحساب الأب للحساب الجديد — سيتم تحديد المستوى تلقائياً حسب الحساب الأب">
                        <ComboBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ComboBox.ItemsPanel>
                    </ComboBox>
                    <TextBlock Text="عند تغيير الحساب الأب، يتم تحديث مستوى الحساب تلقائياً"
                               Style="{StaticResource HelperTextStyle}" Margin="0,2,0,8"/>

                    <!-- Name Ar -->
                    <TextBlock Text="اسم الحساب (عربي) *" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"/>
                    <TextBox Text="{Binding NameAr, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                             Style="{StaticResource ModernTextBox}"
                             TabIndex="2"
                             ToolTip="اسم الحساب باللغة العربية — هذا الحقل إلزامي"/>

                    <!-- Name En -->
                    <TextBlock Text="اسم الحساب (إنجليزي)" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"/>
                    <TextBox Text="{Binding NameEn}"
                             Style="{StaticResource ModernTextBox}"
                             TabIndex="3"
                             ToolTip="اسم الحساب باللغة الإنجليزية — اختياري"/>

                    <!-- AccountType + Level (auto-filled from parent, display-only) -->
                    <Grid Margin="0,8,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="نوع الحساب" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                            <TextBox Text="{Binding NatureDisplay, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Background="#F1F5F9"
                                     Style="{StaticResource ModernTextBox}"
                                     TabIndex="4"
                                     ToolTip="نوع الحساب يتم تحديده تلقائياً من الحساب الأب"/>
                            <TextBlock Text="يُحدد تلقائياً من الحساب الأب"
                                       Style="{StaticResource HelperTextStyle}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="مستوى الحساب" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                            <TextBox Text="{Binding LevelDisplay, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Background="#F1F5F9"
                                     Style="{StaticResource ModernTextBox}"
                                     TabIndex="5"
                                     ToolTip="مستوى الحساب يتم تحديده تلقائياً من الحساب الأب"/>
                            <TextBlock Text="يُحدد تلقائياً من الحساب الأب"
                                       Style="{StaticResource HelperTextStyle}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- AllowTransactions -->
                    <CheckBox IsChecked="{Binding AllowTransactions}" Content="يسمح بالحركات"
                              TabIndex="7"
                              IsEnabled="{Binding IsAllowTransactionsEditable}"
                              ToolTip="تفعيل هذا الخيار للسماح بإضافة قيود يومية على هذا الحساب"
                              Margin="0,8,0,6"/>

                    <!-- OpeningBalance -->
                    <TextBlock Text="الرصيد الافتتاحي" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"
                               Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBox Text="{Binding OpeningBalance, TargetNullValue=''}"
                             Style="{StaticResource ModernTextBox}"
                             Width="150"
                             HorizontalAlignment="Right"
                             TabIndex="8"
                             Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibility}}"
                             ToolTip="الرصيد الافتتاحي للحساب عند بدء استخدام النظام"/>

                    <!-- Description -->
                    <TextBlock Text="الوصف التفصيلي" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"/>
                    <TextBox Text="{Binding Description}" AcceptsReturn="True" MaxHeight="80"
                             TabIndex="9"
                             ToolTip="وصف تفصيلي للحساب — يظهر في التقارير"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F8FAFC" Padding="12,8" BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="150"
                            IsDefault="True"
                            TabIndex="10"
                            Margin="0,0,12,0"
                            ToolTip="حفظ الحساب — سيتم التحقق من البيانات قبل الحفظ">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حفظ البيانات" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Content="❌ إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100"
                            TabIndex="11"
                            ToolTip="إلغاء التعديل والعودة إلى قائمة الحسابات"/>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CCFFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                CornerRadius="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="180" Height="4" Background="#E2E8F0" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" FontWeight="SemiBold" Margin="0,16,0,0" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
