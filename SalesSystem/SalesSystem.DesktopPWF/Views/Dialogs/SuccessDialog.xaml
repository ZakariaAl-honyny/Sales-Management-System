<Window x:Class="SalesSystem.DesktopPWF.Views.Dialogs.SuccessDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">

    <Grid>
        <Rectangle Fill="#80000000"/>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="16" 
                Width="400" MinHeight="170" Padding="20"
                Effect="{StaticResource DeepShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Background="#E8F5E9" CornerRadius="22" Width="44" Height="44">
                        <TextBlock Text="&#10004;" FontSize="20" FontWeight="Bold" Foreground="#388E3C"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="نجاح" FontSize="16" FontWeight="Bold" Foreground="#388E3C"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14"
                               Foreground="#333" LineHeight="24"/>
                </ScrollViewer>

                <Button ToolTip="تأكيد وإغلاق النافذة" Grid.Row="2" Content="حسناً" MinWidth="80"
                        HorizontalAlignment="Center" Margin="0,12,0,0"
                        Background="#388E3C" Foreground="White" FontWeight="SemiBold" FontSize="11"
                        BorderThickness="0" Cursor="Hand" Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                    CornerRadius="6" Padding="10,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#2E7D32"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#1B5E20"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
