<Window x:Class="SalesSystem.DesktopPWF.Views.Dialogs.WarningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">

    <Grid>
        <!-- طبقة التعتيم (Dimming Overlay) -->
        <Rectangle Fill="#80000000"/>

        <!-- بطاقة الحوار المركزية -->
        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="16" 
                Width="440" MinHeight="220" Padding="28"
                Effect="{StaticResource DeepShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="#FFF3E0" CornerRadius="25" Width="50" Height="50">
                        <TextBlock Text="&#9888;" FontSize="24" FontWeight="Bold" Foreground="#F57C00"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="تحذير" FontSize="20" FontWeight="Bold" Foreground="#F57C00"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14"
                               Foreground="#333" LineHeight="24"/>
                </ScrollViewer>

                <Button Grid.Row="2" Content="حسناً" Width="100" Height="36"
                        HorizontalAlignment="Center" Margin="0,16,0,0"
                        Background="#F57C00" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                    CornerRadius="8" Padding="14,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#E67E22"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#D35400"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
