<Window x:Class="SalesSystem.DesktopPWF.Views.Dialogs.DatabaseErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">

    <Grid>
        <Rectangle Fill="#80000000"/>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="16" 
                Width="460" MinHeight="310" Padding="28"
                Effect="{StaticResource DeepShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Error state -->
                <StackPanel x:Name="ErrorPanel" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Background="#FFF3E0" CornerRadius="25" Width="50" Height="50">
                        <TextBlock Text="&#9888;" FontSize="28" FontWeight="Bold" Foreground="#E65100"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="تعذر الاتصال بقاعدة البيانات" FontSize="18" FontWeight="Bold" Foreground="#E65100"/>
                        <TextBlock Text="Database Connection Error" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Retrying state -->
                <StackPanel x:Name="RetryingPanel" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" Visibility="Collapsed">
                    <Border Background="#E3F2FD" CornerRadius="25" Width="50" Height="50">
                        <TextBlock Text="&#969;" FontSize="28" FontWeight="Bold" Foreground="#1565C0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock x:Name="RetryingTitle" Text="جاري إعادة المحاولة..." FontSize="18" FontWeight="Bold" Foreground="#1565C0"/>
                        <TextBlock Text="Retrying Connection" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Error message content -->
                <ScrollViewer x:Name="ErrorContentPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14"
                                   Foreground="#333" LineHeight="24"/>
                        <Border Background="#FFF8E1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
                            <TextBlock Text="تأكد من أن:
• الخادم (Server) قيد التشغيل
• اسم قاعدة البيانات صحيح
• إعدادات الاتصال في التطبيق صحيحة" 
                                       FontSize="12" Foreground="#795548" LineHeight="20"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Retrying content -->
                <StackPanel x:Name="RetryingContentPanel" Grid.Row="1" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="300" Height="6" Margin="0,0,0,16"
                                 Foreground="#1565C0" Background="#E0E0E0"/>
                    <TextBlock x:Name="RetryingStatusText" Text="جاري الاتصال بقاعدة البيانات..."
                               FontSize="13" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Buttons - Error state -->
                <StackPanel x:Name="ErrorButtonsPanel" Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Button x:Name="RetryButton" Content="إعادة المحاولة" Width="130" Height="38"
                            Background="#E65100" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand" Click="RetryButton_Click" Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="RetryBorder" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="12,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="RetryBorder" Property="Background" Value="#D84315"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="RetryBorder" Property="Background" Value="#BF360C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="ExitButton" Content="خروج" Width="100" Height="38"
                            Background="#9E9E9E" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand" Click="ExitButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ExitBorder" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="12,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ExitBorder" Property="Background" Value="#757575"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ExitBorder" Property="Background" Value="#616161"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Buttons - Retrying state (only Exit) -->
                <StackPanel x:Name="RetryingButtonsPanel" Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed">
                    <Button x:Name="CancelRetryButton" Content="إلغاء" Width="100" Height="38"
                            Background="#9E9E9E" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand" Click="ExitButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CancelRetryBorder" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="12,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CancelRetryBorder" Property="Background" Value="#757575"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CancelRetryBorder" Property="Background" Value="#616161"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
