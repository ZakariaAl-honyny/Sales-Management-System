<Window x:Class="SalesSystem.DesktopPWF.Views.Dialogs.FallbackErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="خطأ في النظام"
        Width="500" Height="250"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="⚠️ حدث خطأ غير متوقع" FontSize="18" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="1" Text="{Binding}" TextWrapping="Wrap" FontSize="13" Foreground="#333"/>
        <Button ToolTip="تأكيد العملية" Grid.Row="2" Content="موافق" Width="120" Height="35" HorizontalAlignment="Center"
                Background="#1976D2" Foreground="White" FontSize="14"
                Click="OkButton_Click" Margin="0,10,0,0"/>
    </Grid>
</Window>
