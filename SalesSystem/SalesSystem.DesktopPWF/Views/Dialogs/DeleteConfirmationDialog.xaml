<Window x:Class="SalesSystem.DesktopPWF.Views.Dialogs.DeleteConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">

    <Grid>
        <Rectangle Fill="#80000000"/>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="16" 
                Width="520" MinHeight="300" Padding="28"
                Effect="{StaticResource DeepShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Background="#FFF3E0" CornerRadius="30" Width="60" Height="60">
                        <TextBlock Text="&#9888;" FontSize="32" Foreground="#FF9800"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="تأكيد الحذف" FontSize="22" FontWeight="Bold" Foreground="#E65100"/>
                        <TextBlock x:Name="ItemNameText" FontSize="14" Foreground="#666" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="اختر نوع الحذف المطلوب:"
                           FontSize="14" Foreground="#333" Margin="0,0,0,16"/>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button ToolTip="إلغاء العملية الحالية" x:Name="CancelButton" Content="إلغاء الأمر"
                            Width="130" Height="42" Margin="0,0,12,0"
                            Background="#9E9E9E" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Click="CancelButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#757575"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#616161"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button ToolTip="تعطيل العنصر مع الاحتفاظ به في قاعدة البيانات" x:Name="DeactivateButton" Content="إلغاء تنشيط"
                            Width="130" Height="42" Margin="0,0,12,0"
                            Background="#FF9800" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Click="DeactivateButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#F57C00"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#E65100"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button ToolTip="حذف العنصر نهائياً — لا يمكن التراجع عن هذا الإجراء" x:Name="DeleteButton" Content="حذف نهائي"
                            Width="130" Height="42"
                            Background="#D32F2F" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Click="DeleteButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#C62828"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#B71C1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
