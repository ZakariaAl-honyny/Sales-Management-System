<Window x:Class="SalesSystem.DesktopPWF.Views.Dialogs.DeleteConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تأكيد الحذف"
        Height="300" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Background="#F5F5F5">

    <Border Margin="20" Background="White" CornerRadius="8" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with Warning Icon -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Border Background="#FFF3E0" CornerRadius="30" Width="60" Height="60">
                    <TextBlock Text="&#9888;" FontSize="32" Foreground="#FF9800"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="تأكيد الحذف" FontSize="22" FontWeight="Bold" Foreground="#E65100"/>
                    <TextBlock x:Name="ItemNameText" FontSize="14" Foreground="#666" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Message -->
            <TextBlock Grid.Row="1" Text="اختر نوع الحذف المطلوب:"
                       FontSize="14" Foreground="#333" Margin="0,0,0,12"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Button x:Name="CancelButton" Content="إلغاء الأمر"
                        Width="130" Height="45" Margin="0,0,12,0"
                        Background="#9E9E9E" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"
                        Click="CancelButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="DeactivateButton" Content="إلغاء تنشيط"
                        Width="130" Height="45" Margin="0,0,12,0"
                        Background="#FF9800" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"
                        Click="DeactivateButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="DeleteButton" Content="حذف نهائي"
                        Width="130" Height="45"
                        Background="#D32F2F" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"
                        Click="DeleteButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>