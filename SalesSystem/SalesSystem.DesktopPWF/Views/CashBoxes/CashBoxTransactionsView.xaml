<UserControl x:Class="SalesSystem.DesktopPWF.Views.CashBoxes.CashBoxTransactionsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.CashBoxes"
      mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding CashBoxName, StringFormat='💰  حركات الصندوق - {0}'}"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="CashBoxTransactionsPageTitle"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">

                    <!-- Expense Amount -->
                    <Border Style="{StaticResource CardStyle}" Padding="8,4" Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="مبلغ المصروف:" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding ExpenseAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="أدخل مبلغ المصروف المراد تسجيله"/>
                        </StackPanel>
                    </Border>

                    <!-- Expense Notes -->
                    <Border Style="{StaticResource CardStyle}" Padding="8,4" Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ملاحظات:" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding ExpenseNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="ملاحظات إضافية حول المصروف (اختياري)"/>
                        </StackPanel>
                    </Border>

                    <!-- Record Expense Button -->
                    <Button Command="{Binding RecordExpenseCommand}" Style="{StaticResource DangerButton}" Margin="0,0,8,0"
                            ToolTip="تسجيل مصروف نقدي من الصندوق — سيتم خصم المبلغ من الرصيد الحالي">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تسجيل مصروف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة حركات الصندوق">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="2" Style="{StaticResource ToolbarStyle}" BorderThickness="0,0,0,1" Padding="10,4">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="من تاريخ:" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterFrom}"
                                Style="{StaticResource ModernDatePicker}"
                                Width="140"
                                ToolTip="تصفية الحركات من هذا التاريخ"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="إلى تاريخ:" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterTo}"
                                Style="{StaticResource ModernDatePicker}"
                                Width="140"
                                ToolTip="تصفية الحركات إلى هذا التاريخ"/>
                </StackPanel>

                <Button Command="{Binding FilterCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                        ToolTip="تطبيق التصفية حسب النطاق الزمني المحدد">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="تصفية" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearFilterCommand}" Style="{StaticResource SecondaryButton}"
                        ToolTip="إزالة التصفية وعرض جميع الحركات">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إزالة التصفية" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="3"
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorTextBrush}" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True" Margin="{StaticResource StandardSectionMargin}">
            <Grid>
                <DataGrid ItemsSource="{Binding Transactions}"
                          SelectedItem="{Binding SelectedTransaction}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          AutomationProperties.AutomationId="DgCashTransactions">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ" 
                                            Binding="{Binding CreatedAt, StringFormat=yyyy/MM/dd HH:mm}" 
                                            Width="140" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="النوع" 
                                            Binding="{Binding TransactionTypeName}" 
                                            Width="120" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="المبلغ" 
                                            Binding="{Binding Amount, StringFormat=N2}" 
                                            Width="100" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="الرصيد قبل" 
                                            Binding="{Binding BalanceBefore, StringFormat=N2}" 
                                            Width="100" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="الرصيد بعد" 
                                            Binding="{Binding BalanceAfter, StringFormat=N2}" 
                                            Width="100" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="المرجع" 
                                            Binding="{Binding ReferenceType}" 
                                            Width="100" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="ملاحظات" 
                                            Binding="{Binding Notes}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>

                        <DataGridTextColumn Header="المستخدم" 
                                            Binding="{Binding CreatedBy}" 
                                            Width="80" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="💳" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد حركات" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="لم يتم تسجيل أي حركات نقدية لهذا الصندوق بعد" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Current Balance Summary -->
        <Border Grid.Row="5" Background="White" Padding="10,4" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="الرصيد الحالي: " FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding CurrentBalance, StringFormat=N2}" FontSize="16" FontWeight="Bold" 
                           Foreground="{StaticResource SuccessBrush}" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="6" Background="White" Padding="10,4" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="عدد الحركات: " FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding Transactions.Count, FallbackValue=0}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="7"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل حركات الصندوق..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
