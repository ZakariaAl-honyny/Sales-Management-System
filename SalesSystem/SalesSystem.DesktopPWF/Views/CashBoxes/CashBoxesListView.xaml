<UserControl x:Class="SalesSystem.DesktopPWF.Views.CashBoxes.CashBoxesListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.CashBoxes"
      mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="💰  الصناديق النقدية"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="CashBoxesPageTitle"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="إضافة صندوق نقدي جديد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إضافة صندوق" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل بيانات الصندوق المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DeactivateCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            ToolTip="إلغاء تنشيط الصندوق المحدد — سيتم تعطيل استخدامه">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلغاء تنشيط" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ViewTransactionsCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="عرض حركات وسجل المعاملات للصندوق المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="الحركات" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding TransferCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تحويل أموال بين خزنتين — عملية ذرية بقيد مزدوج">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تحويل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CloseDayCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                            ToolTip="إغلاق اليوم للصندوق المحدد — تنفيذ الجرد اليومي وحساب الرصيد الختامي">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إغلاق اليوم" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة الصناديق النقدية">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorTextBrush}" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding CashBoxes}"
                          SelectedItem="{Binding SelectedCashBox}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          AutomationProperties.AutomationId="DgCashBoxes">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم الصندوق" 
                                            Binding="{Binding BoxName}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>

                        <DataGridTextColumn Header="الحساب المرتبط" 
                                            Binding="{Binding AccountName}" 
                                            Width="140" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>

                        <DataGridTextColumn Header="رقم الهاتف" 
                                            Binding="{Binding PhoneNumber}" 
                                            Width="120" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTemplateColumn Header="الحالة" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Setter Property="Text" Value="غير نشط"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                            <Setter Property="Text" Value="نشط"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="💰" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد صناديق نقدية" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="أضف صندوقاً نقدياً لتتبع الإيرادات والمصروفات" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إضافة صندوق" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="140"
                                ToolTip="إضافة صندوق نقدي جديد"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Background="White" Padding="10,4" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="عدد الصناديق: " FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding CashBoxes.Count, FallbackValue=0}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل الصناديق النقدية..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
