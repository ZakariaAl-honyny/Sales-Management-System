<UserControl x:Class="SalesSystem.DesktopPWF.Views.CashBoxes.DailyClosureView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.CashBoxes"
      mc:Ignorable="d"
      
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding CashBoxName, StringFormat='📊  الإغلاق اليومي - {0}'}"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="DailyClosurePageTitle"/>

        <!-- Summary Cards -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10,6" Margin="{StaticResource StandardSectionMargin}">
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <!-- Opening Balance Card -->
                <Border Style="{StaticResource CardStyle}" Width="160" Margin="0,0,8,0" Padding="10,8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="الرصيد الافتتاحي" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding OpeningBalance, StringFormat=N2}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Income Card -->
                <Border Style="{StaticResource CardStyle}" Width="160" Margin="0,0,8,0" Padding="10,8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="إجمالي الإيرادات" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalIncome, StringFormat=N2}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Expense Card -->
                <Border Style="{StaticResource CardStyle}" Width="160" Margin="0,0,8,0" Padding="10,8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="إجمالي المصروفات" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalExpense, StringFormat=N2}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Projected Closing Balance Card -->
                <Border Style="{StaticResource CardStyle}" Width="160" Padding="10,8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="الرصيد الختامي المتوقع" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ProjectedClosingBalance, StringFormat=N2}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>

        <!-- Reconciliation Section -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12,8" Margin="{StaticResource StandardSectionMargin}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Actual Cash Count -->
                <TextBlock Text="العد الفعلي للخزينة:" Grid.Column="0" VerticalAlignment="Center" 
                           FontWeight="SemiBold" FontSize="13" Margin="0,0,8,0"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox Grid.Column="1" Text="{Binding ActualCashCount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         FontWeight="Bold" FontSize="14"
                         Foreground="{StaticResource PrimaryBrush}"
                         ToolTip="أدخل العدد الفعلي للنقدية في الخزينة — سيتم احتساب الفرق تلقائياً"
                         AutomationProperties.AutomationId="TxtActualCashCount"/>

                <!-- Difference Display -->
                <TextBlock Text="الفرق:" Grid.Column="2" VerticalAlignment="Center" 
                           FontWeight="SemiBold" FontSize="13" Margin="12,0,8,0"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="3" Text="{Binding DifferenceDisplay}" VerticalAlignment="Center"
                           FontWeight="Bold" FontSize="14"
                           AutomationProperties.AutomationId="TxtDifferenceDisplay"/>

                <!-- Reconcile Button -->
                <Button Grid.Column="4"
                        Command="{Binding ReconcileCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="8,4"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="إجراء تسوية بين الرصيد المتوقع والعد الفعلي للخزينة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="تسوية" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="3" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">

                    <!-- Perform Closure Button -->
                    <Button Command="{Binding PerformClosureCommand}"
                            Style="{StaticResource SuccessButton}"
                            Margin="0,0,8,0"
                            ToolTip="تنفيذ الإغلاق اليومي للصندوق — لا يمكن التراجع عن هذه العملية">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔒" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إغلاق اليوم" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Refresh Button -->
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث بيانات الإغلاق اليومي">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- IsClosedToday Success Banner -->
        <Border Grid.Row="4"
                Background="{StaticResource SuccessLightBrush}"
                BorderBrush="{StaticResource SuccessBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding IsClosedToday, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✅" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ReconciliationStatus, StringFormat='{}حالة الإغلاق: {0}'}"
                           Foreground="{StaticResource SuccessTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="5"
                Background="{StaticResource ErrorLightBrush}"
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Past Closures Section Label -->
        <TextBlock Grid.Row="6"
                   Text="الإغلاقات السابقة"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="{StaticResource StandardSectionMargin}"
                   AutomationProperties.AutomationId="PastClosuresSectionLabel"/>

        <!-- Past Closures DataGrid -->
        <Border Grid.Row="7" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True" Margin="{StaticResource StandardSectionMargin}">
            <Grid>
                <DataGrid ItemsSource="{Binding PastClosures}"
                          SelectedItem="{Binding SelectedClosure}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          AutomationProperties.AutomationId="DgPastClosures">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ"
                                            Binding="{Binding ClosureDate, StringFormat=yyyy/MM/dd}"
                                            Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="الرصيد الافتتاحي"
                                            Binding="{Binding OpeningBalance, StringFormat=N2}"
                                            Width="110"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="إجمالي الإيرادات"
                                            Binding="{Binding TotalIncome, StringFormat=N2}"
                                            Width="110"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="إجمالي المصروفات"
                                            Binding="{Binding TotalExpense, StringFormat=N2}"
                                            Width="110"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="الرصيد الختامي"
                                            Binding="{Binding ClosingBalance, StringFormat=N2}"
                                            Width="110"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="العد الفعلي"
                                            Binding="{Binding ActualCashCount, StringFormat=N2}"
                                            Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="الفارق"
                                            Binding="{Binding Difference, StringFormat=N2}"
                                            Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTemplateColumn Header="التسوية" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="{Binding IsReconciled}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReconciled}" Value="True">
                                                        <Setter Property="Text" Value="مطابق ✅"/>
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsReconciled}" Value="False">
                                                        <Setter Property="Text" Value="غير مطابق"/>
                                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد إغلاقات سابقة" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="9"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل بيانات الإغلاق اليومي..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
