<Page x:Class="SalesSystem.DesktopPWF.Views.CashBoxes.DailyClosureView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.CashBoxes"
      mc:Ignorable="d"
      Title="الإغلاق اليومي"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding CashBoxName, StringFormat='الإغلاق اليومي - {0}'}"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="DailyClosurePageTitle"/>

        <!-- Summary Cards -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,12" Margin="{StaticResource StandardSectionMargin}">
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <!-- Opening Balance Card -->
                <Border Style="{StaticResource CardStyle}" Width="180" Margin="0,0,12,0" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="الرصيد الافتتاحي" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding OpeningBalance, StringFormat=N2}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Income Card -->
                <Border Style="{StaticResource CardStyle}" Width="180" Margin="0,0,12,0" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="إجمالي الإيرادات" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalIncome, StringFormat=N2}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Expense Card -->
                <Border Style="{StaticResource CardStyle}" Width="180" Margin="0,0,12,0" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="إجمالي المصروفات" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalExpense, StringFormat=N2}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Projected Closing Balance Card -->
                <Border Style="{StaticResource CardStyle}" Width="200" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="الرصيد الختامي المتوقع" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ProjectedClosingBalance, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="2" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">

                    <!-- Perform Closure Button -->
                    <Button Command="{Binding PerformClosureCommand}"
                            Style="{StaticResource SuccessButton}"
                            Margin="0,0,8,0" Height="36" Padding="16,0"
                            ToolTip="تنفيذ الإغلاق اليومي للصندوق — لا يمكن التراجع عن هذه العملية">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔒" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إغلاق اليوم" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Refresh Button -->
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Height="36" Padding="12,0"
                            ToolTip="تحديث بيانات الإغلاق اليومي">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- IsClosedToday Success Banner -->
        <Border Grid.Row="3"
                Background="{StaticResource SuccessLightBrush}"
                BorderBrush="{StaticResource SuccessBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding IsClosedToday, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✅" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="تم إغلاق هذا الصندوق اليوم"
                           Foreground="{StaticResource SuccessTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="3"
                Background="{StaticResource ErrorLightBrush}"
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Past Closures Section Label -->
        <TextBlock Grid.Row="4"
                   Text="الإغلاقات السابقة"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="{StaticResource StandardSectionMargin}"
                   AutomationProperties.AutomationId="PastClosuresSectionLabel"/>

        <!-- Past Closures DataGrid -->
        <Border Grid.Row="5" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True" Margin="{StaticResource StandardSectionMargin}">
            <Grid>
                <DataGrid ItemsSource="{Binding PastClosures}"
                          SelectedItem="{Binding SelectedClosure}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          AutomationProperties.AutomationId="DgPastClosures">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ"
                                            Binding="{Binding ClosureDate, StringFormat=yyyy/MM/dd}"
                                            Width="120"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="الرصيد الافتتاحي"
                                            Binding="{Binding OpeningBalance, StringFormat=N2}"
                                            Width="120"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="إجمالي الإيرادات"
                                            Binding="{Binding TotalIncome, StringFormat=N2}"
                                            Width="120"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="إجمالي المصروفات"
                                            Binding="{Binding TotalExpense, StringFormat=N2}"
                                            Width="120"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="الرصيد الختامي"
                                            Binding="{Binding ClosingBalance, StringFormat=N2}"
                                            Width="120"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد إغلاقات سابقة" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="7"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل بيانات الإغلاق اليومي..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
