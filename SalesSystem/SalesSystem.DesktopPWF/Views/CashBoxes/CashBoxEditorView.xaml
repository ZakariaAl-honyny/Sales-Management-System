<UserControl x:Class="SalesSystem.DesktopPWF.Views.CashBoxes.CashBoxEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="💰  إضافة صندوق جديد"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="TitleAddCashBox"
                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="0"
                   Text="💰  تعديل صندوق"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="TitleEditCashBox"
                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12"/>

        <!-- Main Content Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16,0,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Error Message (inside card, above scroll) -->
                <Border Grid.Row="0"
                        Background="{StaticResource ErrorLightBrush}"
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        CornerRadius="6"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorTextBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable Form Fields -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,6">

                        <!-- Box Name -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="اسم الصندوق *" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding BoxName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     AutomationProperties.AutomationId="TxtCashBoxName"
                                     ToolTip="اسم الصندوق النقدي — هذا الحقل إلزامي"/>
                        </StackPanel>

                        <!-- Account Info (Auto-creation notice) -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="الحساب المرتبط" Style="{StaticResource LabelStyle}"/>
                            <Border Background="{StaticResource InfoLightBrush}"
                                    BorderBrush="{StaticResource InfoBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8,6">
                                <TextBlock Text="{Binding AccountInfo, FallbackValue='سيتم إنشاء حساب تلقائي ضمن مجموعة النقد وما في حكمه'}"
                                           FontSize="11" Foreground="{StaticResource InfoTextBrush}"
                                           ToolTip="سيتم إنشاء حساب دفتر أستاذ تلقائي لهذا الصندوق ضمن مجموعة النقد — لا حاجة لاختيار حساب يدوي"/>
                            </Border>
                        </StackPanel>

                        <!-- Category -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="الفئة" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"
                                      AutomationProperties.AutomationId="CmbCashBoxCategory"
                                      ToolTip="اختيار فئة للصندوق (اختياري)"/>
                        </StackPanel>

                        <!-- Phone Number -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="رقم الهاتف" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     AutomationProperties.AutomationId="TxtCashBoxPhone"
                                     ToolTip="رقم الهاتف المسؤول عن الصندوق (اختياري)"/>
                        </StackPanel>

                        <!-- Tax Number -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="الرقم الضريبي" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding TaxNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     AutomationProperties.AutomationId="TxtCashBoxTaxNumber"
                                     ToolTip="الرقم الضريبي للصندوق (اختياري)"/>
                        </StackPanel>

                        <!-- Address -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="العنوان" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"
                                     AutomationProperties.AutomationId="TxtCashBoxAddress"
                                     ToolTip="عنوان موقع الصندوق (اختياري)"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        AutomationProperties.AutomationId="BtnSaveCashBox"
                        ToolTip="حفظ بيانات الصندوق النقدي">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="4,0,0,0"
                        AutomationProperties.AutomationId="BtnCancelCashBox"
                        ToolTip="إلغاء الأمر والعودة للقائمة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ البيانات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
