<Window x:Class="SalesSystem.DesktopPWF.Views.Users.UserEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="620" Width="520"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconUser}" Fill="White" Width="24" Height="24" Margin="0,0,16,0" Stretch="Uniform"/>
                <TextBlock Text="👥 " FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>

                <!-- Avatar Section -->
                <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="الصورة الشخصية" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <!-- Avatar Preview -->
                            <Border Width="80" Height="80" CornerRadius="40"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,12,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <!-- Placeholder icon -->
                                    <TextBlock Text="👤" FontSize="36"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- TODO: Image bound to AvatarUrl when HasAvatar -->
                                </Grid>
                            </Border>
                            <!-- Avatar Buttons -->
                            <StackPanel VerticalAlignment="Center">
                                <Button Command="{Binding UploadAvatarCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="100" Margin="0,0,0,4"
                                        ToolTip="رفع صورة شخصية للمستخدم — ستظهر في شريط الحالة">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📷" Margin="0,0,6,0"/>
                                        <TextBlock Text="رفع صورة"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding RemoveAvatarCommand}"
                                        Style="{StaticResource DangerButton}"
                                        MinWidth="100"
                                        ToolTip="إزالة الصورة الشخصية الحالية">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                        <TextBlock Text="إزالة"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Account Info Section -->
                <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="معلومات الحساب" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                        <!-- Username -->
                        <TextBlock Text="اسم المستخدم *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="مثال: ahmed_2024"
                                 TabIndex="1"
                                 IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtUserUsername"
                                 ToolTip="اسم المستخدم للدخول — يجب أن يكون فريداً ولا يمكن تكراره. يُستخدم مع كلمة المرور لتسجيل الدخول"/>
                        <TextBlock Text="اسم فريد يُستخدم للدخول إلى النظام" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6"/>

                        <!-- Full Name -->
                        <TextBlock Text="الاسم بالكامل *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="الاسم الثلاثي للموظف"
                                 TabIndex="2"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtUserFullName"
                                 ToolTip="الاسم الكامل للمستخدم — يظهر في الفواتير والتقارير"/>
                        <TextBlock Text="يظهر هذا الاسم في الفواتير والتقارير" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6"/>

                        <!-- Password -->
                        <TextBlock Text="كلمة المرور" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="أدخل كلمة مرور قوية"
                                 TabIndex="3"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtUserPassword"
                                 ToolTip="كلمة المرور مطلوبة عند إنشاء مستخدم جديد. اتركها فارغة عند التعديل إذا كنت لا تريد تغييرها"/>
                        <TextBlock Text="اتركه فارغاً عند التعديل إذا كنت لا تريد تغيير كلمة المرور" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6"/>

                        <!-- Change Password Button (edit mode only) -->
                        <Button Command="{Binding ChangePasswordCommand}"
                                Style="{StaticResource SecondaryButton}"
                                MinWidth="140"
                                Margin="0,0,0,6"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="فتح نافذة تغيير كلمة المرور — إدخال كلمة المرور الحالية والجديدة">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔑" Margin="0,0,6,0"/>
                                <TextBlock Text="تغيير كلمة المرور"/>
                            </StackPanel>
                        </Button>

                        <!-- Role -->
                        <TextBlock Text="الصلاحية" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding RoleOptions}"
                                  SelectedValue="{Binding Role, ValidatesOnDataErrors=True}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Style="{StaticResource ModernComboBox}"
                                  TabIndex="4"
                                  helpers:FocusHelper.AdvanceOnEnter="True"
                                  AutomationProperties.AutomationId="CbUserRole"
                                  ToolTip="تحدد صلاحيات المستخدم — مدير نظام (كل الصلاحيات)، مدير (مشرف)، كاشير (مبيعات فقط)"/>
                        <TextBlock Text="تحدد الصلاحية ما يمكن للمستخدم رؤيته أو تعديله في النظام" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6"/>

                        <!-- Is Active -->
                        <CheckBox Content="الحساب نشط"
                                  IsChecked="{Binding IsActive}"
                                  TabIndex="5"
                                  Margin="0,0,0,6"
                                  AutomationProperties.AutomationId="ChkUserIsActive"
                                  ToolTip="إلغاء التحديد لتعطيل الحساب — لن يتمكن المستخدم من تسجيل الدخول"/>

                        <!-- Locked Status (edit mode only, read-only) -->
                        <Border Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="حالة الحساب:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}"
                                           Foreground="{StaticResource ErrorBrush}" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="نشط"/>
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                    <Setter Property="Text" Value="مقفل"/>
                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- CashBox -->
                        <TextBlock Text="الصندوق الافتراضي" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding CashBoxOptions}"
                                  SelectedValue="{Binding DefaultCashBoxId}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"
                                  TabIndex="6"
                                  ToolTip="اختيار الصندوق النقدي الافتراضي للمستخدم — يظهر تلقائياً عند فتح شاشة الدفع"/>
                        <TextBlock Text="اختياري — سيتم تعيين هذا الصندوق كافتراضي عند تسجيل المدفوعات" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6"/>
                    </StackPanel>
                </Border>

                <!-- Contact Info Section -->
                <Border Style="{StaticResource CardStyle}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="معلومات الاتصال" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                        <!-- Phone -->
                        <TextBlock Text="رقم الهاتف" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="05XXXXXXXX"
                                 TabIndex="7"
                                 MaxLength="20"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtUserPhone"
                                 ToolTip="رقم الهاتف المحمول أو الثابت — حد أقصى 20 رقم"/>
                        <TextBlock Text="حد أقصى 20 رقم — مثال: 0512345678" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6"/>

                        <!-- Email -->
                        <TextBlock Text="البريد الإلكتروني" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="user@example.com"
                                 TabIndex="8"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtUserEmail"
                                 ToolTip="البريد الإلكتروني — يجب أن يكون بصيغة صحيحة مثل user@example.com"/>
                        <TextBlock Text="البريد الإلكتروني — صيغة صحيحة مطلوبة" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,6"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="140"
                            Margin="0,0,12,0"
                            IsDefault="True"
                            TabIndex="9"
                            AutomationProperties.AutomationId="BtnSaveUser"
                            ToolTip="حفظ البيانات المدخلة">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSave}" Fill="White" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="حفظ المستخدم"/>
                        </StackPanel>
                    </Button>
                    <Button Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="100"
                            TabIndex="10"
                            AutomationProperties.AutomationId="BtnCancelUser"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
