<UserControl x:Class="SalesSystem.DesktopPWF.Views.Users.PasswordChangeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔑" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding HeaderTitle}" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="24,16">
            <Border Style="{StaticResource CardStyle}" Padding="16">
                <StackPanel>

                    <!-- Current Password -->
                    <TextBlock Text="كلمة المرور الحالية *" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="CurrentPasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding CurrentPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TabIndex="1"
                                 ToolTip="أدخل كلمة المرور الحالية الخاصة بك"/>
                    <TextBlock Text="أدخل كلمة المرور الحالية للتحقق من هويتك" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8"/>

                    <!-- New Password -->
                    <TextBlock Text="كلمة المرور الجديدة *" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="NewPasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TabIndex="2"
                                 ToolTip="أدخل كلمة مرور جديدة — يجب أن تكون 8 أحرف على الأقل وتحتوي على أرقام وحروف"/>
                    <TextBlock Text="يجب أن تكون 8 أحرف على الأقل — يفضل استخدام أرقام وحروف ورموز" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8"/>

                    <!-- Confirm Password -->
                    <TextBlock Text="تأكيد كلمة المرور الجديدة *" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TabIndex="3"
                                 ToolTip="أعد إدخال كلمة المرور الجديدة للتأكيد"/>
                    <TextBlock Text="أعد إدخال كلمة المرور الجديدة للتأكيد — يجب أن تطابق الحقل أعلاه" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8"/>

                </StackPanel>
            </Border>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorBrush}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="120"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        TabIndex="4"
                        ToolTip="حفظ كلمة المرور الجديدة — مطلوب لتتمكن من متابعة تسجيل الدخول">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,6,0"/>
                        <TextBlock Text="حفظ"/>
                    </StackPanel>
                </Button>
                <Button Content="إلغاء"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="100"
                        TabIndex="5"
                        Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibility}}"
                        ToolTip="إلغاء وإغلاق النافذة"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="160" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ كلمة المرور..." FontSize="13" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
