<Window x:Class="SalesSystem.DesktopPWF.Views.Suppliers.SupplierEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="600" Width="550"
        MinHeight="500" MinWidth="500"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconSupplier}" Fill="White" Width="24" Height="24" Margin="0,0,16,0" Stretch="Uniform"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>

                        <!-- Name -->
                        <TextBlock Text="اسم المورد *" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="أدخل الاسم الكامل للمورد" 
                                 TabIndex="2"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtSupplierName"
                               ToolTip="الاسم الكامل للمورد — هذا الحقل إلزامي ولا يمكن أن يكون فارغاً"/>
                        <Border Height="12"/>

                        <!-- Phone -->
                        <TextBlock Text="رقم الهاتف" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="05xxxxxxxx (10 أرقام)" 
                                 TabIndex="3"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtSupplierPhone"
                              ToolTip="رقم جوال المورد — يُستخدم للتواصل وطلب البضائع"/>
                        <TextBlock Text="مثال: 0512345678 - سيتم استخدامه للتواصل وطلب البضائع" Style="{StaticResource HelperTextStyle}"/>
                        <Border Height="12"/>

                        <!-- Address -->
                        <TextBlock Text="العنوان" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="المدينة، الحي، الشارع، أو اسم معلم قريب (اختياري)" 
                                 Height="60" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 VerticalContentAlignment="Top" 
                                 TabIndex="4"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtSupplierAddress"
                              ToolTip="عنوان المورد — يساعد في إرسال المرتجعات"/>
                        <TextBlock Text="يساعدك العنوان في الوصول للمورد أو إرسال المرتجعات" Style="{StaticResource HelperTextStyle}"/>
                        <Border Height="12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="الرقم الضريبي" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding TaxNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                          Style="{StaticResource ModernTextBox}" 
                                          Tag="15 رقم"
                                          TabIndex="5"
                                          helpers:FocusHelper.AdvanceOnEnter="True"
                                          AutomationProperties.AutomationId="TxtSupplierTaxNumber"
                                          ToolTip="الرقم الضريبي للمورد — يستخدم في إصدار فواتير الشراء"/>
                                <TextBlock Text="الرقم الضريبي الموحد للمورد" Style="{StaticResource HelperTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="البريد الإلكتروني" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                          Style="{StaticResource ModernTextBox}" 
                                          Tag="example@test.com"
                                          TabIndex="6"
                                          helpers:FocusHelper.AdvanceOnEnter="True"
                                          AutomationProperties.AutomationId="TxtSupplierEmail"
                                          ToolTip="البريد الإلكتروني الرسمي للمورد للمراسلة"/>
                                <TextBlock Text="البريد الإلكتروني الرسمي للمراسلة" Style="{StaticResource HelperTextStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="12"/>

                        <!-- Opening Balance -->
                        <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="الرصيد الافتتاحي (رصيد سابق)" Style="{StaticResource LabelStyle}"/>
<TextBox Text="{Binding OpeningBalance, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}" 
                                      Style="{StaticResource ModernTextBox}" 
                                      TabIndex="7"
                                      helpers:FocusHelper.AdvanceOnEnter="True"
                                      AutomationProperties.AutomationId="TxtSupplierOpeningBalance"
                                      ToolTip="الرصيد السابق للمورد — المبلغ المستحق له (موجب) أو المستحق عليه (سالب)"/>
                            <TextBlock Text="المبلغ المستحق للمورد (بالموجب) أو المستحق عليه (بالسالب) قبل استخدام النظام" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <Border Height="12"/>
                        </StackPanel>

                        <!-- Status -->
                        <CheckBox Content="مورد نشط" IsChecked="{Binding IsActive}" FontSize="14" 
                                  Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}" 
                                  TabIndex="8"
                                  AutomationProperties.AutomationId="ChkSupplierActive"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="24,16" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="140"
                            Margin="0,0,12,0"
                            IsDefault="True"
                            TabIndex="9"
                            AutomationProperties.AutomationId="BtnSaveSupplier"
                            ToolTip="حفظ البيانات المدخلة">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSave}" Fill="White" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="حفظ البيانات"/>
                        </StackPanel>
                    </Button>
                    <Button Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100"
                            TabIndex="10"
                            AutomationProperties.AutomationId="BtnCancelSupplier"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري الحفظ..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

