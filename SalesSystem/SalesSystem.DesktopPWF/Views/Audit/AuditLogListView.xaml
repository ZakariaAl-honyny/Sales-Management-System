<UserControl x:Class="SalesSystem.DesktopPWF.Views.Audit.AuditLogListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="📋  سجل الأحداث"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="AuditLogPageTitle"/>

        <!-- Filter Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4">

                <!-- Action Filter -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="الإجراء" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding ActionFilters}"
                              SelectedItem="{Binding SelectedAction}"
                              Style="{StaticResource ModernComboBox}"
                              MinWidth="100"
                              ToolTip="تصفية حسب نوع الإجراء — Login, Create, Update, Delete..."/>
                </StackPanel>

                <!-- Entity Type Filter -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="الكيان" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding EntityTypeFilters}"
                              SelectedItem="{Binding SelectedEntityType}"
                              Style="{StaticResource ModernComboBox}"
                              MinWidth="100"
                              ToolTip="تصفية حسب نوع الكيان — فاتورة بيع، مستخدم، منتج..."/>
                </StackPanel>

                <!-- From Date -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="من" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker SelectedDate="{Binding FromDate}"
                                Style="{StaticResource ModernDatePicker}"
                                ToolTip="تصفية من تاريخ — اختر تاريخ البداية"/>
                </StackPanel>

                <!-- To Date -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="إلى" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker SelectedDate="{Binding ToDate}"
                                Style="{StaticResource ModernDatePicker}"
                                ToolTip="تصفية إلى تاريخ — اختر تاريخ النهاية"/>
                </StackPanel>

                <!-- Search -->
                <TextBox Text="{Binding SearchText}"
                         Width="140"
                         Tag="بحث..."
                         Margin="0,0,8,0"
                         ToolTip="بحث نصي في التفاصيل"/>
                <Button Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,4,0"
                        ToolTip="تنفيذ البحث بناءً على معايير التصفية المحددة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Margin="0,0,6,0"/>
                        <TextBlock Text="بحث"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="تحديث سجل الأحداث">
                    <TextBlock Text="🔄"/>
                </Button>
            </WrapPanel>
        </Border>

        <!-- Error Banner -->
        <Border Grid.Row="2"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                Background="{StaticResource ErrorLightBrush}"
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorTextBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button Grid.Column="2" Content="✕"
                        Command="{Binding RefreshCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource ErrorTextBrush}" FontWeight="Bold"
                        Padding="6,0" VerticalAlignment="Center"
                        ToolTip="إخفاء رسالة الخطأ"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding Logs}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          AutomationProperties.AutomationId="DgAuditLogs">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ والوقت"
                                            Binding="{Binding Timestamp, StringFormat='{}{0:yyyy/MM/dd HH:mm:ss}'}"
                                            Width="140"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="المستخدم"
                                            Binding="{Binding UserName}"
                                            Width="120"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="الإجراء"
                                            Binding="{Binding Action}"
                                            Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="الكيان"
                                            Binding="{Binding EntityType}"
                                            Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="رقم الكيان"
                                            Binding="{Binding EntityId}"
                                            Width="80"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="التفاصيل"
                                            Binding="{Binding Details}"
                                            Width="*"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="عنوان IP"
                                            Binding="{Binding IpAddress}"
                                            Width="110"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.3"/>
                        <TextBlock Text="لا توجد أحداث مسجلة" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="حاول تغيير معايير التصفية أو البحث" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Pagination Footer -->
        <Border Grid.Row="4" Margin="0,8,0,0" Padding="8,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding PrevPageCommand}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="80"
                        Margin="0,0,4,0"
                        ToolTip="الصفحة السابقة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Margin="0,0,6,0"/>
                        <TextBlock Text="السابق"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding PageDisplay}"
                           VerticalAlignment="Center"
                           Margin="12,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Command="{Binding NextPageCommand}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="80"
                        ToolTip="الصفحة التالية">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="التالي"/>
                        <TextBlock Text="◀" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل سجل الأحداث..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
