<UserControl x:Class="SalesSystem.DesktopPWF.Views.Products.ProductUnitEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="إضافة وحدة قياس جديدة"
                   Style="{StaticResource HeaderStyle}"
                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
        <TextBlock Grid.Row="0"
                   Text="تعديل وحدة قياس"
                   Style="{StaticResource HeaderStyle}"
                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">

                    <!-- Unit Name -->
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="اسم الوحدة *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 ToolTip="أدخل اسم الوحدة — هذا الحقل إلزامي"/>
                    </StackPanel>

                    <!-- Conversion Factor -->
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="عامل التحويل *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding ConversionFactor, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 ToolTip="عامل التحويل — عدد الوحدات الأساسية في هذه الوحدة (مثال: 12 إذا كانت العلبة = 12 قطعة)"/>
                    </StackPanel>

                    <!-- Retail Price -->
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="سعر التجزئة *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding RetailPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 Style="{StaticResource ModernTextBox}"
                                 ToolTip="سعر بيع التجزئة للوحدة الواحدة"/>
                    </StackPanel>

                    <!-- Wholesale Price -->
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="سعر الجملة" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding WholesalePrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 Style="{StaticResource ModernTextBox}"
                                 ToolTip="سعر بيع الجملة للوحدة الواحدة"/>
                    </StackPanel>

                    <!-- Is Base Unit -->
                    <StackPanel Margin="0,0,0,8">
                        <CheckBox Content="وحدة قياس أساسية"
                                  IsChecked="{Binding IsBaseUnit}"
                                  ToolTip="الوحدة الأساسية هي أصغر وحدة قياس للمنتج (مثل: قطعة)"/>
                    </StackPanel>

                    <!-- Barcodes -->
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="الباركود" Style="{StaticResource LabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox Text="{Binding NewBarcode, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="أدخل باركود الوحدة — يجب أن يكون فريداً"/>
                            <Button Command="{Binding AddBarcodeCommand}"
                                    Style="{StaticResource SuccessButton}"
                                    Margin="8,0,0,0"
                                    ToolTip="إضافة باركود جديد للوحدة">
                                <TextBlock Text="➕ إضافة"/>
                            </Button>
                        </StackPanel>

                        <ListBox ItemsSource="{Binding Barcodes}"
                                 SelectedItem="{Binding SelectedBarcode}"
                                 Height="120"
                                 Margin="0,8,0,0"
                                 ToolTip="قائمة الباركود المسجلة للوحدة">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Command="{Binding RemoveBarcodeCommand}"
                                Style="{StaticResource DangerButton}"
                                Margin="0,6,0,0" Width="120"
                                HorizontalAlignment="Left"
                                ToolTip="حذف الباركود المحدد من القائمة">
                            <TextBlock Text="🗑️ حذف الباركود"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Error Message -->
        <Border Grid.Row="1"
                Background="{StaticResource ErrorLightBrush}"
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="16"
                CornerRadius="6"
                VerticalAlignment="Bottom"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" Padding="10,4" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
<Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        ToolTip="حفظ بيانات وحدة القياس">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

<Button Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="4,0,0,0"
                        ToolTip="إلغاء الأمر والعودة للقائمة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ البيانات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
