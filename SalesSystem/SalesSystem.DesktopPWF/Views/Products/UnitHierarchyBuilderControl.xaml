<UserControl x:Class="SalesSystem.DesktopPWF.Views.Products.UnitHierarchyBuilderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Help Box -->
        <Border Grid.Row="0" 
                Background="#FFF3E0" 
                BorderBrush="#FF9800"
                BorderThickness="1" 
                CornerRadius="4"
                Padding="12" 
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontWeight="Bold" FontSize="13" Foreground="#E65100">
                        <Run Text="💡 "/>
                        <Run Text="كيف تبني وحدات المنتج؟"/>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Margin="20,4,0,0" Foreground="#555">
                        <Run Text="1. ابدأ بالوحدة الصغرى (مثال: حبة) — معامل التحويل = 1"/>
                        <LineBreak/>
                        <Run Text="2. أضف الوحدات الأكبر واكتب كم وحدة صغرى بداخلها"/>
                        <LineBreak/>
                        <Run Text="3. مثال: طبق بيض = 30 حبة | كرتون = 12 طبق = 360 حبة"/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1"
                        ToolTip="عرض تعليمات إضافة الوحدات"
                        Content="تفاصيل أكثر"
                        Command="{Binding ShowHelpCommand}"
                        Background="Transparent"
                        BorderBrush="#FF9800"
                        Foreground="#E65100"
                        Padding="8,4"
                        Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Header Row -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="الوحدة" FontWeight="SemiBold" Width="150"/>
            <TextBlock Text="معامل التحويل" Grid.Column="1" FontWeight="SemiBold" Width="100" TextAlignment="Center"/>
            <TextBlock Text="سعر البيع" Grid.Column="2" FontWeight="SemiBold" TextAlignment="Center"/>
            <TextBlock Text="تكلفة الشراء" Grid.Column="3" FontWeight="SemiBold" TextAlignment="Center"/>
            <TextBlock Text="الباركود" Grid.Column="4" FontWeight="SemiBold" TextAlignment="Center"/>
            <TextBlock Grid.Column="6" FontWeight="SemiBold" Width="40" TextAlignment="Center"/>
        </Grid>

        <!-- Units ItemsControl -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Units}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Base Unit Checkbox -->
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsBaseUnit}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0">
                                    <TextBlock Text="أساسي"/>
                                </CheckBox>

                                <!-- Unit Name -->
                                <TextBox Grid.Column="1"
                                         Text="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"
                                         Padding="6,4">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#FAFAFA"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Conversion Factor -->
                                <TextBox Grid.Column="2"
                                         Text="{Binding BaseConversionFactor, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         IsEnabled="{Binding IsBaseUnit, Converter={StaticResource InverseBoolConverter}}"
                                         Margin="0,0,8,0"
                                         Padding="4,4">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBaseUnit}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Sales Price -->
                                <TextBox Grid.Column="3"
                                         Text="{Binding SalesPrice, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Margin="0,0,8,0"
                                         Padding="4,4"/>

                                <!-- Purchase Cost -->
                                <TextBox Grid.Column="4"
                                         Text="{Binding PurchaseCost, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Margin="0,0,8,0"
                                         Padding="4,4"/>

                                <!-- Barcode -->
                                <TextBox Grid.Column="5"
                                         Text="{Binding BarcodeValue, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Margin="0,0,8,0"
                                         Padding="4,4"/>

                                <!-- Remove Button -->
                                <Button Grid.Column="6"
                                        ToolTip="حذف الوحدة المحددة"
                                        Content="✕"
                                        Command="{Binding DataContext.RemoveUnitCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        Foreground="#E53935"
                                        BorderThickness="0"
                                        Width="30"
                                        Height="30"
                                        FontSize="14"
                                        Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Validation Summary -->
        <Border Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Text="{Binding ValidationSummary}"
                       TextWrapping="Wrap"
                       FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#2E7D32"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                                <Setter Property="Foreground" Value="#C62828"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>