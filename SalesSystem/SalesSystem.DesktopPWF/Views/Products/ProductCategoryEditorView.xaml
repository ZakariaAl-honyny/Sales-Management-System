<Window x:Class="SalesSystem.DesktopPWF.Views.Products.ProductCategoryEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="350" Width="500"
        MinHeight="300" MinWidth="400"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📂" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="اسم المجموعة *" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtCategoryName"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="أدخل اسم المجموعة"
                                 TabIndex="1"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtCategoryName"
                                 ToolTip="اسم مجموعة الأصناف (مثل: مواد غذائية، مشروبات) — هذا الحقل إلزامي"/>
                        <Border Height="8"/>

                        <TextBlock Text="الوصف" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 Height="72"
                                 VerticalContentAlignment="Top" 
                                 TabIndex="2"
                                 ToolTip="وصف المجموعة (اختياري) — يظهر في قائمة المجموعات والتقارير"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            IsDefault="True" 
                            TabIndex="3"
                            ToolTip="حفظ مجموعة الأصناف">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حفظ"/>
                        </StackPanel>
                    </Button>

                    <Button Content="إلغاء" 
                            Command="{Binding CancelCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            MinWidth="80"
                            TabIndex="4"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ مجموعة الأصناف..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
