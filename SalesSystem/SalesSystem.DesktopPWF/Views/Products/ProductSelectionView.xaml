<Window x:Class="SalesSystem.DesktopPWF.Views.Products.ProductSelectionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="بحث واختيار صنف" Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}"
                         Tag="ابحث بالاسم أو الباركود...">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" Content="🔍 بحث" Command="{Binding SearchCommand}" 
                        Style="{StaticResource SecondaryButton}" MinWidth="80" Margin="8,0,0,0" ToolTip="البحث في القائمة"/>
            </Grid>
        </Border>

        <!-- Unit Selection Panel (visible when a product row is selected) -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="8"
                Visibility="{Binding HasUnits, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="المنتج:" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding SelectedProductName}" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,12,0"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding SelectedProductName}"/>

                <TextBlock Grid.Column="2" Text="الوحدة:" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox Grid.Column="3" 
                          ItemsSource="{Binding AvailableUnits}"
                          SelectedItem="{Binding SelectedUnit}"
                          DisplayMemberPath="UnitName"
                          Style="{StaticResource ModernComboBox}"
                          ToolTip="اختر الوحدة لعرض المخزون المحول"/>

                <!-- Converted stock display -->
                <TextBlock Grid.Column="3" 
                           Text="{Binding ConvertedStockDisplay}" 
                           FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Margin="0,0,8,0"
                           Foreground="{StaticResource PrimaryBrush}"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Product List -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid x:Name="ProductsDataGrid"
                          ItemsSource="{Binding ProductsView}"
                          SelectedItem="{Binding SelectedItem}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          BorderThickness="0">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding SelectCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding SelectCommand}"/>
                        <KeyBinding Key="Return" Command="{Binding SelectCommand}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الصنف" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="الباركود" Binding="{Binding Barcode}" Width="110"/>
                        <DataGridTextColumn Header="اسم الصنف" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="المخزون" Binding="{Binding StockDisplay}" Width="110"
                                            ToolTipService.ToolTip="المخزون المتوفر — يتم التحويل تلقائياً حسب الوحدة المختارة"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Stock Loading Indicator (Subtle overlay inside grid) -->
                <ProgressBar IsIndeterminate="True" 
                             Height="4" 
                             VerticalAlignment="Top" 
                             Background="Transparent" 
                             Foreground="{StaticResource PrimaryBrush}"
                             Visibility="{Binding IsStockLoading, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <TextBlock Text="💡 تلميح: استخدم الأسهم (↑↓) للتنقل واضغط Enter للاختيار السريع." 
                       VerticalAlignment="Center" 
                       Foreground="{StaticResource TextSecondaryBrush}" 
                       FontSize="11"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="إلغاء" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}" MinWidth="80" Margin="0,0,12,0" ToolTip="إلغاء وإغلاق النافذة"/>
                <Button Content="✅ اختيار" Command="{Binding SelectCommand}" Style="{StaticResource PrimaryButton}" MinWidth="100" IsDefault="True" ToolTip="تأكيد تحديد المنتج وإغلاق النافذة"/>
            </StackPanel>
        </Grid>

        <!-- General Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل المنتجات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
