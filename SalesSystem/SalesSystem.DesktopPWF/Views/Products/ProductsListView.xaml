<UserControl x:Class="SalesSystem.DesktopPWF.Views.Products.ProductsListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Products"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="📦  إدارة المنتجات"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="ProductsPageTitle"/>

        <!-- Toolbar (Search & Actions) -->
        <!-- Toolbar (Search & Actions) -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Group -->
                <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="160"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="TxtProductSearch"
                             Tag="اسم المنتج..."
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Command="{Binding SearchCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            Margin="4,0,0,0"
                            AutomationProperties.AutomationId="BtnProductSearch"
                            ToolTip="اضغط هنا للبحث عن المنتجات بالاسم">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,2,12,2">
                    <CheckBox Content="عرض غير النشطة" 
                               IsChecked="{Binding IncludeInactive}" 
                               VerticalAlignment="Center" 
                               FontSize="11"
                               AutomationProperties.AutomationId="ChkIncludeInactive"
                               ToolTip="عرض المنتجات المعطلة/غير النشطة أيضاً في القائمة"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="فتح شاشة إضافة منتج جديد"
                            AutomationProperties.AutomationId="BtnAddProduct">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="منتج جديد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل العنصر المحدد"
                            AutomationProperties.AutomationId="BtnEditProduct">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnDeleteProduct"
                            Visibility="{Binding SelectedProduct.IsActive, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}"
                            ToolTip="حذف أو إلغاء تنشيط العنصر المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حذف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RestoreCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            Visibility="{Binding SelectedProduct.IsActive, Converter={StaticResource InverseBoolToVisibility}, FallbackValue=Collapsed}"
                            AutomationProperties.AutomationId="BtnRestoreProduct"
                            ToolTip="استعادة العنصر المحذوف">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♻️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="استعادة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Padding="8,0"
                            AutomationProperties.AutomationId="BtnRefreshProducts"
                            ToolTip="تحديث قائمة البيانات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorTextBrush}" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding ProductsView}"
                          SelectedItem="{Binding SelectedProduct}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          MouseDoubleClick="ProductsDataGrid_MouseDoubleClick"
                          AutomationProperties.AutomationId="DgProducts">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" Command="{Binding EditCommand}"
                              ToolTip="فتح نافذة تعديل بيانات المنتج المحدد">
                                <MenuItem.Icon>
                                    <TextBlock Text="✏️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="حذف" Command="{Binding DeleteCommand}"
                                      ToolTip="إلغاء تنشيط المنتج المحدد — لن يظهر في قوائم الاختيار"
                                      Visibility="{Binding SelectedProduct.IsActive, Converter={StaticResource BoolToVisibility}}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🗑️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="استعادة" Command="{Binding RestoreCommand}"
                                      ToolTip="إعادة تنشيط المنتج — سيظهر في قوائم الاختيار مرة أخرى"
                                      Visibility="{Binding SelectedProduct.IsActive, Converter={StaticResource InverseBoolToVisibility}}">
                                <MenuItem.Icon>
                                    <TextBlock Text="♻️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم المنتج" 
                                            Binding="{Binding Id}" 
                                            Width="80" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="اسم المنتج" 
                                            Binding="{Binding Name}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="التصنيف" 
                                            Binding="{Binding CategoryName}" 
                                            Width="150" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="الوحدة" 
                                            Binding="{Binding UnitName}" 
                                            Width="90" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="سعر التجزئة" 
                                            Binding="{Binding RetailPrice, StringFormat=N2}" 
                                            Width="110" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="سعر الجملة" 
                                            Binding="{Binding WholesalePrice, StringFormat=N2}" 
                                            Width="110" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="الباركود" 
                                            Binding="{Binding Barcode}" 
                                            Width="130" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTemplateColumn Header="الحالة" Width="90" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                    <Setter Property="Text" Value="نشط"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                            <Setter Property="Text" Value="معطل"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📦" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد منتجات حالياً" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="ابدأ بإضافة منتجاتك وتعريف الأصناف للبدء في عمليات البيع والمخزون" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إضافة أول منتج" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="140"
                                ToolTip="فتح شاشة إضافة منتج جديد"
                                AutomationProperties.AutomationId="BtnEmptyAddProduct"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="إجمالي المنتجات: " FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ProductsView.Count, FallbackValue=0}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="4,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="آخر تحديث: " FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding LastUpdateTime}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل المنتجات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
