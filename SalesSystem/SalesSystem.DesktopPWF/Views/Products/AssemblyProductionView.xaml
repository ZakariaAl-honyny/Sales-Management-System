<UserControl x:Class="SalesSystem.DesktopPWF.Views.Products.AssemblyProductionView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource PrimaryBrush}" Padding="12,6" CornerRadius="6,6,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="أمر إنتاج" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,12,0,0">

                <!-- Assembly Product -->
                <TextBlock Text="المنتج المُجمَّع *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding AvailableProducts}"
                          SelectedItem="{Binding SelectedAssemblyProduct}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource ModernComboBox}"
                          ToolTip="اختر المنتج المُجمَّع المراد إنتاجه — يجب أن يكون له مكونات محددة مسبقاً"/>
                <TextBlock Text="اختر المنتج المُجمَّع الذي تريد إنتاجه" 
                           Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8"/>

                <!-- Warehouse -->
                <TextBlock Text="المستودع *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding AvailableWarehouses}"
                          SelectedItem="{Binding SelectedWarehouse}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource ModernComboBox}"
                          ToolTip="اختر المستودع الذي سيتم صرف المكونات منه وإضافة المنتج المُجمَّع إليه"/>
                <TextBlock Text="المستودع الذي سيتم صرف المكونات منه وإيداع المُجمَّع فيه" 
                           Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8"/>

                <!-- Quantity -->
                <TextBlock Text="الكمية المطلوب إنتاجها *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         ToolTip="أدخل كمية المنتج المُجمَّع المراد إنتاجها — سيتم صرف المكونات بنفس النسبة"/>
                <TextBlock Text="عدد وحدات المُجمَّع المراد إنتاجها (بالوحدة الأساسية)" 
                           Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Result Display -->
        <Border Grid.Row="2"
                Background="{StaticResource SuccessLightBrush}"
                BorderBrush="{StaticResource SuccessBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="0,12,0,0"
                CornerRadius="6"
                Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="{StaticResource SuccessTextBrush}" Margin="0,0,0,8">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="تم إنتاج {0:N3} وحدة من {1}">
                            <Binding Path="ProduceResult.QuantityProduced"/>
                            <Binding Path="ProduceResult.AssemblyProductName"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6">
                    <TextBlock.Text>
                        <Binding Path="ProduceResult.TotalCost" StringFormat="التكلفة الإجمالية: {0:N2} ر.س"/>
                    </TextBlock.Text>
                </TextBlock>

                <Separator Margin="0,4"/>

                <TextBlock Text="المكونات المُصرفة:" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4"/>

                <ItemsControl ItemsSource="{Binding ProduceResult.Components}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,3" Margin="0,1" Background="White" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ComponentProductName}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Margin="8,0" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <Binding Path="QuantityConsumed" StringFormat="{}{0:N3}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Grid.Column="2" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <Binding Path="TotalCost" StringFormat="{}{0:N2} ر.س"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Error Message -->
        <Border Grid.Row="3"
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="0,8,0,0"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Footer Buttons -->
        <Border Grid.Row="4" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding ProduceCommand}" Style="{StaticResource SuccessButton}"
                        ToolTip="تنفيذ أمر الإنتاج — صرف المكونات من المستودع وإضافة المُجمَّع للمخزون — هذه العملية نهائية">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إنتاج" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                        ToolTip="إلغاء وإغلاق نافذة أمر الإنتاج">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚫" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
