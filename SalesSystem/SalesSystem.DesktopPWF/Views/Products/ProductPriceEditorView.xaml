<UserControl x:Class="SalesSystem.DesktopPWF.Views.Products.ProductPriceEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Products"
       xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
       mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="💰  إضافة سعر جديد"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="TitleAddPrice"
                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="0"
                   Text="💰  تعديل السعر"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="TitleEditPrice"
                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12"/>

        <!-- Main Content Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16,0,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Error Message (inside card, above scroll) -->
                <Border Grid.Row="0"
                        Background="{StaticResource ErrorLightBrush}"
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        CornerRadius="6"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorTextBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable Form Fields -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,6">

                        <!-- Unit Name Display -->
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="الوحدة" Style="{StaticResource LabelStyle}"/>
                            <Border Background="{StaticResource InfoLightBrush}" Padding="10,6" CornerRadius="4">
                                <TextBlock Text="{Binding ProductUnitName}" FontWeight="SemiBold" FontSize="13"/>
                            </Border>
                        </StackPanel>

                        <!-- Currency -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="العملة *" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Currencies}"
                                      SelectedItem="{Binding SelectedCurrency}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"
                                      AutomationProperties.AutomationId="CmbPriceCurrency"
                                      ToolTip="اختر العملة — السعر محدد بهذه العملة"/>
                        </StackPanel>

                        <!-- Price Value -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="السعر *" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding PriceValue, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     AutomationProperties.AutomationId="TxtPriceValue"
                                     helpers:InputHelper.NumericOnly="True"
                                     ToolTip="قيمة السعر بهذه العملة — يجب أن تكون أكبر من صفر"/>
                        </StackPanel>

                        <!-- Effective From Date -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="من تاريخ *" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding EffectiveFrom}"
                                        Style="{StaticResource ModernDatePicker}"
                                        AutomationProperties.AutomationId="DtPriceEffectiveFrom"
                                        ToolTip="تاريخ بدء سريان السعر — يبدأ السعر من هذا التاريخ"/>
                        </StackPanel>

                        <!-- Effective To Date (optional) -->
                        <StackPanel Margin="0,0,0,6">
                            <CheckBox IsChecked="{Binding HasEffectiveTo}"
                                      Content="انتهاء صلاحية"
                                      ToolTip="قم بتفعيل هذا الخيار إذا كان للسعر تاريخ انتهاء صلاحية"
                                      AutomationProperties.AutomationId="ChkHasEffectiveTo"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6"
                                    IsEnabled="{Binding HasEffectiveTo}">
                            <TextBlock Text="إلى تاريخ" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding EffectiveTo}"
                                        Style="{StaticResource ModernDatePicker}"
                                        AutomationProperties.AutomationId="DtPriceEffectiveTo"
                                        ToolTip="تاريخ انتهاء صلاحية السعر — بعد هذا التاريخ لن يكون السعر سارياً"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        AutomationProperties.AutomationId="BtnSavePrice"
                        ToolTip="حفظ بيانات السعر — سيتم التحقق من صحة البيانات قبل الحفظ">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="4,0,0,0"
                        AutomationProperties.AutomationId="BtnCancelPrice"
                        ToolTip="إلغاء الأمر والعودة للقائمة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ بيانات السعر..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
