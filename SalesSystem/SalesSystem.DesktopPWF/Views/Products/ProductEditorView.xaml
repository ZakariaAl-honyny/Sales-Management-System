<Window x:Class="SalesSystem.DesktopPWF.Views.Products.ProductEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="780" Width="650"
        MinHeight="600" MinWidth="600"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconProduct}" Fill="White" Width="24" Height="24" Margin="0,0,16,0" Stretch="Uniform"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Basic Info Section -->
                        <TextBlock Text="المعلومات الأساسية" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        

                        <TextBlock Text="اسم المنتج *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="أدخل اسم المنتج بالكامل" 
                                 TabIndex="2"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtProductName"
                                 ToolTip="اسم المنتج كما يظهر في الفواتير — هذا الحقل إلزامي"/>
                        <Border Height="8"/>

                        <TextBlock Text="الفئة *" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedValue="{Binding CategoryId, ValidatesOnDataErrors=True}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"
                                  TabIndex="3"
                                  helpers:FocusHelper.AdvanceOnEnter="True"
                                  ToolTip="اختر الفئة التي ينتمي إليها المنتج (مثل: مواد غذائية، مشروبات)"/>
                                <Border Height="8"/>

                        <TextBlock Text="الوصف" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource ModernTextBox}" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 Height="60"
                                 VerticalContentAlignment="Top" 
                                 TabIndex="4"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 ToolTip="وصف إضافي للمنتج (اختياري) — يظهر في الفواتير والتقارير"/>
                        <Border Height="24"/>

                        <!-- Dual Units Section -->
                        <TextBlock Text="إعدادات الوحدات (نظام ثنائي الوحدات)" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="وحدة البيع (تجزئة) *" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Units}"
                                          SelectedValue="{Binding RetailUnitId, ValidatesOnDataErrors=True}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          TabIndex="5"
                                          ToolTip="وحدة البيع بالتجزئة (مثل: حبة، كيس) — الوحدة الأساسية للمخزون"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="وحدة الجملة *" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Units}"
                                          SelectedValue="{Binding WholesaleUnitId, ValidatesOnDataErrors=True}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          TabIndex="6"
                                          ToolTip="وحدة البيع بالجملة (مثل: كرتون، صندوق) — تستخدم لمبيعات الجملة"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="معامل التحويل (جملة->تجزئة) *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding ConversionFactor, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N3}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         TabIndex="7"
                                         ToolTip="عدد وحدات التجزئة في وحدة الجملة (مثلاً 12 قطعة في الكرتون) — هذا الحقل إلزامي"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="ملاحظة: وحدة التجزئة هي الوحدة الأساسية للمخزون" Style="{StaticResource HelperTextStyle}" Margin="0,4,0,0"/>
                        <Border Height="24"/>

                        <!-- Pricing Section -->
                        <TextBlock Text="الأسعار والتكلفة" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="سعر التجزئة *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding RetailPrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                         TabIndex="8"
                                         ToolTip="سعر البيع للعميل العادي (تجزئة) — هذا الحقل إلزامي ويجب أن يكون أكبر من صفر"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="سعر الجملة *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding WholesalePrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"
                                         TabIndex="9"
                                         ToolTip="سعر البيع لتجار الجملة — هذا الحقل إلزامي ويجب أن يكون أكبر من صفر"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="سعر التكلفة (تجزئة)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         TabIndex="10"
                                         ToolTip="سعر شراء المنتج من المورد — يُستخدم لحساب تكلفة المخزون والأرباح"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="الباركود" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         TabIndex="11"
                                         ToolTip="الباركود (رقم المنتج العالمي) — يجب أن يكون فريداً لكل منتج. إذا كان المنتج ليس له باركود، اتركه فارغاً"/>
                                <TextBlock Text="الباركود يجب أن يكون فريداً — لا يمكن تكرار نفس الرمز لمنتجين مختلفين" Style="{StaticResource HelperTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="تنبيه المخزون المنخفض (بالتجزئة)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding MinStock, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N3}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         TabIndex="12"
                                         ToolTip="الحد الأدنى للمخزون — سيتم تنبيهك عندما يصل المخزون إلى هذا الحد"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="24"/>

                        <!-- Options Section -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="منتج نشط" IsChecked="{Binding IsActive}" Margin="0,0,24,0" TabIndex="13"/>
                            </StackPanel>
                            <Border Height="16"/>
                            
                            <!-- Expiration Date Section -->
                            <TextBlock Text="تاريخ انتهاء الصلاحية" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="له تاريخ انتهاء" 
                                          IsChecked="{Binding HasExpirationDate}" 
                                          VerticalAlignment="Center"
                                          Margin="0,0,16,0"
                                          TabIndex="14"
                                          ToolTip="حدد هذا الخيار إذا كان المنتج له تاريخ صلاحية"/>
                                
                                <DatePicker SelectedDate="{Binding ExpirationDate, ValidatesOnDataErrors=True, TargetNullValue=''}"
                                            IsEnabled="{Binding HasExpirationDate}"
                                            Width="200"
                                            Style="{StaticResource ModernDatePicker}"
                                            TabIndex="15"
                                            ToolTip="اختر تاريخ انتهاء صلاحية المنتج — لا يمكن أن يكون في الماضي"/>
                            </StackPanel>
                            <TextBlock Text="يجب أن يكون تاريخ الانتهاء في المستقبل — سيتم تنبيهك قبل 30 يوماً من انتهاء الصلاحية" 
                                       Style="{StaticResource HelperTextStyle}" Margin="0,4,0,0"/>
                            
                            <Border Height="24"/>
                            
                            <!-- Image Upload Section -->
                            <TextBlock Text="صورة المنتج" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Command="{Binding UploadImageCommand}" 
                                        Style="{StaticResource SecondaryButton}"
                                        Width="140"
                                        Margin="0,0,12,0"
                                        TabIndex="16"
                                        ToolTip="اختيار صورة للمنتج من جهاز الكمبيوتر — يُسمح بملفات JPG و PNG فقط">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconUpload}" Fill="{StaticResource TextSecondaryBrush}" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                                        <TextBlock Text="اختيار صورة"/>
                                    </StackPanel>
                                </Button>
                                
                                <Border Background="#FFF5F5F5" CornerRadius="4" Padding="8,4" 
                                        Visibility="{Binding ImagePath, Converter={StaticResource StringToVisibility}}">
                                    <TextBlock Text="{Binding ImagePath}" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            
                            <!-- Image Preview -->
                            <Border Width="120" Height="120" 
                                    Background="#FFF5F5F5" 
                                    CornerRadius="4"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Visibility="{Binding ImagePath, Converter={StaticResource StringToVisibility}}">
                                <Image Source="{Binding ImagePath, IsAsync=True}" 
                                       Width="100" Height="100"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,100,100"/>
                                    </Image.Clip>
                                </Image>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="24,16" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            Width="140"
                            Margin="0,0,12,0"
                            IsDefault="True" 
                            TabIndex="17"
                            ToolTip="حفظ البيانات المدخلة">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSave}" Fill="White" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="حفظ البيانات"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Content="إلغاء" 
                            Command="{Binding CancelCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            Width="100"
                            TabIndex="18"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ المنتج..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
