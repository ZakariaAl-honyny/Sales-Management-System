<Window x:Class="SalesSystem.DesktopPWF.Views.Products.ProductEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="780" Width="650"
        MinHeight="600" MinWidth="600"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconProduct}" Fill="White" Width="24" Height="24" Margin="0,0,16,0" Stretch="Uniform"/>
                <TextBlock Text="📦 " FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Tabbed Content -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Margin="0,4,0,0"
                    TabStripPlacement="Top"
                    ToolTip="تبويب معلومات المنتج">
            
            <!-- Tab 1: Basic Info -->
            <TabItem Header="📋 معلومات أساسية">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="اسم المنتج *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         Tag="أدخل اسم المنتج بالكامل" 
                                         TabIndex="2"
                                         helpers:FocusHelper.AdvanceOnEnter="True"
                                         AutomationProperties.AutomationId="TxtProductName"
                                         ToolTip="اسم المنتج كما يظهر في الفواتير — هذا الحقل إلزامي"/>
                                <Border Height="6"/>

                                <TextBlock Text="الفئة *" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Categories}"
                                          SelectedValue="{Binding CategoryId, ValidatesOnDataErrors=True}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          TabIndex="3"
                                          helpers:FocusHelper.AdvanceOnEnter="True"
                                          ToolTip="اختر الفئة التي ينتمي إليها المنتج (مثل: مواد غذائية، مشروبات)"/>
                                <Border Height="6"/>

                                <TextBlock Text="الوصف" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                         Style="{StaticResource ModernTextBox}" 
                                         TextWrapping="Wrap" 
                                         AcceptsReturn="True" 
                                         Height="56"
                                         VerticalContentAlignment="Top" 
                                         TabIndex="4"
                                         ToolTip="وصف إضافي للمنتج (اختياري) — يظهر في الفواتير والتقارير"/>
                                <Border Height="8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                        <TextBlock Text="الباركود" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                                 Style="{StaticResource ModernTextBox}" 
                                                 TabIndex="5"
                                                 ToolTip="الباركود (رقم المنتج العالمي) — يجب أن يكون فريداً لكل منتج. إذا كان المنتج ليس له باركود، اتركه فارغاً"/>
                                        <TextBlock Text="الباركود يجب أن يكون فريداً — لا يمكن تكرار نفس الرمز لمنتجين مختلفين" Style="{StaticResource HelperTextStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <TextBlock Text="تنبيه المخزون المنخفض" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding ReorderLevel, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N3}" 
                                                 Style="{StaticResource ModernTextBox}" 
                                                 TabIndex="6"
                                                 ToolTip="الحد الأدنى للمخزون — سيتم تنبيهك عندما يصل المخزون إلى هذا الحد"/>
                                    </StackPanel>
                                </Grid>
                                <Border Height="8"/>

                                <!-- Options Section -->
                                <StackPanel>
                                    <CheckBox Content="منتج نشط" IsChecked="{Binding IsActive}" TabIndex="7"
                                              ToolTip="إلغاء التفعيل يخفي المنتج من قوائم الاختيار"/>
                                    <CheckBox Content="تتبع الصلاحية" IsChecked="{Binding TrackExpiry}" TabIndex="8"
                                              ToolTip="تفعيل تتبع تواريخ انتهاء الصلاحية للمنتج — يظهر حقل تاريخ الانتهاء في المعاملات"
                                              Visibility="{Binding ShowOpeningFields, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Opening Stock Section (create mode only) -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0"
                                Visibility="{Binding ShowOpeningFields, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="المخزون الافتتاحي" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="الكمية الافتتاحية" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding OpeningQuantity, StringFormat=N3, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                 Style="{StaticResource ModernTextBox}"
                                                 ToolTip="الكمية المتاحة عند إضافة المنتج لأول مرة — يمكن تركها فارغة لبدء المخزون من الصفر"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="4,0">
                                        <TextBlock Text="تكلفة الوحدة" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding OpeningUnitCost, StringFormat=N2, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                 Style="{StaticResource ModernTextBox}"
                                                 ToolTip="تكلفة شراء الوحدة الواحدة عند فتح المخزون — تستخدم لحساب تكلفة المخزون الافتتاحي"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                        <TextBlock Text="تاريخ الانتهاء" Style="{StaticResource LabelStyle}"/>
                                        <DatePicker SelectedDate="{Binding OpeningExpiryDate, ValidatesOnDataErrors=True}"
                                                    Style="{StaticResource ModernDatePicker}"
                                                    ToolTip="تاريخ انتهاء صلاحية الدفعة الافتتاحية — مطلوب إذا كان المنتج يتطلب تتبع الصلاحية وتم إدخال كمية افتتاحية"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- Phase 25: وحدة القياس تُدار عبر شاشة وحدات الصنف -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="وحدات القياس" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="تتم إدارة وحدات القياس من شاشة «وحدات الصنف» عبر زر الوحدات في شريط الأدوات" 
                                           Style="{StaticResource HelperTextStyle}" TextWrapping="Wrap"/>
                                <TextBlock Text="بعد حفظ المنتج، يمكنك إضافة وحدات قياس متعددة (مثل: قطعة، علبة، كرتون) مع معامل التحويل المناسب" 
                                           Style="{StaticResource HelperTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Tab 3: Pricing (inline DataGrid) -->
            <TabItem Header="💰 الأسعار">
                <Grid Margin="8,6,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Command="{Binding AddPriceCommand}" Style="{StaticResource PrimaryButton}" 
                                Margin="0,0,4,0" MinWidth="100"
                                ToolTip="إضافة سعر جديد للوحدة والعملة المحددة">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="إضافة سعر" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding EditPriceCommand}" Style="{StaticResource SecondaryButton}" 
                                Margin="4,0" MinWidth="80"
                                ToolTip="تعديل السعر المحدد — يمكن تغيير القيمة والتواريخ">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✏️" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RefreshPricesCommand}" Style="{StaticResource SecondaryButton}"
                                Margin="4,0,0,0" MinWidth="40"
                                ToolTip="تحديث قائمة الأسعار">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Prices}"
                              SelectedItem="{Binding SelectedPrice}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{StaticResource ModernDataGrid}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الوحدة" Binding="{Binding ProductUnitName}" Width="100"/>
                            <DataGridTextColumn Header="العملة" Binding="{Binding CurrencyCode}" Width="70"/>
                            <DataGridTextColumn Header="السعر" Binding="{Binding Price, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="من تاريخ" Binding="{Binding EffectiveFrom, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="إلى تاريخ" Binding="{Binding EffectiveTo, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTemplateColumn Header="ساري" Width="70" CellStyle="{StaticResource DataGridCellCenterStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                    <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrentlyEffective}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                        <Setter Property="Text" Value="منتهي"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrentlyEffective}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                                <Setter Property="Text" Value="ساري"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <TextBlock Grid.Row="2" Text="{Binding Prices.Count, StringFormat='عدد الأسعار: {0}'}" 
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- Tab 4: Images (placeholder — feature not yet implemented) -->
            <TabItem Header="🖼️ الصور">
                <Grid Margin="8,6,8,8">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🖼️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.3"/>
                        <TextBlock Text="إدارة صور المنتج" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="هذه الميزة قيد التطوير — سيتم إتاحتها قريباً" FontSize="13" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Tab 5: Batches (read-only DataGrid) -->
            <TabItem Header="📦 الدفعات" IsEnabled="{Binding IsExistingProduct}"
                     ToolTip="عرض دفعات المخزون — متاح للمنتجات المحفوظة فقط">
                <Grid Margin="8,6,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Command="{Binding RefreshBatchesCommand}" Style="{StaticResource SecondaryButton}"
                                MinWidth="40"
                                ToolTip="تحديث قائمة دفعات المخزون">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Batches}"
                              SelectedItem="{Binding SelectedBatch}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{StaticResource ModernDataGrid}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الدفعة" Binding="{Binding BatchNo}" Width="110"/>
                            <DataGridTextColumn Header="المستودع" Binding="{Binding WarehouseName}" Width="120"/>
                            <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity, StringFormat=N3}" Width="90"/>
                            <DataGridTextColumn Header="تكلفة الوحدة" Binding="{Binding UnitCost, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="القيمة" Binding="{Binding TotalValue, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="تاريخ التصنيع" Binding="{Binding ManufactureDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="تاريخ الانتهاء" Binding="{Binding ExpiryDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTemplateColumn Header="حالة الصلاحية" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                    <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                        <Setter Property="Text" Value="ساري"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                                <Setter Property="Text" Value="منتهي"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <TextBlock Grid.Row="2" Text="{Binding Batches.Count, StringFormat='عدد الدفعات: {0}'}" 
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="100"
                            Margin="0,0,12,0"
                            IsDefault="True" 
                            TabIndex="17"
                            ToolTip="حفظ البيانات المدخلة">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSave}" Fill="White" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="حفظ البيانات"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Content="إلغاء" 
                            Command="{Binding CancelCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            MinWidth="80"
                            TabIndex="18"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ المنتج..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
