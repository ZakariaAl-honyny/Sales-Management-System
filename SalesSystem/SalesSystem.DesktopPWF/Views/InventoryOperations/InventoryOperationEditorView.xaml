<UserControl x:Class="SalesSystem.DesktopPWF.Views.InventoryOperations.InventoryOperationEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.InventoryOperations"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:InventoryOperationEditorViewModel}"
      
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding HeaderIcon}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding WindowTitle}" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="#B0D4F1" Margin="26,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
            <StackPanel>
                <!-- Metadata Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="12">
                    <StackPanel>
                        <!-- First Row: Warehouse + Date -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="المستودع *" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding Warehouses}"
                                      SelectedValue="{Binding WarehouseId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"
                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                      AutomationProperties.AutomationId="CboOperationWarehouse"
                                      ToolTip="اختر المستودع الذي ستتم فيه العملية المخزنية"/>

                            <TextBlock Grid.Column="3" Text="التاريخ" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker Grid.Column="4" 
                                        SelectedDate="{Binding OperationDate}"
                                        Style="{StaticResource ModernDatePicker}"
                                        IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                        AutomationProperties.AutomationId="DpOperationDate"
                                        ToolTip="تاريخ العملية المخزنية"/>
                        </Grid>

                        <!-- Second Row: ReferenceNo + AdjustmentType -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="رقم المرجع" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding ReferenceNo, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     IsReadOnly="{Binding IsReadOnly}"
                                     AutomationProperties.AutomationId="TxtReferenceNo"
                                     ToolTip="رقم المرجع الخارجي (فاتورة مورد / إذن صرف / ...) — اختياري"/>

                            <!-- Adjustment Type (only for Adjustment operation) -->
                            <TextBlock Grid.Column="3" Text="نوع التسوية *" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Visibility="{Binding IsAdjustmentType, Converter={StaticResource BoolToVisibility}}"/>
                            <ComboBox Grid.Column="4" 
                                      ItemsSource="{Binding AdjustmentTypeList}"
                                      SelectedValue="{Binding AdjustmentType}"
                                      SelectedValuePath="Key"
                                      DisplayMemberPath="Value"
                                      Style="{StaticResource ModernComboBox}"
                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                      AutomationProperties.AutomationId="CboAdjustmentType"
                                      ToolTip="اختر نوع التسوية: فائض (زيادة في المخزون) أو عجز (نقص في المخزون)"
                                      Visibility="{Binding IsAdjustmentType, Converter={StaticResource BoolToVisibility}}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Items Card -->
                <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True" MinHeight="300">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Add Item Header -->
                        <Border Grid.Row="0" Background="#F8FAFC" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="أصناف العملية" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Width="220" Margin="0,0,8,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBox Grid.Column="1" 
                                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="ابحث بالباركود أو الاسم..."
                                                     Style="{StaticResource ModernTextBox}"
                                                     BorderThickness="0"
                                                     VerticalContentAlignment="Center"
                                                     helpers:InputHelper.EnterKeyCommand="{Binding QuickAddProductCommand}"
                                                     IsReadOnly="{Binding IsReadOnly}"
                                                     AutomationProperties.AutomationId="TxtQuickAddProduct"/>
                                        </Grid>
                                    </Border>

                                    <Button Style="{StaticResource SuccessButton}" 
                                            Padding="10,4"
                                            Command="{Binding SearchProductCommand}"
                                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                                            AutomationProperties.AutomationId="BtnAddItem"
                                            ToolTip="فتح نافذة البحث عن منتج لإضافته للعملية">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="إضافة صنف" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Items DataGrid -->
                        <DataGrid Grid.Row="1" 
                                  ItemsSource="{Binding Items}"
                                  Style="{StaticResource ModernDataGrid}"
                                  MinHeight="220"
                                  MaxHeight="450"
                                  BorderThickness="0"
                                  CanUserAddRows="False"
                                  AutomationProperties.AutomationId="DgOperationItems">
                            <DataGrid.Columns>
                                <!-- Product column -->
                                <DataGridTemplateColumn Header="الصنف *" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" 
                                                          ItemsSource="{Binding Products}"
                                                          SelectedValue="{Binding ProductId, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Id"
                                                          DisplayMemberPath="Name"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          TextSearch.TextPath="Name"
                                                          Style="{StaticResource ModernComboBox}"
                                                          Height="28" Padding="8,0"
                                                          BorderThickness="0"
                                                          IsEnabled="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
                                                          ToolTip="اختر المنتج من القائمة أو اكتب للبحث"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Quantity column -->
                                <DataGridTextColumn Header="الكمية *" 
                                                    Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N3}" 
                                                    Width="110"
                                                    CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                                <!-- UnitCost column (only for StockReceipt) -->
                                <DataGridTextColumn Header="تكلفة الوحدة" 
                                                    Binding="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                                    Width="120"
                                                    CellStyle="{StaticResource DataGridCellCenterStyle}"
                                                    Visibility="{Binding DataContext.IsStockReceipt, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}"/>

                                <!-- StockIssueReason column (only for StockIssue) -->
                                <DataGridTemplateColumn Header="سبب الصرف" Width="140"
                                                        Visibility="{Binding DataContext.IsStockIssue, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.StockIssueReasonList, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding StockIssueReason, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="Value"
                                                      Style="{StaticResource ModernComboBox}"
                                                      Height="28"
                                                      BorderThickness="0"
                                                      IsEnabled="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
                                                      ToolTip="سبب الصرف: تالف / استخدام داخلي / عينة مجانية / أخرى"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Notes column -->
                                <DataGridTextColumn Header="ملاحظات" 
                                                    Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                                                    Width="120"
                                                    CellStyle="{StaticResource DataGridCellStyle}"/>

                                <!-- Remove button -->
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="🗑️"
                                                    Style="{StaticResource DangerButton}"
                                                    Height="26" Width="26" Padding="0"
                                                    Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVisibility}}"
                                                    AutomationProperties.AutomationId="BtnRemoveItem"
                                                    ToolTip="حذف هذا السطر من العملية"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Notes Card -->
                <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,8,0,0">
                    <StackPanel>
                        <Border Background="#F8FAFC" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <TextBlock Text="ملاحظات" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        </Border>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="50"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Padding="8,4"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 AutomationProperties.AutomationId="TxtOperationNotes"
                                 ToolTip="ملاحظات إضافية حول العملية المخزنية"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="✅ ترحيل" 
                            Command="{Binding PostCommand}" 
                            Style="{StaticResource PrimaryButton}" 
                            Width="100" 
                            Margin="0,0,8,0"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                            AutomationProperties.AutomationId="BtnPostOperation"
                            ToolTip="حفظ وترحيل العملية فوراً — سيتم تحديث المخزون في المستودع ولا يمكن التراجع"/>

                    <Button Content="💾 حفظ مسودة" 
                            Command="{Binding SaveCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            Width="100" 
                            Margin="0,0,8,0" 
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                            AutomationProperties.AutomationId="BtnSaveOperation"
                            ToolTip="حفظ العملية كمسودة دون ترحيل — يمكن التعديل عليها لاحقاً"/>

                    <Button Content="🚫 إغلاق" 
                            Command="{Binding CancelCommand}" 
                            Style="{StaticResource SecondaryButton}"
                            Width="80"
                            AutomationProperties.AutomationId="BtnCloseEditor"
                            ToolTip="إغلاق النافذة دون حفظ"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap" 
                           Margin="0,6,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
