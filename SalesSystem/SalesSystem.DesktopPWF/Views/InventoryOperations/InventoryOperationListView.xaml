<UserControl x:Class="SalesSystem.DesktopPWF.Views.InventoryOperations.InventoryOperationListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.InventoryOperations"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:InventoryOperationListViewModel}"
      
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="📦  العمليات المخزنية"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="InventoryOperationsPageTitle"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="200"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="رقم العملية..."
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True"
                             AutomationProperties.AutomationId="TxtSearchOperation">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Command="{Binding SearchCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            Margin="4,0,0,0"
                            AutomationProperties.AutomationId="BtnSearchOperation"
                            ToolTip="البحث عن عملية برقم العملية أو اسم المستودع">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Type Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="النوع" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding TypeFilterList}"
                              SelectedValue="{Binding SelectedTypeFilter}"
                              SelectedValuePath="Key"
                              DisplayMemberPath="Value"
                              Style="{StaticResource ModernComboBox}"
                              Width="130"
                              AutomationProperties.AutomationId="CboOperationTypeFilter"
                              ToolTip="تصفية العمليات حسب النوع — صرف مخزني / توريد مخزني / تسوية مخزنية"/>
                </StackPanel>

                <!-- Warehouse Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="المستودع" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedValue="{Binding SelectedWarehouseFilter}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Style="{StaticResource ModernComboBox}"
                              Width="140"
                              AutomationProperties.AutomationId="CboWarehouseFilter"
                              ToolTip="تصفية العمليات حسب المستودع"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnAddOperation"
                            ToolTip="فتح شاشة إضافة عملية مخزنية جديدة — صرف / توريد / تسوية حسب الفلتر المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="عملية جديدة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PostCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnPostOperation"
                            ToolTip="ترحيل العملية المحددة — سيتم تحديث المخزون في المستودع">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ترحيل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelOperationCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnCancelOperation"
                            ToolTip="إلغاء العملية المحددة — سيتم عكس تأثيرها على المخزون">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnRefreshOperations"
                            ToolTip="تحديث قائمة العمليات المخزنية">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorTextBrush}" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Grid Area -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding OperationsView}"
                          SelectedItem="{Binding SelectedOperation}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          AutomationProperties.AutomationId="DgInventoryOperations">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="عرض التفاصيل" Command="{Binding ViewCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="👁️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="ترحيل" Command="{Binding PostCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="✅"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="إلغاء" Command="{Binding CancelOperationCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="❌"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <!-- Operation ID -->
                        <DataGridTextColumn Header="الرقم" 
                                             Binding="{Binding Id}" 
                                             Width="70" 
                                             CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <!-- Operation No -->
                        <DataGridTextColumn Header="رقم العملية" 
                                             Binding="{Binding OperationNo}" 
                                             Width="130" 
                                             CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <!-- Operation Type -->
                        <DataGridTemplateColumn Header="النوع" Width="120" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               ToolTip="نوع العملية المخزنية">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="صرف مخزني"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OperationType}" Value="2">
                                                        <Setter Property="Text" Value="توريد مخزني"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding OperationType}" Value="3">
                                                        <Setter Property="Text" Value="تسوية مخزنية"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Warehouse -->
                        <DataGridTextColumn Header="المستودع" 
                                             Binding="{Binding WarehouseName}" 
                                             Width="*" 
                                             CellStyle="{StaticResource DataGridCellStyle}"/>

                        <!-- Operation Date -->
                        <DataGridTextColumn Header="التاريخ" 
                                             Binding="{Binding OperationDate, StringFormat=yyyy-MM-dd}" 
                                             Width="100" 
                                             CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <!-- Items Count -->
                        <DataGridTextColumn Header="عدد الأصناف" 
                                             Binding="{Binding Items.Count}" 
                                             Width="90" 
                                             CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <!-- Status -->
                        <DataGridTemplateColumn Header="الحالة" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="1"> <!-- Draft -->
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="2"> <!-- Posted -->
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3"> <!-- Cancelled -->
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Text" Value="مسودة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Text" Value="مرحل"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Text" Value="ملغي"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📦" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد عمليات مخزنية حالياً" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="قم بإضافة عملية صرف أو توريد أو تسوية مخزنية جديدة" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إضافة أول عملية" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="140"
                                ToolTip="فتح شاشة إضافة عملية مخزنية جديدة"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Background="White" Padding="10,4" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="إجمالي العمليات: " FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding OperationsCount}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل العمليات المخزنية..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
