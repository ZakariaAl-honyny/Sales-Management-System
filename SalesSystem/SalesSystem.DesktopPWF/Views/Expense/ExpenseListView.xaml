<UserControl x:Class="SalesSystem.DesktopPWF.Views.Expense.ExpenseListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16,16,16,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="  المصروفات" Style="{StaticResource HeaderStyle}"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="بحث" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="250" Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="ابحث عن مصروف..." TabIndex="1"/>
                    <Button Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                            ToolTip="البحث عن مصروف بالرقم أو البيان">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="إضافة مصروف جديد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBlock Text="إضافة مصروف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل المصروف المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PostCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="ترحيل المصروف المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ترحيل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelCommand}" Style="{StaticResource WarningButton}" Margin="0,0,4,0"
                            ToolTip="إلغاء المصروف المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            ToolTip="حذف المصروف المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="حذف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة المصروفات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="تحديث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="12,8"
                Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorTextBrush}" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding ExpensesView}"
                          SelectedItem="{Binding SelectedExpense}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم المصروف" Binding="{Binding ExpenseNo}" Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="البيان" Binding="{Binding Notes}" Width="*"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="المبلغ" Binding="{Binding Amount, StringFormat='{}{0:N2}'}" Width="120"
                                            CellStyle="{StaticResource DataGridCellNumberStyle}"/>
                        <DataGridTextColumn Header="الصندوق" Binding="{Binding CashBoxName}" Width="120"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTemplateColumn Header="الحالة" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusName}" Value="Posted">
                                                        <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusName}" Value="Cancelled">
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Setter Property="Text" Value="مسودة"/>
                                                    <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusName}" Value="Posted">
                                                            <Setter Property="Text" Value="مرحل"/>
                                                            <Setter Property="Foreground" Value="{StaticResource InfoTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusName}" Value="Cancelled">
                                                            <Setter Property="Text" Value="ملغي"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy/MM/dd}'}" Width="80"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="لا توجد مصروفات مسجلة" Style="{StaticResource HeaderStyle}" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="ابدأ بإضافة مصروف جديد من خلال الزر أعلاه" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="+ إضافة أول مصروف" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="140"
                                ToolTip="فتح شاشة إضافة مصروف جديد"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل المصروفات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
