<UserControl x:Class="SalesSystem.DesktopPWF.Views.Reports.ReturnsReportView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views.Reports"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="🔄 تقرير المرتجعات"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="ReturnsReportPageTitle"/>

        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="النوع:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Width="120"
                              ItemsSource="{Binding ReturnTypes}"
                              SelectedItem="{Binding SelectedReturnType}"
                              ToolTip="تصفية حسب نوع المرتجع"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="المنتج:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Width="140"
                              ItemsSource="{Binding Products}"
                              SelectedValue="{Binding SelectedProductId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              ToolTip="تصفية حسب المنتج"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="من:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Width="120" SelectedDate="{Binding DateFrom}" ToolTip="تاريخ البداية"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="إلى:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Width="120" SelectedDate="{Binding DateTo}" ToolTip="تاريخ النهاية"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding ExportCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            ToolTip="تصدير بيانات التقرير إلى ملف Excel">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📥" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تصدير Excel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding LoadCommand}" Style="{StaticResource PrimaryButton}"
                            ToolTip="تحديث بيانات التقرير">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تحديث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <Border Background="{StaticResource ErrorLightBrush}"
                        Padding="10,6" Margin="0,0,0,0" VerticalAlignment="Top"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <Button Grid.Column="2" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" Height="28" Padding="12,0" FontSize="11"
                                ToolTip="إعادة المحاولة">
                            <TextBlock Text="إعادة المحاولة"/>
                        </Button>
                    </Grid>
                </Border>

                <DataGrid ItemsSource="{Binding ReportData}"
                          AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource ModernDataGrid}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم المرتجع" Binding="{Binding ReturnNo}" Width="120"
                                            ToolTipService.ToolTip="رقم مستند المرتجع"/>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}" Width="100"
                                            ToolTipService.ToolTip="تاريخ المرتجع"/>
                        <DataGridTextColumn Header="النوع" Binding="{Binding Type}" Width="80"
                                            ToolTipService.ToolTip="نوع المرتجع (مبيعات/مشتريات)"/>
                        <DataGridTextColumn Header="الطرف" Binding="{Binding PartyName}" Width="1.5*"
                                            ToolTipService.ToolTip="اسم العميل أو المورد"/>
                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="1.5*"
                                            ToolTipService.ToolTip="اسم المنتج"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity, StringFormat={}{0:N3}}" Width="90"
                                            ToolTipService.ToolTip="الكمية المرتجعة"/>
                        <DataGridTextColumn Header="المبلغ" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="100"
                                            ToolTipService.ToolTip="قيمة المرتجع"/>
                        <DataGridTextColumn Header="السبب" Binding="{Binding Reason}" Width="1.5*"
                                            ToolTipService.ToolTip="سبب المرتجع"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding Status}" Width="80"
                                            ToolTipService.ToolTip="حالة المرتجع"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock Text="🔄" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد مرتجعات" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="لم يتم العثور على مرتجعات للفترة المحددة"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <Border Background="#CCFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="240" Height="6" Background="#E2E8F0" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="جاري تحميل البيانات..." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource FooterBarStyle}" Padding="12,8"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📊 الملخص:" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding SummaryText}" FontSize="13" VerticalAlignment="Center"
                           ToolTip="ملخص التقرير — إجمالي عدد المرتجعات"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
