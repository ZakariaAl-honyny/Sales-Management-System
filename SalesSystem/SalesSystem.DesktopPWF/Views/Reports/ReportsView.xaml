<Page x:Class="SalesSystem.DesktopPWF.Views.Reports.ReportsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views.Reports"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="التقارير"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="التقارير والإحصائيات"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="ReportsPageTitle"/>

        <!-- Filters Section -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Report Type Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="نوع التقرير" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Width="200" ItemsSource="{Binding ReportTypes}" SelectedValue="{Binding SelectedReportType}" SelectedValuePath="Type" DisplayMemberPath="DisplayName" Height="36" TabIndex="1"/>
                </StackPanel>

                <!-- Date Range Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="من" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <DatePicker SelectedDate="{Binding DateFrom}" Style="{StaticResource ModernDatePicker}" Width="150" TabIndex="2"/>
                    
                    <TextBlock Text="إلى" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="16,0,12,0"/>
                    <DatePicker SelectedDate="{Binding DateTo}" Style="{StaticResource ModernDatePicker}" Width="150" TabIndex="3"/>
                </StackPanel>

                <!-- Warehouse Filter (visible only for applicable reports) -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5"
                            Visibility="{Binding WarehouseFilterVisible, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="المخزن" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Width="180" Height="36" TabIndex="4"
                              ItemsSource="{Binding Warehouses}"
                              SelectedValue="{Binding SelectedWarehouseId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding GenerateReportCommand}" Style="{StaticResource PrimaryButton}" Height="36" Padding="20,0" TabIndex="4" ToolTip="توليد التقرير حسب المعايير المحددة">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="توليد التقرير" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Menu Background="Transparent" Margin="12,0,0,0">
                        <MenuItem Header="📁 تصدير" ToolTip="تصدير التقرير" Padding="12,4" Height="36" Background="#F1F5F9" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                            <MenuItem.Icon>
                                <TextBlock Text="📤" VerticalAlignment="Center"/>
                            </MenuItem.Icon>
                            <MenuItem Header="Excel (.xlsx)" ToolTip="تصدير إلى ملف Excel" Command="{Binding ExportExcelCommand}"/>
                            <MenuItem Header="CSV (.csv)" ToolTip="تصدير إلى ملف CSV" Command="{Binding ExportCsvCommand}"/>
                        </MenuItem>
                    </Menu>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Report Content -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <!-- 1. Data Results View -->
                <DataGrid ItemsSource="{Binding ReportData.DefaultView}"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          BorderThickness="0">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource ModernDataGrid}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                </DataGrid>

                <!-- 2. Empty/Initial State -->
                <Grid Visibility="{Binding HasSearched, Converter={StaticResource InverseBoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="جاهز لتوليد التقارير" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="اختر نوع التقرير والفترة الزمنية المطلوبة ثم اضغط على 'توليد التقرير'" 
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- 3. No Data Found View -->
                <Grid Background="White">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasSearched}" Value="True"/>
                                        <Condition Binding="{Binding IsEmpty}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد بيانات للعرض" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource ErrorBrush}"/>
                        <TextBlock Text="لم يتم العثور على أي سجلات مطابقة للفلاتر المختارة في هذه الفترة الزمنية" 
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Loading Overlay -->
                <Border Background="#CCFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="240" Height="6" Background="#E2E8F0" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="جاري تحليل البيانات وتوليد التقرير..." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer / Summary -->
        <Border Grid.Row="3" Style="{StaticResource FooterBarStyle}" Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📑 إجمالي التقرير:" Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding FormattedReportTotal}" Style="{StaticResource FooterBarTextStyle}" FontSize="22" FontWeight="Bold" Margin="12,0,8,0"/>
                <TextBlock Text="ريال" Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
