<UserControl x:Class="SalesSystem.DesktopPWF.Views.Reports.TrialBalanceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views.Reports"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📋  ميزان المراجعة" Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="TrialBalancePageTitle"/>

        <!-- Filters Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="كما في تاريخ" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <DatePicker SelectedDate="{Binding AsOfDate}" Style="{StaticResource ModernDatePicker}" Width="150" TabIndex="1"
                                ToolTip="اختر التاريخ الذي تريد عرض ميزان المراجعة عنده"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding GenerateReportCommand}" Style="{StaticResource PrimaryButton}" TabIndex="2"
                            ToolTip="توليد ميزان المراجعة حسب التاريخ المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="عرض ميزان المراجعة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExportExcelCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" TabIndex="3"
                            ToolTip="تصدير ميزان المراجعة إلى ملف Excel">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📥" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Excel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExportPdfCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" TabIndex="4"
                            ToolTip="تصدير ميزان المراجعة إلى ملف PDF">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="PDF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <!-- Error Message -->
                <Border Background="{StaticResource ErrorLightBrush}" Padding="10,6" Margin="0,0,0,0"
                        VerticalAlignment="Top" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <Button Grid.Column="2" Command="{Binding GenerateReportCommand}" Style="{StaticResource SecondaryButton}" Height="28" Padding="12,0" FontSize="11"
                                ToolTip="إعادة المحاولة">
                            <TextBlock Text="إعادة المحاولة"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <DataGrid ItemsSource="{Binding Entries}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          Margin="0,0,0,0">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource ModernDataGrid}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="كود الحساب" Binding="{Binding AccountCode}" Width="1*"
                                            ToolTipService.ToolTip="رمز الحساب في دليل الحسابات"/>
                        <DataGridTextColumn Header="اسم الحساب" Binding="{Binding AccountName}" Width="3*"
                                            ToolTipService.ToolTip="الاسم الكامل للحساب"/>
                        <DataGridTextColumn Header="مدين" Binding="{Binding Debit, StringFormat={}{0:N2}}" Width="2*"
                                            ToolTipService.ToolTip="إجمالي المبالغ المدينة">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="دائن" Binding="{Binding Credit, StringFormat={}{0:N2}}" Width="2*"
                                            ToolTipService.ToolTip="إجمالي المبالغ الدائنة">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock Text="📋" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="ميزان المراجعة" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="اختر التاريخ ثم اضغط على 'عرض ميزان المراجعة'"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Loading Overlay -->
                <Border Background="#CCFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="240" Height="6" Background="#E2E8F0" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="جاري تحميل ميزان المراجعة..." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Summary Footer -->
        <Border Grid.Row="3" Style="{StaticResource FooterBarStyle}"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,40,0">
                    <TextBlock Text="إجمالي المدين:" Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                    <TextBlock Text="{Binding FormattedTotalDebit}" Style="{StaticResource FooterBarTextStyle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" Margin="8,0,4,0"/>
                    <TextBlock Text="ريال" Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="إجمالي الدائن:" Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                    <TextBlock Text="{Binding FormattedTotalCredit}" Style="{StaticResource FooterBarTextStyle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="8,0,4,0"/>
                    <TextBlock Text="ريال" Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
