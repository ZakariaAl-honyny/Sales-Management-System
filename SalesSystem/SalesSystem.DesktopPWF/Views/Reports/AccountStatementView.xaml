<UserControl x:Class="SalesSystem.DesktopPWF.Views.Reports.AccountStatementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views.Reports"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
Text="📋  كشف حساب"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="AccountStatementPageTitle"/>

        <!-- Filters Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Mode Toggle -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="نوع الحساب" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton Content="عميل" IsChecked="{Binding IsCustomerMode}" GroupName="AccountMode" Margin="0,0,16,0" FontSize="14"
                                 ToolTip="عرض كشف حساب عميل — يعرض جميع الحركات المدينة والدائنة للعميل"/>
                    <RadioButton Content="مورد" IsChecked="{Binding IsCustomerMode, Converter={StaticResource InverseBoolConverter}}" GroupName="AccountMode" FontSize="14"
                                 ToolTip="عرض كشف حساب مورد — يعرض جميع الحركات المدينة والدائنة للمورد"/>
                </StackPanel>

                <!-- Customer Selection (visible in customer mode) -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5"
                            Visibility="{Binding IsCustomerMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="العميل" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Width="180" TabIndex="2"
                              ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              DisplayMemberPath="Name"
                              ToolTip="اختر العميل لعرض كشف الحساب الخاص به"/>
                </StackPanel>

                <!-- Supplier Selection (visible in supplier mode) -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5"
                            Visibility="{Binding IsSupplierMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="المورد" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Width="180" TabIndex="2"
                              ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              DisplayMemberPath="Name"
                              ToolTip="اختر المورد لعرض كشف الحساب الخاص به"/>
                </StackPanel>

                <!-- Date Range -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="من" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <DatePicker SelectedDate="{Binding DateFrom}" Style="{StaticResource ModernDatePicker}" Width="140" TabIndex="3"
                                ToolTip="بداية الفترة الزمنية لكشف الحساب"/>
                    <TextBlock Text="إلى" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="12,0,12,0"/>
                    <DatePicker SelectedDate="{Binding DateTo}" Style="{StaticResource ModernDatePicker}" Width="140" TabIndex="4"
                                ToolTip="نهاية الفترة الزمنية لكشف الحساب"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding GenerateCustomerStatementCommand}" Style="{StaticResource PrimaryButton}" TabIndex="5"
                            Visibility="{Binding IsCustomerMode, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="عرض كشف حساب العميل المحدد للفترة المختارة">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="كشف حساب عميل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GenerateSupplierStatementCommand}" Style="{StaticResource PrimaryButton}" TabIndex="6" Margin="8,0,0,0"
                            Visibility="{Binding IsSupplierMode, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="عرض كشف حساب المورد المحدد للفترة المختارة">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="كشف حساب مورد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <!-- Error Message -->
                <Border Background="{StaticResource ErrorLightBrush}"
                        Padding="10,6"
                        Margin="0,0,0,0"
                        VerticalAlignment="Top"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <Button Grid.Column="2" Command="{Binding GenerateCustomerStatementCommand}" Style="{StaticResource SecondaryButton}" Height="28" Padding="12,0" FontSize="11"
                                ToolTip="إعادة المحاولة">
                            <TextBlock Text="إعادة المحاولة"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- DataGrid — Account Statement Entries -->
                <DataGrid ItemsSource="{Binding Entries}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          Margin="0,0,0,0">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource ModernDataGrid}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat={}{0:yyyy/MM/dd}}" Width="1.2*"
                                            ToolTipService.ToolTip="تاريخ الحركة"/>
                        <DataGridTextColumn Header="البيان" Binding="{Binding Description}" Width="3*"
                                            ToolTipService.ToolTip="وصف الحركة"/>
                        <DataGridTextColumn Header="رقم المرجع" Binding="{Binding ReferenceNumber}" Width="1.2*"
                                            ToolTipService.ToolTip="رقم الفاتورة أو سند القبض المرتبط"/>
                        <DataGridTextColumn Header="مدين" Binding="{Binding Debit, StringFormat={}{0:N2}}" Width="1.2*"
                                            ToolTipService.ToolTip="المبلغ المدين (ما له على الحساب)">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="دائن" Binding="{Binding Credit, StringFormat={}{0:N2}}" Width="1.2*"
                                            ToolTipService.ToolTip="المبلغ الدائن (ما له على الحساب)">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="الرصيد" Binding="{Binding Balance, StringFormat={}{0:N2}}" Width="1.2*"
                                            ToolTipService.ToolTip="الرصيد التراكمي بعد الحركة">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock Text="📋" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="كشف حساب" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="اختر العميل أو المورد والفترة الزمنية ثم اضغط على 'كشف حساب'" 
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Loading Overlay -->
                <Border Background="#CCFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="240" Height="6" Background="#E2E8F0" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="جاري تحميل كشف الحساب..." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Summary Footer -->
        <Border Grid.Row="3" Style="{StaticResource FooterBarStyle}"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="الرصيد الختامي:" Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding FormattedRunningBalance}" Style="{StaticResource FooterBarTextStyle}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="12,0,8,0"/>
                <TextBlock Text="ريال" Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
