<UserControl x:Class="SalesSystem.DesktopPWF.Views.Reports.WorkingCapitalView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views.Reports"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="💰 تقرير رأس المال العامل"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="WorkingCapitalPageTitle"/>

        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="من:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Width="120" SelectedDate="{Binding DateFrom}" ToolTip="تاريخ البداية"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="إلى:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Width="120" SelectedDate="{Binding DateTo}" ToolTip="تاريخ النهاية"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding ExportCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            ToolTip="تصدير بيانات التقرير إلى ملف Excel">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📥" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تصدير Excel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding LoadCommand}" Style="{StaticResource PrimaryButton}"
                            ToolTip="تحديث بيانات التقرير">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تحديث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,16">
                <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,12">
                    <Grid>
                        <Border Background="{StaticResource ErrorLightBrush}"
                                Padding="10,6"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Grid.Column="2" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" Height="28" Padding="12,0" FontSize="11"
                                        ToolTip="إعادة المحاولة">
                                    <TextBlock Text="إعادة المحاولة"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="ملخص رأس المال العامل"
                                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,0,12">
                                <TextBlock.Visibility>
                                    <Binding Path="HasData" Converter="{StaticResource BoolToVisibility}"/>
                                </TextBlock.Visibility>
                            </TextBlock>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                        Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                                <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,8" Background="#F0F9FF">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#0369A1">
                                        <Run Text="إجمالي الأصول المتداولة:" FontWeight="Normal"/>
                                        <Run Text="{Binding TotalCurrentAssets, StringFormat={}{0:N2}}" FontWeight="Bold"/>
                                    </TextBlock>
                                </Border>
                                <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,8" Background="#FFF7ED">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#C2410C">
                                        <Run Text="إجمالي الخصوم المتداولة:" FontWeight="Normal"/>
                                        <Run Text="{Binding TotalCurrentLiabilities, StringFormat={}{0:N2}}" FontWeight="Bold"/>
                                    </TextBlock>
                                </Border>
                                <Border Style="{StaticResource CardStyle}" Padding="14" Background="#F0FDF4">
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#166534">
                                        <Run Text="صافي رأس المال العامل:" FontWeight="Normal"/>
                                        <Run Text="{Binding NetWorkingCapital, StringFormat={}{0:N2}}" FontWeight="ExtraBold"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,16,0,0"
                                        Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                                <Border Style="{StaticResource CardStyle}" Padding="14" Background="#F0FDF4">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#166534">
                                        <Run Text="النسبة الحالية (Current Ratio):" FontWeight="Normal"/>
                                        <Run Text="{Binding CurrentRatio, StringFormat={}{0:N2}}" FontWeight="Bold"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Margin="0,30,0,30">
                                <StackPanel.Visibility>
                                    <Binding Path="IsEmpty" Converter="{StaticResource BoolToVisibility}"/>
                                </StackPanel.Visibility>
                                <TextBlock Text="💰" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                                <TextBlock Text="لا توجد بيانات" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="اختر الفترة الزمنية ثم اضغط على 'تحديث'"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="0"
                        Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <TextBlock Text="تفاصيل الأصول والخصوم المتداولة" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="16,12,16,8"/>

                        <DataGrid ItemsSource="{Binding AccountDetails}"
                                  AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0"
                                  Margin="0,0,0,0">
                            <DataGrid.Style>
                                <Style TargetType="DataGrid" BasedOn="{StaticResource ModernDataGrid}">
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="الحساب" Binding="{Binding AccountName}" Width="2*"
                                                    ToolTipService.ToolTip="اسم الحساب"/>
                                <DataGridTextColumn Header="النوع" Binding="{Binding Type}" Width="80"
                                                    ToolTipService.ToolTip="نوع الحساب (أصل/خصم)"/>
                                <DataGridTextColumn Header="الرصيد" Binding="{Binding Balance, StringFormat={}{0:N2}}" Width="120"
                                                    ToolTipService.ToolTip="الرصيد الحالي للحساب"/>
                                <DataGridTextColumn Header="النسبة المئوية" Binding="{Binding Percentage, StringFormat={}{0:P1}}" Width="110"
                                                    ToolTipService.ToolTip="نسبة الحساب من إجمالي الأصول المتداولة"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Background="#CCFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">
                        <ProgressBar IsIndeterminate="True" Width="240" Height="6" Background="#E2E8F0" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="جاري تحميل البيانات..." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Style="{StaticResource FooterBarStyle}" Padding="12,8"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📊 الملخص:" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding SummaryText}" FontSize="13" VerticalAlignment="Center"
                           ToolTip="ملخص التقرير — إجمالي رأس المال العامل"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
