<Window x:Class="SalesSystem.DesktopPWF.Views.Inventory.InventoryTransactionEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="650" Width="900"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📦" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>
                <!-- Metadata Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="النوع" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <Border Grid.Row="0" Grid.Column="1" Background="#E3F2FD" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TransactionTypeDisplay}" FontWeight="SemiBold" Foreground="#1565C0"/>
                        </Border>

                        <TextBlock Grid.Row="0" Grid.Column="3" Text="التاريخ" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <DatePicker Grid.Row="0" Grid.Column="4"
                                    SelectedDate="{Binding TransactionDate}"
                                    Style="{StaticResource ModernDatePicker}"
                                    ToolTip="تاريخ الحركة"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="المستودع" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                  ItemsSource="{Binding Warehouses}"
                                  SelectedValue="{Binding WarehouseId}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"
                                  ToolTip="اختر المستودع"/>
                    </Grid>
                </Border>

                <!-- Items Card -->
                <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True" MinHeight="280">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Add Item Header -->
                        <Border Grid.Row="0" Background="#F8FAFC" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <TextBlock Text="الأصناف" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                                <Button HorizontalAlignment="Left"
                                        Style="{StaticResource SuccessButton}"
                                        Padding="10,4"
                                        Command="{Binding AddLineCommand}"
                                        ToolTip="فتح نافذة اختيار منتج">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="إضافة صنف" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Items DataGrid -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Lines}"
                                  Style="{StaticResource ModernDataGrid}"
                                  MinHeight="200"
                                  MaxHeight="450"
                                  BorderThickness="0"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="المنتج"
                                                    Binding="{Binding ProductName}"
                                                    Width="*"
                                                    IsReadOnly="True"
                                                    CellStyle="{StaticResource DataGridCellStyle}"/>

                                <DataGridTextColumn Header="الوحدة"
                                                    Binding="{Binding ProductUnitName}"
                                                    Width="70"
                                                    IsReadOnly="True"
                                                    CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                                <DataGridTextColumn Header="الكمية *"
                                                    Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N3}"
                                                    Width="110"
                                                    CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                                <DataGridTextColumn Header="تكلفة الوحدة"
                                                    Binding="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                    Width="110"
                                                    CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                                <DataGridTextColumn Header="الإجمالي"
                                                    Binding="{Binding TotalCost, StringFormat=N2}"
                                                    Width="110"
                                                    IsReadOnly="True"
                                                    CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                                <DataGridTemplateColumn Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="🗑️"
                                                    Style="{StaticResource DangerButton}"
                                                    Height="28" Width="28" Padding="0"
                                                    ToolTip="حذف هذا السطر"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Notes -->
                <Border Background="#F1F5F9" Padding="16" Margin="0,8,0,0" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="50"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Padding="8,4"
                                 ToolTip="ملاحظات إضافية حول الحركة"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="✅ ترحيل"
                            Command="{Binding PostCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="100"
                            Margin="0,0,12,0"
                            ToolTip="ترحيل العملية نهائياً — سيتم تحديث المخزون والرصيد"/>

                    <Button Content="💾 حفظ مسودة"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100"
                            Margin="0,0,8,0"
                            ToolTip="حفظ كمسودة دون ترحيل"/>

                    <Button Content="🚫 إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100"
                            ToolTip="إغلاق النافذة دون حفظ"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
