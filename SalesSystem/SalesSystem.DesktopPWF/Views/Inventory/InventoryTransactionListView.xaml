<UserControl x:Class="SalesSystem.DesktopPWF.Views.Inventory.InventoryTransactionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="📦  حركات المخزون"
                   Style="{StaticResource HeaderStyle}"/>

        <!-- Filter Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4">

                <!-- Transaction Type Filter -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="النوع" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding TransactionTypeOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding TransactionTypeFilter}"
                              Style="{StaticResource ModernComboBox}"
                              MinWidth="100"
                              ToolTip="تصفية حسب نوع الحركة"/>
                </StackPanel>

                <!-- From Date -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="من" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker SelectedDate="{Binding FromDate}"
                                Style="{StaticResource ModernDatePicker}"
                                ToolTip="تصفية من تاريخ"/>
                </StackPanel>

                <!-- To Date -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <TextBlock Text="إلى" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker SelectedDate="{Binding ToDate}"
                                Style="{StaticResource ModernDatePicker}"
                                ToolTip="تصفية إلى تاريخ"/>
                </StackPanel>

                <Button Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,4,0"
                        ToolTip="تنفيذ البحث">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Margin="0,0,6,0"/>
                        <TextBlock Text="بحث"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="تحديث الحركات">
                    <TextBlock Text="🔄"/>
                </Button>
            </WrapPanel>
        </Border>

        <!-- Error Banner -->
        <Border Grid.Row="2"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                Background="{StaticResource ErrorLightBrush}"
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorTextBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button Grid.Column="2" Content="✕"
                        Command="{Binding RefreshCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource ErrorTextBrush}" FontWeight="Bold"
                        Padding="6,0" VerticalAlignment="Center"
                        ToolTip="إخفاء رسالة الخطأ"/>
            </Grid>
        </Border>

        <!-- Transactions DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding Transactions}"
                          SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          AutomationProperties.AutomationId="DgInventoryTransactions">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الحركة"
                                            Binding="{Binding TransactionNo}"
                                            Width="80"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="التاريخ"
                                            Binding="{Binding TransactionDate, StringFormat='{}{0:yyyy/MM/dd}'}"
                                            Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="النوع"
                                            Binding="{Binding TransactionTypeDisplay}"
                                            Width="90"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="المستودع"
                                            Binding="{Binding WarehouseName}"
                                            Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="المرجع"
                                            Binding="{Binding ReferenceId}"
                                            Width="70"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="نوع المرجع"
                                            Binding="{Binding ReferenceType}"
                                            Width="70"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="الحالة"
                                            Binding="{Binding StatusDisplay}"
                                            Width="70"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="ملاحظات"
                                            Binding="{Binding Notes}"
                                            Width="*"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.3"/>
                        <TextBlock Text="لا توجد حركات مخزون" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="حاول تغيير معايير التصفية" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Pagination Footer -->
        <Border Grid.Row="4" Margin="0,8,0,0" Padding="8,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding PrevPageCommand}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="80"
                        Margin="0,0,4,0"
                        ToolTip="الصفحة السابقة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Margin="0,0,6,0"/>
                        <TextBlock Text="السابق"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding PageDisplay}"
                           VerticalAlignment="Center"
                           Margin="12,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Command="{Binding NextPageCommand}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="80"
                        ToolTip="الصفحة التالية">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="التالي"/>
                        <TextBlock Text="◀" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Detail Panel (Item Lines) -->
        <Border Grid.Row="5" Style="{StaticResource CardStyle}" Padding="8"
                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="تفاصيل الحركة — الأصناف"
                           FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SelectedLines}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          MaxHeight="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المنتج"
                                            Binding="{Binding ProductName}"
                                            Width="*"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="الوحدة"
                                            Binding="{Binding ProductUnitName}"
                                            Width="70"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="الكمية"
                                            Binding="{Binding Quantity, StringFormat='N3'}"
                                            Width="80"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="التكلفة"
                                            Binding="{Binding UnitCost, StringFormat='N2'}"
                                            Width="80"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="الإجمالي"
                                            Binding="{Binding TotalCost, StringFormat='N2'}"
                                            Width="90"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="6"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل حركات المخزون..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
