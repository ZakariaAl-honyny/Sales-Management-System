<Page x:Class="SalesSystem.DesktopPWF.Views.Inventory.InventoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views.Inventory"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="حركة المخزون"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24,24,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <TextBlock Grid.Row="0"
                   Text="📦 مراقبة المخزون" 
                   Style="{StaticResource HeaderStyle}"
                   FontSize="28" 
                   Margin="0,0,0,24"
                   AutomationProperties.AutomationId="InventoryPageTitle"/>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}">
            <!-- Movements Tab -->
            <TabItem Header="📜 حركات المخزون" AutomationProperties.AutomationId="TabMovements">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Style="{StaticResource ToolbarStyle}">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Search Group -->
                            <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                                <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Width="300"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="بحث في الحركات..."
                                         TabIndex="1"
                                         helpers:FocusHelper.AdvanceOnEnter="True">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding RefreshCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Command="{Binding RefreshCommand}" 
                                        Style="{StaticResource PrimaryButton}" 
                                        Margin="12,0,0,0" Height="36" Padding="16,0"
                                        ToolTip="البحث في سجل حركات المخزون">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="بحث" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Actions Group -->
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Height="36" Padding="16,0"
                                        ToolTip="تحديث قائمة حركات المخزون">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="تحديث" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                        <Grid>
                            <DataGrid ItemsSource="{Binding Movements}" 
                                      AutoGenerateColumns="False" 
                                      Style="{StaticResource ModernDataGrid}"
                                      IsReadOnly="True"
                                      AutomationProperties.AutomationId="GridMovements">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="التاريخ" 
                                                        Binding="{Binding MovementDate, StringFormat=yyyy-MM-dd HH:mm}" 
                                                        Width="150"
                                                        CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                    
                                    <DataGridTextColumn Header="المنتج" 
                                                        Binding="{Binding ProductName}" 
                                                        Width="*"
                                                        CellStyle="{StaticResource DataGridCellStyle}"/>
                                    
                                    <DataGridTextColumn Header="المستودع" 
                                                        Binding="{Binding WarehouseName}" 
                                                        Width="150"
                                                        CellStyle="{StaticResource DataGridCellStyle}"/>
                                    
                                    <DataGridTemplateColumn Header="النوع" Width="130" CellStyle="{StaticResource DataGridCellCenterStyle}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="1">
                                                                    <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="3">
                                                                    <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="6">
                                                                    <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="2">
                                                                    <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="4">
                                                                    <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="5">
                                                                    <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MovementType}" Value="7">
                                                                    <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding MovementType}" Value="1">
                                                                        <Setter Property="Text" Value="شراء (+)"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MovementType}" Value="3">
                                                                        <Setter Property="Text" Value="مرتجع بيع (+)"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MovementType}" Value="6">
                                                                        <Setter Property="Text" Value="تحويل وارد (+)"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MovementType}" Value="2">
                                                                        <Setter Property="Text" Value="بيع (-)"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MovementType}" Value="4">
                                                                        <Setter Property="Text" Value="مرتجع شراء (-)"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MovementType}" Value="5">
                                                                        <Setter Property="Text" Value="تحويل صادر (-)"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MovementType}" Value="7">
                                                                        <Setter Property="Text" Value="تعديل"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="الكمية" 
                                                        Binding="{Binding QuantityChange, StringFormat=N3}" 
                                                        Width="100"
                                                        CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                    
                                    <DataGridTextColumn Header="قبل" 
                                                        Binding="{Binding QuantityBefore, StringFormat=N3}" 
                                                        Width="100"
                                                        CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                    
                                    <DataGridTextColumn Header="بعد" 
                                                        Binding="{Binding QuantityAfter, StringFormat=N3}" 
                                                        Width="100"
                                                        CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                    
                                    <DataGridTextColumn Header="المرجع" 
                                                        Binding="{Binding ReferenceType}" 
                                                        Width="120"
                                                        CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Empty State -->
                            <Grid Visibility="{Binding IsMovementsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📜" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                                    <TextBlock Text="لا توجد حركات مخزنية حالياً" Style="{StaticResource HeaderStyle}" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="سيتم تسجيل كافة حركات الدخول والخروج للمنتجات هنا تلقائياً" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Stock Levels Tab -->
            <TabItem Header="📊 مستويات المخزون" AutomationProperties.AutomationId="TabStockLevels">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ToolbarStyle}">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Height="36" Padding="16,0"
                                        AutomationProperties.AutomationId="BtnRefreshStocks"
                                        ToolTip="تحديث مستويات المخزون الحالية">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="تحديث" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                        <Grid>
                            <DataGrid ItemsSource="{Binding Stocks}" 
                                      AutoGenerateColumns="False" 
                                      Style="{StaticResource ModernDataGrid}"
                                      IsReadOnly="True"
                                      AutomationProperties.AutomationId="GridStocks">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="المنتج" 
                                                        Binding="{Binding ProductName}" 
                                                        Width="*"
                                                        CellStyle="{StaticResource DataGridCellStyle}"/>
                                    
                                    <DataGridTextColumn Header="المستودع" 
                                                        Binding="{Binding WarehouseName}" 
                                                        Width="150"
                                                        CellStyle="{StaticResource DataGridCellStyle}"/>
                                    
                                    <DataGridTemplateColumn Header="الكمية المتوفرة" Width="180" CellStyle="{StaticResource DataGridCellCenterStyle}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Quantity, StringFormat=N3}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <MultiBinding Converter="{StaticResource LowStockConverter}">
                                                                                <Binding Path="Quantity"/>
                                                                                <Binding Path="ReorderLevel"/>
                                                                            </MultiBinding>
                                                                        </DataTrigger.Binding>
                                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                                    <Setter Property="Text" Value="متوفر"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Value="True">
                                                                            <DataTrigger.Binding>
                                                                                <MultiBinding Converter="{StaticResource LowStockConverter}">
                                                                                    <Binding Path="Quantity"/>
                                                                                    <Binding Path="ReorderLevel"/>
                                                                                </MultiBinding>
                                                                            </DataTrigger.Binding>
                                                                            <Setter Property="Text" Value="منخفض"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <DataGridTextColumn Header="حد إعادة الطلب" 
                                                        Binding="{Binding ReorderLevel, StringFormat=N3}" 
                                                        Width="150"
                                                        CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                    
                                    <DataGridTextColumn Header="الوحدة" 
                                                        Binding="{Binding UnitName}" 
                                                        Width="100"
                                                        CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Empty State -->
                            <Grid Visibility="{Binding IsStocksEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📊" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                                    <TextBlock Text="لا توجد أرصدة مخزنية حالياً" Style="{StaticResource HeaderStyle}" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ابدأ بتعريف المنتجات وإضافة مخزون أول المدة أو تسجيل فواتير الشراء" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل بيانات المخزون..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>

