<UserControl x:Class="SalesSystem.DesktopPWF.Views.Inventory.LowStockView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views.Inventory"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1100"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="⚠️  تقرير النواقص والطلب الذكي" 
                           Style="{StaticResource HeaderStyle}"
                           FontSize="28"/>
                <TextBlock Text="عرض المنتجات التي وصلت لحد إعادة الطلب مع مقترحات الكميات المطلوبة" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Command="{Binding ExportCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        Margin="0,0,8,0"
                        ToolTip="تصدير البيانات إلى ملف Excel">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="تصدير إكسل" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding RefreshCommand}" 
                        Style="{StaticResource PrimaryButton}" 
                        ToolTip="تحديث البيانات">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="تحديث" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filter Bar -->
        <Border Grid.Row="0" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="المستودع:" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Warehouses}" 
                              SelectedValue="{Binding SelectedWarehouseId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Width="200"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding Items}" 
                          AutoGenerateColumns="False" 
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم المنتج" Binding="{Binding ProductId}" Width="120" CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="اسم المنتج" Binding="{Binding ProductName}" Width="*" CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="الفئة" Binding="{Binding CategoryName}" Width="130" CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="المستودع" Binding="{Binding WarehouseName}" Width="130" CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTemplateColumn Header="المخزون الحالي" Width="130" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CurrentRetailQty, StringFormat=N2}" Foreground="{StaticResource ErrorBrush}" FontWeight="Bold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
 
                        <DataGridTextColumn Header="حد الطلب" Binding="{Binding ReorderLevelRetailQty, StringFormat=N2}" Width="110" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTemplateColumn Header="الطلب المقترح" Width="200" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource SuccessLightBrush}" Padding="8,4" CornerRadius="4" Margin="0,0,4,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding SuggestedWholesaleBoxes}" FontWeight="Bold" Foreground="{StaticResource SuccessTextBrush}"/>
                                                <TextBlock Text=" "/>
                                                <TextBlock Text="{Binding WholesaleUnitName}" FontSize="10" VerticalAlignment="Bottom" Foreground="{StaticResource SuccessTextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource PrimaryLightBrush}" Padding="8,4" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding SuggestedRetailRemainder}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                                <TextBlock Text=" "/>
                                                <TextBlock Text="{Binding RetailUnitName}" FontSize="10" VerticalAlignment="Bottom" Foreground="{StaticResource PrimaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding Items.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="✅" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                        <TextBlock Text="المخزون مكتمل" Style="{StaticResource HeaderStyle}" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="لا توجد منتجات تحت حد الطلب حالياً" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Loading Overlay -->
                <Border Background="#80FFFFFF" Panel.ZIndex="1000" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="جاري تحليل مستويات المخزون..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
