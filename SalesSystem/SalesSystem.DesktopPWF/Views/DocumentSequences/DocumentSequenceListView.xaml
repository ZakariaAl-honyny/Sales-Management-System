<UserControl x:Class="SalesSystem.DesktopPWF.Views.DocumentSequences.DocumentSequenceListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.DocumentSequences"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:DocumentSequenceListViewModel, IsDesignTimeCreatable=False}"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="24,24,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="تسلسل المستندات" Style="{StaticResource HeaderStyle}"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <!-- Reset -->
                    <Button Command="{Binding ResetCommand}" Style="{StaticResource WarningButton}" Margin="0,0,4,0"
                            ToolTip="إعادة تعيين الرقم التالي للتسلسل المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إعادة تعيين" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Refresh -->
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث القائمة — إعادة تحميل تسلسل المستندات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔃" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding Sequences}"
                          SelectedItem="{Binding SelectedSequence}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          ToolTip="قائمة تسلسل المستندات — اختر تسلسلاً لإعادة تعيين الرقم التالي">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="نوع المستند" Binding="{Binding DocumentType}" Width="*"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="البادئة" Binding="{Binding Prefix}" Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="السنة" Binding="{Binding Year}" Width="80"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="الرقم التالي" Binding="{Binding LastNumber}" Width="120"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                    </DataGrid.Columns>

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="إعادة تعيين الرقم التالي" Command="{Binding ResetCommand}"
                                      ToolTip="إعادة تعيين الرقم التالي للتسلسل المحدد">
                                <MenuItem.Icon>
                                    <TextBlock Text="🔄"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📄" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                        <TextBlock Text="لا توجد تسلسلات مستندات" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="سيتم إنشاء التسلسلات تلقائياً عند إنشاء المستندات"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Reset Input -->
        <Border Grid.Row="3" Style="{StaticResource FooterStyle}" Padding="12,8"
                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="الرقم التالي الجديد:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding ResetValue, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" Style="{StaticResource ModernTextBox}"
                         ToolTip="أدخل الرقم التالي الجديد للتسلسل"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#80FFFFFF" Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل تسلسل المستندات..." FontSize="14" Margin="0,12,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
