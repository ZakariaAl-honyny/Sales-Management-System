<UserControl x:Class="SalesSystem.DesktopPWF.Views.Employee.EmployeeEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Background="{StaticResource BackgroundBrush}"
        FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Padding="16">
                <StackPanel>
                    <!-- PartyId (Name lookup) -->
                    <TextBlock Text="الشخص (Party) *" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                    <TextBox Text="{Binding PartyName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                             Style="{StaticResource ModernTextBox}"
                             Tag="اسم الشخص المرتبط"
                             TabIndex="1"
                             IsReadOnly="True"
                             ToolTip="الشخص المرتبط بالموظف"/>

                    <!-- EmployeeNo -->
                    <TextBlock Text="الرقم الوظيفي" Style="{StaticResource LabelStyle}" Margin="4,12,0,8"/>
                    <TextBox Text="{Binding EmployeeNo, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Width="150"
                             TabIndex="2"
                             ToolTip="الرقم الوظيفي للموظف"/>

                    <!-- HireDate -->
                    <TextBlock Text="تاريخ التوظيف *" Style="{StaticResource LabelStyle}" Margin="4,12,0,8"/>
                    <DatePicker SelectedDate="{Binding HireDate}"
                                Style="{StaticResource ModernDatePicker}"
                                TabIndex="3"
                                ToolTip="تاريخ التحاق الموظف بالعمل"/>

                    <!-- DepartmentId -->
                    <TextBlock Text="القسم" Style="{StaticResource LabelStyle}" Margin="4,12,0,8"/>
                    <TextBox Text="{Binding DepartmentId, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Width="150"
                             TabIndex="4"
                             ToolTip="معرف القسم (اختياري)"/>

                    <!-- Salary -->
                    <TextBlock Text="الراتب" Style="{StaticResource LabelStyle}" Margin="4,12,0,8"/>
                    <TextBox Text="{Binding Salary, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Width="200"
                             TabIndex="5"
                             ToolTip="راتب الموظف"/>

                    <!-- Notes -->
                    <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}" Margin="4,12,0,8"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Height="60"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             TabIndex="6"
                             ToolTip="أي ملاحظات إضافية عن الموظف"/>

                    <!-- IsActive -->
                    <CheckBox Content="نشط" 
                              IsChecked="{Binding IsActive}"
                              Margin="4,16,0,0"
                              TabIndex="7"
                              ToolTip="تفعيل أو إيقاف الموظف"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F8FAFC" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="120"
                        IsDefault="True"
                        TabIndex="8"
                        Margin="0,0,12,0"
                        ToolTip="حفظ بيانات الموظف">
                    <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                </Button>
                <Button Content="إلغاء"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        TabIndex="9"
                        ToolTip="إلغاء والعودة"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CCFFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="180" Height="4" Background="#E2E8F0" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" FontWeight="SemiBold" Margin="0,16,0,0" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
