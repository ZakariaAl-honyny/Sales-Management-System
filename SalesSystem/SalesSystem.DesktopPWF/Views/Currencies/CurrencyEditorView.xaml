<UserControl x:Class="SalesSystem.DesktopPWF.Views.Currencies.CurrencyEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Background="{StaticResource BackgroundBrush}"
        FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1E293B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💰" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource HeaderStyle}" Foreground="White"/>
                    </StackPanel>
                    <TextBlock Text="إدارة العملات وأسعار الصرف في النظام" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Form Content -->
        <ScrollViewer Grid.Row="1">
            <Border Padding="16">
                <StackPanel>
                    <!-- Name -->
                    <TextBlock Text="اسم العملة *" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                             Style="{StaticResource ModernTextBox}"
                             Tag="أدخل اسم العملة (مثلاً: دولار أمريكي)"
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True"
                             ToolTip="أدخل اسم العملة — هذا الحقل إلزامي"/>

                    <!-- Code (ISO) -->
                    <TextBlock Text="رمز العملة (ISO) *" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"/>
                    <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                             Style="{StaticResource ModernTextBox}"
                             Width="150"
                             TabIndex="2"
                             ToolTip="أدخل رمز ISO ثلاثي الأحرف — مثال: USD للدولار الأمريكي، SAR للريال السعودي"/>
                    <TextBlock Text="رمز ISO ثلاثي الأحرف — مثال: USD, SAR, EUR"
                               Style="{StaticResource HelperTextStyle}"/>

                    <!-- Symbol -->
                    <TextBlock Text="الرمز *" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"/>
                    <TextBox Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                             Style="{StaticResource ModernTextBox}"
                             Width="120"
                             TabIndex="3"
                             ToolTip="أدخل رمز العملة — مثال: $, ﷼, €"/>
                    <TextBlock Text="الرمز الذي يمثل العملة — مثال: $, ﷼, €"
                               Style="{StaticResource HelperTextStyle}"/>

                    <!-- Base Currency Indicator (Read-Only) -->
                    <Border Margin="0,12,0,0"
                            Padding="12,8"
                            Background="#E8F5E9"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#C8E6C9"
                            Visibility="{Binding IsBaseCurrency, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⭐" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="عملة أساسية — هذه العملة هي العملة الأساسية للنظام ولا يمكن تغييرها"
                                       FontSize="12"
                                       Foreground="#2E7D32"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Fraction Name -->
                    <TextBlock Text="اسم الجزء" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"/>
                    <TextBox Text="{Binding FractionName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Width="200"
                             TabIndex="6"
                             ToolTip="أدخل اسم الجزء من العملة — اختياري (مثال: فلس, سنت, قرش)"/>
                    <TextBlock Text="اسم الجزء الصغير من العملة — اختياري (مثال: فلس, سنت)"
                               Style="{StaticResource HelperTextStyle}"/>

                    <!-- Decimal Places -->
                    <TextBlock Text="عدد المنازل العشرية *" Style="{StaticResource LabelStyle}" Margin="4,8,0,8"/>
                    <TextBox Text="{Binding DecimalPlaces, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                             Style="{StaticResource ModernTextBox}"
                             Width="120"
                             TabIndex="5"
                             ToolTip="أدخل عدد المنازل العشرية للعملة — مثال: 2 للدولار (0.01), 3 للدينار (0.001)"/>
                    <TextBlock Text="عدد المنازل العشرية — مثال: 2 للدولار, 3 للدينار الكويتي"
                               Style="{StaticResource HelperTextStyle}"/>

                    <Border Margin="0,16,0,0" Padding="16" Background="#F8FAFC" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="العملة الأساسية هي العملة الرئيسية المستخدمة في النظام. يتم تحويل جميع العملات الأخرى بناءً على سعر صرفها مقابل العملة الأساسية."
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="400"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F8FAFC" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="150"
                            IsDefault="True"
                            TabIndex="7"
                            Margin="0,0,12,0"
                            ToolTip="حفظ بيانات العملة">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSave}" Fill="White" Width="16" Height="16" Margin="0,0,10,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="حفظ البيانات" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100"
                            TabIndex="8"
                            ToolTip="إلغاء والعودة"/>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CCFFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                CornerRadius="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="180" Height="4" Background="#E2E8F0" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" FontWeight="SemiBold" Margin="0,16,0,0" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
