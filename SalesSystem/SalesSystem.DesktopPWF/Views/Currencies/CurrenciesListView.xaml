<UserControl x:Class="SalesSystem.DesktopPWF.Views.Currencies.CurrenciesListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16,16,16,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="💰  العملات"
                   Style="{StaticResource HeaderStyle}"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="250"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="ابحث عن اسم العملة أو رمزها..."
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                            ToolTip="البحث عن عملة بالاسم أو الرمز">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <CheckBox Content="عرض العملات غير النشطة" 
                              IsChecked="{Binding IncludeInactive}" 
                              VerticalAlignment="Center" 
                              FontSize="12"
                              ToolTip="إظهار العملات التي تم تعطيلها سابقاً"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="إضافة عملة جديدة — إضافة عملة جديدة للنظام مع تحديد سعر الصرف">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إضافة عملة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل العملة المختارة — تغيير الاسم أو الرمز أو سعر الصرف">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            Visibility="{Binding SelectedCurrency.IsActive, Converter={StaticResource BoolToVisibility}, FallbackValue=Visible}"
                            ToolTip="إيقاف نشاط العملة المختارة — لن تكون متاحة للاستخدام في الفواتير">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حذف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RestoreCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            Visibility="{Binding SelectedCurrency.IsActive, Converter={StaticResource InverseBoolToVisibility}, FallbackValue=Collapsed}"
                            ToolTip="إعادة تنشيط العملة المختارة — إتاحتها للاستخدام مرة أخرى">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♻️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="استعادة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة العملات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding CurrenciesView}"
                          SelectedItem="{Binding SelectedCurrency}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" Command="{Binding EditCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="✏️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="حذف" Command="{Binding DeleteCommand}"
                                      Visibility="{Binding SelectedCurrency.IsActive, Converter={StaticResource BoolToVisibility}}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🗑️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="استعادة" Command="{Binding RestoreCommand}"
                                      Visibility="{Binding SelectedCurrency.IsActive, Converter={StaticResource InverseBoolToVisibility}}">
                                <MenuItem.Icon>
                                    <TextBlock Text="♻️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المعرف" 
                                            Binding="{Binding Id}" 
                                            Width="80" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="اسم العملة" 
                                            Binding="{Binding Name}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="الرمز (ISO)" 
                                            Binding="{Binding Code}" 
                                            Width="100" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="الرمز" 
                                            Binding="{Binding Symbol}" 
                                            Width="80" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="سعر الصرف" 
                                            Binding="{Binding ExchangeRateToBase, StringFormat='{}{0:N2}'}" 
                                            Width="120" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTemplateColumn Header="أساسية" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="نعم"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBaseCurrency}" Value="False">
                                                        <Setter Property="Text" Value="لا"/>
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Header="الحالة" Width="120" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Setter Property="Text" Value="نشط"/>
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text" Value="متوقف"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="💰" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                        <TextBlock Text="لا توجد عملات مسجلة" Style="{StaticResource HeaderStyle}" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="ابدأ بإضافة عملة جديدة من خلال الزر أعلاه" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إضافة أول عملة" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="140"
                                ToolTip="فتح شاشة إضافة عملة جديدة مع تحديد سعر الصرف"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل العملات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
