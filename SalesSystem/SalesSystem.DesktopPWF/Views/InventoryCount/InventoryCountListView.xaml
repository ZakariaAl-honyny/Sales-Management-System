<UserControl x:Class="SalesSystem.DesktopPWF.Views.InventoryCount.InventoryCountListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.InventoryCount"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:InventoryCountListViewModel}"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📋  الجرد" Style="{StaticResource HeaderStyle}"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="200" Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="رقم الجرد أو المستودع...">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButton}" Margin="4,0,0,0"
                            ToolTip="البحث في الجرد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="إنشاء جرد جديد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="جرد جديد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل الجرد المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding PostCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                            ToolTip="ترحيل الجرد — سيتم تحديث المخزون بناءً على الفروقات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ترحيل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            ToolTip="إلغاء الجرد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚫" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة الجرد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message -->
        <Border Grid.Row="2" Background="{StaticResource ErrorLightBrush}" BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1" Padding="12,8" Margin="{StaticResource StandardSectionMargin}"
                CornerRadius="6" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" FontWeight="SemiBold"
                           VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding CountsView}" SelectedItem="{Binding SelectedCount}"
                          Style="{StaticResource ModernDataGrid}" IsReadOnly="True" BorderThickness="0"
                          MouseDoubleClick="CountsDataGrid_MouseDoubleClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="تعديل" ToolTip="تعديل الجرد المحدد" Command="{Binding EditCommand}">
                                <MenuItem.Icon><TextBlock Text="✏️"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="ترحيل" ToolTip="ترحيل الجرد — سيتم تحديث المخزون" Command="{Binding PostCommand}">
                                <MenuItem.Icon><TextBlock Text="🚀"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="إلغاء" ToolTip="إلغاء الجرد المحدد" Command="{Binding CancelCommand}">
                                <MenuItem.Icon><TextBlock Text="🚫"/></MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الجرد" Binding="{Binding CountNo}" Width="80" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="المستودع" Binding="{Binding WarehouseName}" Width="*" CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding CountDate, StringFormat=yyyy/MM/dd}" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="150" CellStyle="{StaticResource DataGridCellStyle}"/>
                        <DataGridTemplateColumn Header="الحالة" Width="100" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3">
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource InfoTextBrush}"/>
                                                    <Setter Property="Text" Value="مسودة"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                            <Setter Property="Text" Value="مرحل"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                            <Setter Property="Text" Value="ملغي"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد جرد" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="انقر على 'جرد جديد' للبدء" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ جرد جديد" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="140"
                                ToolTip="إنشاء جرد جديد"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource FooterBarStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="إجمالي الجرد: " Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding CountsCount}" Style="{StaticResource FooterBarTextStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="5" Background="#80FFFFFF" Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل البيانات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
