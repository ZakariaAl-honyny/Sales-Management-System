<UserControl x:Class="SalesSystem.DesktopPWF.Views.CustomerReceipt.CustomerReceiptEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💰" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Form + Allocation Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- Receipt Details Card -->
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="رقم العميل *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CustomerId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource ModernTextBox}" Tag="أدخل رقم العميل"
                                         ToolTip="أدخل رقم العميل — هذا الحقل إلزامي"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="رقم الصندوق *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CashBoxId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource ModernTextBox}" Tag="أدخل رقم الصندوق"
                                         ToolTip="أدخل رقم الصندوق — هذا الحقل إلزامي"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="العملة *" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Currencies}"
                                          SelectedValue="{Binding CurrencyId, ValidatesOnDataErrors=True}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          ToolTip="اختر العملة — إذا كانت غير العملة الأساسية سيظهر حقل سعر الصرف"/>
                                <!-- Exchange Rate (Visible only for foreign currencies) -->
                                <Border Height="4"/>
                                <TextBox Text="{Binding ExchangeRate, UpdateSourceTrigger=PropertyChanged}"
                                         helpers:InputHelper.NumericOnly="True"
                                         Style="{StaticResource ModernTextBox}"
                                         Visibility="{Binding IsForeignCurrency, Converter={StaticResource BoolToVisibility}}"
                                         ToolTip="سعر صرف العملة المختارة مقابل العملة الأساسية — يمكن تعديله"/>
                                <TextBlock Text="{Binding CurrentExchangeRateInfo, StringFormat='السعر الحالي: {0}'}"
                                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"
                                           Visibility="{Binding IsForeignCurrency, Converter={StaticResource BoolToVisibility}}"
                                           ToolTip="سعر الصرف الحالي من قاعدة البيانات — للمعلومات فقط"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="المبلغ *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource ModernTextBox}" Tag="0.00"
                                         helpers:InputHelper.NumericOnly="True"
                                         ToolTip="المبلغ المقبوض — يجب أن يكون أكبر من صفر"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="8"/>

                        <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"
                                 Tag="ملاحظات إضافية" TextWrapping="Wrap" AcceptsReturn="True" Height="48"
                                 ToolTip="ملاحظات إضافية حول سند القبض"/>
                    </StackPanel>
                </Border>

                <!-- Allocation Grid Card -->
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="توزيع المبلغ على الفواتير" FontSize="14" FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <Button Grid.Column="1" Content="🔄 تحميل الفواتير غير المسددة"
                                    Command="{Binding LoadUnpaidInvoicesCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="8,4" FontSize="12"
                                    ToolTip="تحميل فواتير البيع غير المسددة لهذا العميل"/>
                        </Grid>

                        <DataGrid ItemsSource="{Binding UnpaidInvoices}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  Style="{StaticResource ModernDataGrid}"
                                  MaxHeight="300"
                                  Visibility="{Binding UnpaidInvoices.Count, Converter={StaticResource CountToVisibility}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNo}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding InvoiceDate}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="المخصص" Width="120">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="AllocatedAmount" StringFormat="N2" UpdateSourceTrigger="PropertyChanged"/>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="الباقي بعد التخصيص" Binding="{Binding RemainingAfterAllocation, StringFormat=N2}" Width="130" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="لا توجد فواتير غير مسددة لهذا العميل"
                                   Style="{StaticResource HelperTextStyle}"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding UnpaidInvoices.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}"/>

                        <!-- Summary -->
                        <Border Background="{StaticResource SurfaceBrush}" Padding="12,8" CornerRadius="8" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="المبلغ المتبقي للتوزيع:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding RemainingToAllocate, StringFormat=N2}"
                                           FontWeight="Bold" FontSize="16"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" MinWidth="100" Margin="0,0,8,0" IsDefault="True"
                            ToolTip="حفظ سند القبض — سيتم التحقق من صحة الحقول قبل الحفظ">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="حفظ"/>
                        </StackPanel>
                    </Button>
                    <Button Content="إلغاء" Command="{Binding CancelDialogCommand}" Style="{StaticResource SecondaryButton}" MinWidth="80"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                           FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap"
                           Margin="0,8,0,0" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#80FFFFFF" Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري الحفظ..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
