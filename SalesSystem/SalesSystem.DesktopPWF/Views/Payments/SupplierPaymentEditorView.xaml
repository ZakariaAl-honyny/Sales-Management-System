<Window x:Class="SalesSystem.DesktopPWF.Views.Payments.SupplierPaymentEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="600" Width="520"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💵" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding WindowTitle}" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>
                        <!-- Supplier -->
                        <TextBlock Text="المورد *" Style="{StaticResource LabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Suppliers}"
                                      SelectedValue="{Binding SelectedSupplierId, ValidatesOnDataErrors=True}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"
                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                      TabIndex="1"
                                      helpers:FocusHelper.AdvanceOnEnter="True"
                                      AutomationProperties.AutomationId="CbPaymentSupplier"
                                      ToolTip="اختر المورد المستحق له الدفع"/>
                            <Button Grid.Column="1" Content="🔍" 
                                    Command="{Binding SearchSupplierCommand}"
                                    Style="{StaticResource SecondaryButton}" 
                                    Padding="4,0" Height="28" Width="30"
                                    Margin="4,0,0,0"
                                    IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                    ToolTip="البحث عن مورد واستعراض القائمة"/>
                        </Grid>
                        <Border Height="8"/>

                        <!-- Date -->
                        <TextBlock Text="تاريخ السداد" Style="{StaticResource LabelStyle}"/>
                        <DatePicker SelectedDate="{Binding PaymentDate}"
                                    Style="{StaticResource ModernDatePicker}"
                                    IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                    TabIndex="2"
                                    helpers:FocusHelper.AdvanceOnEnter="True"
                                    AutomationProperties.AutomationId="DpPaymentDate"
                                    ToolTip="تاريخ تسجيل سند الدفع"/>
                        <Border Height="8"/>

                        <!-- Amount -->
                        <TextBlock Text="المبلغ *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="أدخل المبلغ المدفوع"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 FontWeight="Bold"
                                 FontSize="16"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 TabIndex="3"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtPaymentAmount"
                                 ToolTip="أدخل المبلغ الذي سيدفع للمورد — يجب أن يكون أكبر من صفر"/>
                        <TextBlock Text="المبلغ الذي سيخصم من مستحقات المورد" Style="{StaticResource HelperTextStyle}"/>
                        <Border Height="8"/>

                        <!-- Payment Method -->
                        <TextBlock Text="طريقة الدفع" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding PaymentMethodOptions}"
                                  SelectedValue="{Binding PaymentMethod, ValidatesOnDataErrors=True}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Style="{StaticResource ModernComboBox}"
                                  IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                  TabIndex="4"
                                  helpers:FocusHelper.AdvanceOnEnter="True"
                                  AutomationProperties.AutomationId="CbPaymentMethod"
                                  ToolTip="اختر طريقة الدفع — شيك يتطلب إدخال بيانات إضافية"/>

                        <!-- Cheque Fields (visible only when PaymentMethod == Cheque) -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0" Padding="12"
                                Visibility="{Binding ShowChequeFields, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="بيانات الشيك" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="رقم الشيك *" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding ChequeNumber, ValidatesOnDataErrors=True}"
                                                 Style="{StaticResource ModernTextBox}"
                                                 IsReadOnly="{Binding IsReadOnly}"
                                                 TabIndex="5"
                                                 ToolTip="رقم الشيك كما هو مدون على الشيك — هذا الحقل إلزامي للدفع بشيك"
                                                 AutomationProperties.AutomationId="TxtChequeNumber"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                        <TextBlock Text="اسم البنك *" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding ChequeBankName, ValidatesOnDataErrors=True}"
                                                 Style="{StaticResource ModernTextBox}"
                                                 IsReadOnly="{Binding IsReadOnly}"
                                                 TabIndex="6"
                                                 ToolTip="اسم البنك المصدر للشيك — هذا الحقل إلزامي"
                                                 AutomationProperties.AutomationId="TxtChequeBankName"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="تاريخ الإصدار" Style="{StaticResource LabelStyle}"/>
                                        <DatePicker SelectedDate="{Binding ChequeIssueDate, ValidatesOnDataErrors=True}"
                                                    Style="{StaticResource ModernDatePicker}"
                                                    IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                                    TabIndex="7"
                                                    ToolTip="تاريخ إصدار الشيك"
                                                    AutomationProperties.AutomationId="DpChequeIssueDate"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                        <TextBlock Text="تاريخ الاستحقاق *" Style="{StaticResource LabelStyle}"/>
                                        <DatePicker SelectedDate="{Binding ChequeMaturityDate, ValidatesOnDataErrors=True}"
                                                    Style="{StaticResource ModernDatePicker}"
                                                    IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                                    TabIndex="8"
                                                    ToolTip="تاريخ استحقاق صرف الشيك — يجب أن يكون بعد تاريخ الإصدار"
                                                    AutomationProperties.AutomationId="DpChequeMaturityDate"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Height="8"/>

                        <!-- Notes -->
                        <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 TabIndex="9"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtPaymentNotes"
                                 ToolTip="ملاحظات إضافية حول سند الدفع (اختياري)"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="💾 حفظ السند"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                            IsDefault="True"
                            TabIndex="10"
                            AutomationProperties.AutomationId="BtnSavePayment"
                            ToolTip="حفظ سند الدفع — سيتم التحقق من صحة البيانات قبل الحفظ"/>
                    <Button Content="🖨️ طباعة السند"
                            Command="{Binding PrintCommand}"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}"
                            AutomationProperties.AutomationId="BtnPrintPayment"
                            ToolTip="طباعة سند الدفع"/>
                    <Button Content="🚫 إغلاق"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="80"
                            TabIndex="11"
                            AutomationProperties.AutomationId="BtnCancelPayment"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="Bold" 
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
