<Window x:Class="SalesSystem.DesktopPWF.Views.Payments.SupplierPaymentEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="700" Width="580"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💵" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding WindowTitle}" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form + Allocation Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <!-- Supplier -->
                        <TextBlock Text="المورد *" Style="{StaticResource LabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Suppliers}"
                                      SelectedValue="{Binding SelectedSupplierId, ValidatesOnDataErrors=True}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"
                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                      helpers:FocusHelper.AdvanceOnEnter="True"
                                      AutomationProperties.AutomationId="CbPaymentSupplier"
                                      ToolTip="اختر المورد المستحق له الدفع"/>
                            <Button Grid.Column="1" Content="🔍" 
                                    Command="{Binding SearchSupplierCommand}"
                                    Style="{StaticResource SecondaryButton}" 
                                    Padding="4,0" Height="28" Width="30"
                                    Margin="4,0,0,0"
                                    IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                    ToolTip="البحث عن مورد واستعراض القائمة"/>
                        </Grid>
                        <Border Height="8"/>

                        <!-- Date + Method -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="تاريخ السداد" Style="{StaticResource LabelStyle}"/>
                                <DatePicker SelectedDate="{Binding PaymentDate}"
                                            Style="{StaticResource ModernDatePicker}"
                                            IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                            helpers:FocusHelper.AdvanceOnEnter="True"
                                            AutomationProperties.AutomationId="DpPaymentDate"
                                            ToolTip="تاريخ تسجيل سند الدفع"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="طريقة الدفع" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding PaymentMethodOptions}"
                                          SelectedValue="{Binding PaymentMethod, ValidatesOnDataErrors=True}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Display"
                                          Style="{StaticResource ModernComboBox}"
                                          IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                          AutomationProperties.AutomationId="CbPaymentMethod"
                                          ToolTip="اختر طريقة الدفع"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="8"/>

                        <!-- Amount -->
                        <TextBlock Text="المبلغ *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="أدخل المبلغ المدفوع"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 FontWeight="Bold"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 helpers:InputHelper.NumericOnly="True"
                                 AutomationProperties.AutomationId="TxtPaymentAmount"
                                 ToolTip="أدخل المبلغ الذي سيدفع للمورد — يجب أن يكون أكبر من صفر"/>
                        <Border Height="8"/>

                        <!-- Notes -->
                        <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="48"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 AutomationProperties.AutomationId="TxtPaymentNotes"
                                 ToolTip="ملاحظات إضافية حول سند الدفع (اختياري)"/>

                        <!-- Currency -->
                        <TextBlock Text="العملة *" Style="{StaticResource LabelStyle}" Margin="0,8,0,0"/>
                        <ComboBox ItemsSource="{Binding Currencies}"
                                  SelectedValue="{Binding SelectedCurrencyId, ValidatesOnDataErrors=True}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"
                                  ToolTip="اختر عملة الدفع — إذا كانت غير العملة الأساسية سيظهر حقل سعر الصرف"/>

                        <!-- Exchange Rate (Visible only for foreign currencies) -->
                        <TextBox Text="{Binding ExchangeRate, UpdateSourceTrigger=PropertyChanged}"
                                 helpers:InputHelper.NumericOnly="True"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,4,0,0"
                                 Visibility="{Binding IsForeignCurrency, Converter={StaticResource BoolToVisibility}}"
                                 ToolTip="سعر صرف العملة المختارة مقابل العملة الأساسية — يمكن تعديله"/>
                        <TextBlock Text="{Binding CurrentExchangeRateInfo, StringFormat='السعر الحالي: {0}'}"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"
                                   Visibility="{Binding IsForeignCurrency, Converter={StaticResource BoolToVisibility}}"
                                   ToolTip="سعر الصرف الحالي من قاعدة البيانات — للمعلومات فقط"/>
                    </StackPanel>
                </Border>

                <!-- Allocation Grid Card -->
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="توزيع المبلغ على فواتير المشتريات" FontSize="14" FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <Button Grid.Column="1" Content="🔄 تحميل الفواتير غير المسددة"
                                    Command="{Binding LoadUnpaidInvoicesCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="8,4" FontSize="12"
                                    AutomationProperties.AutomationId="BtnLoadUnpaid"
                                    ToolTip="تحميل فواتير المشتريات غير المسددة لهذا المورد"/>
                        </Grid>

                        <DataGrid ItemsSource="{Binding UnpaidInvoices}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  Style="{StaticResource ModernDataGrid}"
                                  MaxHeight="280"
                                  Visibility="{Binding UnpaidInvoices.Count, Converter={StaticResource CountToVisibility}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNo}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding InvoiceDate}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="المخصص" Width="120">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="AllocatedAmount" StringFormat="N2" UpdateSourceTrigger="PropertyChanged"/>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="الباقي بعد التخصيص" Binding="{Binding RemainingAfterAllocation, StringFormat=N2}" Width="130" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="لا توجد فواتير غير مسددة لهذا المورد"
                                   Style="{StaticResource HelperTextStyle}"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding UnpaidInvoices.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}"/>

                        <!-- Summary -->
                        <Border Background="{StaticResource SurfaceBrush}" Padding="12,8" CornerRadius="8" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="المبلغ المتبقي للتوزيع:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding RemainingToAllocate, StringFormat=N2}"
                                           FontWeight="Bold" FontSize="16"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="💾 حفظ السند"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                            IsDefault="True"
                            AutomationProperties.AutomationId="BtnSavePayment"
                            ToolTip="حفظ سند الدفع — سيتم التحقق من صحة البيانات قبل الحفظ"/>
                    <Button Content="🖨️ طباعة السند"
                            Command="{Binding PrintCommand}"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}"
                            AutomationProperties.AutomationId="BtnPrintPayment"
                            ToolTip="طباعة سند الدفع"/>
                    <Button Content="🚫 إغلاق"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="80"
                            AutomationProperties.AutomationId="BtnCancelPayment"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="Bold" 
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
