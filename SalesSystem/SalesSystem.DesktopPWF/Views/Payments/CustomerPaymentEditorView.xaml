<Window x:Class="SalesSystem.DesktopPWF.Views.Payments.CustomerPaymentEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="550" Width="500"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💰" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding WindowTitle}" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <!-- Customer -->
                        <TextBlock Text="العميل *" Style="{StaticResource LabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Customers}"
                                      SelectedValue="{Binding SelectedCustomerId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}"
                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                      TabIndex="1"
                                      helpers:FocusHelper.AdvanceOnEnter="True"
                                      AutomationProperties.AutomationId="CbPaymentCustomer"/>
                            <Button Grid.Column="1" Content="🔍" 
                                    Command="{Binding SearchCustomerCommand}"
                                    Style="{StaticResource SecondaryButton}" 
                                    Padding="4,0" Height="28" Width="30"
                                    Margin="4,0,0,0"
                                    IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"/>
                        </Grid>
                        <Border Height="20"/>

                        <!-- Date -->
                        <TextBlock Text="تاريخ السداد" Style="{StaticResource LabelStyle}"/>
                        <DatePicker SelectedDate="{Binding PaymentDate}"
                                    Style="{StaticResource ModernDatePicker}"
                                    IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                    TabIndex="2"
                                    helpers:FocusHelper.AdvanceOnEnter="True"
                                    AutomationProperties.AutomationId="DpPaymentDate"/>
                        <Border Height="20"/>

                        <!-- Amount -->
                        <TextBlock Text="المبلغ *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="أدخل المبلغ المستلم"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 FontWeight="Bold"
                                 FontSize="16"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 TabIndex="3"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtPaymentAmount"/>
                        <TextBlock Text="المبلغ الذي سخصم من مديونية العميل" Style="{StaticResource HelperTextStyle}"/>
                        <Border Height="20"/>

                        <!-- Payment Type -->
                        <TextBlock Text="طريقة الدفع" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding PaymentTypeOptions}"
                                  SelectedValue="{Binding PaymentType}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Style="{StaticResource ModernComboBox}"
                                  IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                  TabIndex="4"
                                  helpers:FocusHelper.AdvanceOnEnter="True"
                                  AutomationProperties.AutomationId="CbPaymentType"/>
                        <Border Height="20"/>

                        <!-- Notes -->
                        <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 TabIndex="5"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="TxtPaymentNotes"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="24,16" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="💾 حفظ السند"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="140"
                            Margin="0,0,12,0"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                            IsDefault="True"
                            TabIndex="6"
                            AutomationProperties.AutomationId="BtnSavePayment"/>
                    <Button Content="🖨️ طباعة السند"
                            Command="{Binding PrintCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="140"
                            Margin="0,0,12,0"
                            Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}"
                            AutomationProperties.AutomationId="BtnPrintPayment"/>
                    <Button Content="🚫 إغلاق"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="100"
                            TabIndex="7"
                            AutomationProperties.AutomationId="BtnCancelPayment"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="Bold" 
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

