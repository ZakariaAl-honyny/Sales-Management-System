<UserControl x:Class="SalesSystem.DesktopPWF.Views.Transfers.WarehouseTransfersListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
     
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="Auto"/> <!-- Error Notification -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="🔄  التحويلات المخزنية"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="WarehouseTransfersPageTitle"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="200"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="رقم التحويل..."
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True"
                             AutomationProperties.AutomationId="TxtSearchTransfer">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding RefreshCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Margin="4,0,0,0" AutomationProperties.AutomationId="BtnSearchTransfer"
                            ToolTip="البحث في البيانات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <CheckBox Content="عرض الملغاة" 
                               IsChecked="{Binding IncludeInactive}" 
                               VerticalAlignment="Center" 
                               FontSize="12"
                               ToolTip="عرض التحويلات الملغاة"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnAddTransfer"
                            ToolTip="فتح شاشة إنشاء تحويل مخزون جديد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تحويل جديد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل العنصر المحدد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PostCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                            ToolTip="ترحيل العملية وتحديث المخزون">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ترحيل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            AutomationProperties.AutomationId="BtnRefreshTransfers"
                            ToolTip="تحديث قائمة البيانات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource SecondaryButton}"
                            AutomationProperties.AutomationId="BtnPrintTransfer"
                            ToolTip="طباعة المستند">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖨️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="طباعة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Notification Banner -->
        <Border Grid.Row="2" 
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1" 
                CornerRadius="6" 
                Padding="12,8" 
                Margin="{StaticResource StandardSectionMargin}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorTextBrush}" VerticalAlignment="Center" FontSize="12"/>
                <Button Grid.Column="2" Content="✕" 
                        Command="{Binding RefreshCommand}" 
                        Background="Transparent" BorderThickness="0" 
                        Foreground="{StaticResource ErrorTextBrush}"
                        VerticalAlignment="Center"
                        ToolTip="إخفاء رسالة الخطأ"/>
            </Grid>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding TransfersView}"
                          SelectedItem="{Binding SelectedTransfer}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          AutomationProperties.AutomationId="DgTransfers">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="عرض التحويل" ToolTip="عرض تفاصيل التحويل" Command="{Binding ViewCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="👁️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="تعديل التحويل" ToolTip="تعديل التحويل المحدد" Command="{Binding EditCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="📝"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="ترحيل التحويل" ToolTip="ترحيل التحويل — سيتم نقل المخزون" Command="{Binding PostCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="✅"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="إلغاء التحويل" ToolTip="إلغاء التحويل المحدد" Command="{Binding CancelCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="❌"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="طباعة" ToolTip="طباعة إذن التحويل" Command="{Binding PrintCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🖨️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم التحويل" 
                                            Binding="{Binding TransferNo}" 
                                            Width="140" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="التاريخ" 
                                            Binding="{Binding TransferDate, StringFormat=yyyy-MM-dd}" 
                                            Width="110" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="من مستودع" 
                                            Binding="{Binding SourceWarehouseName}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="إلى مستودع" 
                                            Binding="{Binding DestinationWarehouseName}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTemplateColumn Header="الحالة" Width="110" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="1"> <!-- Draft -->
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="2"> <!-- Posted -->
                                                        <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3"> <!-- Cancelled -->
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Text" Value="مسودة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Text" Value="مرحل"/>
                                                            <Setter Property="Foreground" Value="{StaticResource InfoTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Text" Value="ملغي"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                     </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🚛" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.2"/>
                        <TextBlock Text="لا توجد تحويلات مخزنية حالياً" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="يمكنك نقل الكميات بين المستودعات المختلفة وتسجيل الحركات هنا" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إضافة تحويل جديد" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="140"
                                ToolTip="فتح شاشة إنشاء تحويل مخزون جديد"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource FooterBarStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="إجمالي العمليات: " Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding TransfersView.Count, FallbackValue=0}" Style="{StaticResource FooterBarTextStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل البيانات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
