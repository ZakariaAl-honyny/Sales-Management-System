<Window x:Class="SalesSystem.DesktopPWF.Views.Transfers.StockTransferEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="تحويل مخزني"
        Height="700" Width="1000"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="F3" Command="{Binding SearchProductCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔄" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="تحرير تحويل مخزني" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>
                <!-- Metadata Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="المخزن المصدر" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Warehouses}"
                                  SelectedValue="{Binding FromWarehouseId}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"
                                  IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"/>

                        <TextBlock Grid.Column="3" Text="المخزن الهدف" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox Grid.Column="4" ItemsSource="{Binding Warehouses}"
                                  SelectedValue="{Binding ToWarehouseId}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"
                                  IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"/>
                    </Grid>
                </Border>

                <!-- Items Card -->
                <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True" MinHeight="350">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Add Item Header -->
                        <Border Grid.Row="0" Background="#F8FAFC" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <TextBlock Text="أصناف التحويل" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Width="250" Margin="0,0,8,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBox Grid.Column="1" 
                                                     Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="ابحث بالباركود أو الاسم..."
                                                     Style="{StaticResource ModernTextBox}"
                                                     BorderThickness="0"
                                                     VerticalContentAlignment="Center"
                                                     helpers:InputHelper.EnterKeyCommand="{Binding QuickAddProductCommand}"/>
                                        </Grid>
                                    </Border>

                                    <Button Style="{StaticResource SuccessButton}" 
                                            Padding="10,4"
                                            Command="{Binding SearchProductCommand}"
                                            Visibility="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibility}}"
                                            ToolTip="إضافة سطر جديد للفاتورة">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="إضافة صنف" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Items List -->
                        <DataGrid Grid.Row="1" 
                                  ItemsSource="{Binding Items}"
                                  Style="{StaticResource ModernDataGrid}"
                                  MinHeight="250"
                                  MaxHeight="500"
                                  BorderThickness="0"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="الصنف *" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" ItemsSource="{Binding Products}"
                                                          SelectedValue="{Binding ProductId, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Id"
                                                          DisplayMemberPath="Name"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          TextSearch.TextPath="Barcode"
                                                          Style="{StaticResource ModernComboBox}"
                                                          Height="28" Padding="8,0"
                                                          BorderThickness="0"
                                                          IsEnabled="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}}"/>
                                                <Button Grid.Column="1" 
                                                        Content="🔍" 
                                                        Command="{Binding DataContext.SearchProductSingleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Width="30" Height="26" Margin="4,0"
                                                        Padding="0" BorderThickness="0"
                                                        ToolTip="بحث متقدم"
                                                        Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibility}}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="النظام" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Mode, Converter={StaticResource SaleModeToBrushConverter}}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Mode, Converter={StaticResource SaleModeToStringConverter}}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedValue="{Binding Mode, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Value"
                                                      DisplayMemberPath="Text"
                                                      Style="{StaticResource ModernComboBox}"
                                                      Height="28">
                                                <ComboBox.Items>
                                                    <helpers:EnumValue Text="تجزئة" Value="{Binding Source={StaticResource SaleModeRetail}}"/>
                                                    <helpers:EnumValue Text="جملة" Value="{Binding Source={StaticResource SaleModeWholesale}}"/>
                                                </ComboBox.Items>
                                            </ComboBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="الكمية *" 
                                                    Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N3}" 
                                                    Width="120"
                                                    CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                                <DataGridTemplateColumn Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="🗑️"
                                                    Style="{StaticResource DangerButton}"
                                                    Height="28" Width="28" Padding="0"
                                                    Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibility}}"
                                                    ToolTip="حذف هذا السطر من الفاتورة"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Background="#F1F5F9" Padding="16" Margin="0,8,0,0" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="ملاحظات التحويل" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="50"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Padding="8,4"
                                 IsReadOnly="{Binding IsReadOnly}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="✅ ترحيل النهائي" 
                            Command="{Binding PostCommand}" 
                            Style="{StaticResource PrimaryButton}" 
                            Width="120" 
                            Margin="0,0,12,0"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                            ToolTip="ترحيل العملية نهائياً — سيتم تحديث المخزون والرصيد"/>

                    <Button Content="💾 حفظ مسودة" 
                            Command="{Binding SaveCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            Width="110" 
                            Margin="0,0,8,0" 
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                            ToolTip="حفظ كمسودة دون ترحيل"/>

                    <Button Content="🖨️ طباعة A4" 
                            Command="{Binding PrintA4Command}" 
                            Style="{StaticResource SecondaryButton}" 
                            Width="110" 
                            Margin="0,0,8,0"
                            Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="طباعة فاتورة بصيغة A4"/>

                    <Button Content="❌ إلغاء التحويل" 
                            Command="{Binding CancelTransferCommand}" 
                            Style="{StaticResource DangerButton}" 
                            Width="110" 
                            Margin="0,0,12,0" 
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVisibility}}"
                            ToolTip="إلغاء العملية (للحالات غير المرحلة)"/>

                    <Button Content="🚫 إغلاق" 
                            Command="{Binding CancelCommand}" 
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="إغلاق النافذة دون حفظ"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap" 
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
