<UserControl x:Class="SalesSystem.DesktopPWF.Views.Purchases.PurchaseOrdersListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Purchases"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:PurchaseOrderListViewModel}"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📋 أوامر الشراء" FontSize="14" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

        <!-- ToolBar -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="8,6" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         ToolTip="ابحث باسم المورد أو رقم الأمر">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding RefreshCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Grid.Column="2" Text="الحالة:" VerticalAlignment="Center" Margin="12,0,8,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox Grid.Column="3" ItemsSource="{Binding StatusOptions}"
                          SelectedValue="{Binding FilterStatus}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Display"
                          Style="{StaticResource ModernComboBox}"
                          Width="140"
                          HorizontalAlignment="Left"
                          ToolTip="تصفية حسب حالة أمر الشراء"/>

                <Button Grid.Column="5" Content="🔄 تحديث" Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                        ToolTip="تحديث قائمة أوامر الشراء"/>

                <Button Grid.Column="6" Content="➕ أمر شراء جديد" Command="{Binding AddCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Width="140"
                        ToolTip="إنشاء أمر شراء جديد — تحديد المنتجات والكميات المطلوبة من المورد"/>
            </Grid>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                Background="#F8FAFC" Margin="0,0,0,8">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="لا توجد أوامر شراء" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4" HorizontalAlignment="Center"/>
                <TextBlock Text="قم بإنشاء أول أمر شراء لتحديد المنتجات المطلوب شراؤها من الموردين"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                <Button Content="➕ إنشاء أول أمر شراء" Command="{Binding AddCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Width="160"
                        ToolTip="فتح شاشة إنشاء أمر شراء جديد"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0"
                Visibility="{Binding IsEmpty, Converter={StaticResource InvertedBoolToVisibility}}">
            <DataGrid ItemsSource="{Binding Orders}" Style="{StaticResource ModernDataGrid}"
                      SelectedItem="{Binding SelectedOrder}" BorderThickness="0"
                      CanUserAddRows="False" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="الرقم" Binding="{Binding OrderNo}" Width="80"/>
                    <DataGridTextColumn Header="المورد" Binding="{Binding SupplierName}" Width="*"/>
                    <DataGridTextColumn Header="تاريخ الأمر" Binding="{Binding OrderDate, StringFormat=yyyy/MM/dd}" Width="100"/>
                    <DataGridTextColumn Header="تاريخ التسليم" Binding="{Binding ExpectedDate, StringFormat='{}{0:yyyy/MM/dd}'}" Width="100"/>
                    <DataGridTemplateColumn Header="الحالة" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource OrderStatusToBrushConverter}}"
                                        CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding StatusDisplay}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="المجموع الفرعي" Binding="{Binding SubTotal, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, StringFormat=N2}" Width="100" FontWeight="Bold"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer Actions -->
        <Border Grid.Row="4" Background="White" Padding="8,6" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                Visibility="{Binding IsEmpty, Converter={StaticResource InvertedBoolToVisibility}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="✏️ تعديل" Command="{Binding EditCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                        ToolTip="تعديل أمر الشراء المحدد"/>
                <Button Content="🚫 إلغاء الأمر" Command="{Binding CancelOrderCommand}"
                        Style="{StaticResource DangerButton}" Margin="0,0,8,0"
                        ToolTip="إلغاء أمر الشراء المحدد — متاح فقط للأوامر غير المستلمة"/>
            </StackPanel>
        </Border>

        <!-- Error Message -->
        <TextBlock Grid.Row="5" Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource ErrorBrush}" FontWeight="SemiBold"
                   HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="6" Background="#80FFFFFF" Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري التحميل..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
