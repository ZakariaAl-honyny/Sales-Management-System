<UserControl x:Class="SalesSystem.DesktopPWF.Views.Purchases.PurchaseOrdersListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="16,16,16,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📋  أوامر الشراء" Style="{StaticResource HeaderStyle}" Margin="0,0,0,12"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="200"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="رقم الأمر أو المورد..."
                             ToolTip="أدخل نصاً للبحث في رقم الأمر أو اسم المورد">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Command="{Binding SearchCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            ToolTip="اضغط هنا للبحث عن أوامر الشراء حسب البيانات التي أدخلتها">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Filter -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedValue="{Binding StatusFilter}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"
                              Width="130"
                              Style="{StaticResource ModernComboBox}"
                              ToolTip="تصفية حسب حالة أمر الشراء"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding NewCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,4,0"
                            ToolTip="فتح شاشة إنشاء أمر شراء جديد">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="أمر جديد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ViewCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="عرض أمر الشراء المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👁️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="عرض" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="تعديل أمر الشراء المختار (للمسودات فقط)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PostCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                            ToolTip="اعتماد أمر الشراء المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="اعتماد" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelOrderCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                            ToolTip="إلغاء أمر الشراء المختار">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة أوامر الشراء من الخادم">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource ErrorLightBrush}"
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="10,6"
                Margin="0,0,0,16"
                CornerRadius="8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding OrdersView}"
                          SelectedItem="{Binding SelectedOrder}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutomationProperties.AutomationId="DgPurchaseOrders">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="عرض الأمر" Command="{Binding ViewCommand}">
                                <MenuItem.Icon><TextBlock Text="👁️"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="تعديل الأمر" Command="{Binding EditCommand}">
                                <MenuItem.Icon><TextBlock Text="📝"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="اعتماد الأمر" Command="{Binding PostCommand}">
                                <MenuItem.Icon><TextBlock Text="✅"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="إلغاء الأمر" Command="{Binding CancelOrderCommand}">
                                <MenuItem.Icon><TextBlock Text="❌"/></MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="تحديث" Command="{Binding RefreshCommand}">
                                <MenuItem.Icon><TextBlock Text="🔄"/></MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المعرف"
                                            Binding="{Binding Id}"
                                            Width="70"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="رقم الأمر"
                                            Binding="{Binding OrderNo}"
                                            Width="100"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="التاريخ"
                                            Binding="{Binding OrderDate, StringFormat=yyyy-MM-dd}"
                                            Width="110"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="المورد"
                                            Binding="{Binding SupplierName}"
                                            Width="*"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>

                        <DataGridTextColumn Header="المستودع"
                                            Binding="{Binding WarehouseName}"
                                            Width="120"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>

                        <DataGridTextColumn Header="الإجمالي"
                                            Binding="{Binding TotalAmount, StringFormat=N2}"
                                            Width="120"
                                            CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="0,0,12,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="الحالة" Width="120" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="2"> <!-- Approved -->
                                                        <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="1"> <!-- Draft -->
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3"> <!-- PartiallyReceived -->
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                        <Setter Property="BorderBrush" Value="#F97316"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="4"> <!-- Received -->
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="5"> <!-- Cancelled -->
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Text" Value="معتمد"/>
                                                            <Setter Property="Foreground" Value="{StaticResource InfoTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Text" Value="مسودة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Text" Value="مستلم جزئياً"/>
                                                            <Setter Property="Foreground" Value="#9A3412"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="4">
                                                            <Setter Property="Text" Value="مستلم بالكامل"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="5">
                                                            <Setter Property="Text" Value="ملغي"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                        <TextBlock Text="لا توجد أوامر شراء حالياً" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="أنشئ أمر شراء جديد لبدء تتبع طلبات الشراء من الموردين" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ أمر شراء جديد" Command="{Binding NewCommand}" Margin="0,12,0,0" Width="140"
                                ToolTip="إنشاء أمر شراء جديد"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource FooterBarStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="عدد الأوامر: " Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding Orders.Count, FallbackValue=0}" Style="{StaticResource FooterBarTextStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل أوامر الشراء..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
