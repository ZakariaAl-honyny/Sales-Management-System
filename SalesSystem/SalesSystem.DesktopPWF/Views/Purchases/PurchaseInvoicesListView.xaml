<Page x:Class="SalesSystem.DesktopPWF.Views.Purchases.PurchaseInvoicesListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
      Title="فواتير الشراء"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RefreshCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="16,16,16,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="فواتير الشراء" Style="{StaticResource HeaderStyle}" Margin="0,0,0,12"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="البحث" VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Width="200"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="رقم الفاتورة أو المورد..."
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Command="{Binding SearchCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            Margin="12,0,0,0" Height="36" Padding="16,0"
                            ToolTip="اضغط هنا للبحث عن الفواتير حسب البيانات التي أدخلتها">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="بحث" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <CheckBox Content="عرض الفواتير الملغاة" 
                               IsChecked="{Binding IncludeInactive}" 
                               VerticalAlignment="Center" 
                               FontSize="12"
                               ToolTip="إظهار الفواتير التي تم إلغاؤها سابقاً"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding NewCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,12,0" Height="36" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="فاتورة جديدة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0" Height="36" Padding="16,0"
                            ToolTip="تعديل الفاتورة المختارة (للمسودات فقط)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PostCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" Height="36" Padding="16,0"
                            ToolTip="ترحيل الفاتورة المختارة نهائياً للمخزون">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ترحيل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Height="36" Padding="12,0"
                            ToolTip="تحديث قائمة الفواتير من الخادم">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Error Message Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource ErrorLightBrush}" 
                BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1"
                Padding="16,12"
                Margin="0,0,0,16"
                CornerRadius="8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="18"/>
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorTextBrush}" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding InvoicesView}"
                          SelectedItem="{Binding SelectedInvoice}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutomationProperties.AutomationId="DgPurchaseInvoices">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="عرض الفاتورة" Command="{Binding ViewCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="👁️"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="تعديل الفاتورة" Command="{Binding EditCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="📝"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="ترحيل الفاتورة" Command="{Binding PostCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="✅"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="إلغاء الفاتورة" Command="{Binding CancelCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="❌"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="تحديث" Command="{Binding RefreshCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="🔄"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
<DataGridTextColumn Header="المعرف" 
                                            Binding="{Binding Id}" 
                                            Width="80" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="التاريخ" 
                                            Binding="{Binding InvoiceDate, StringFormat=yyyy-MM-dd}" 
                                            Width="120" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="المورد" 
                                            Binding="{Binding SupplierName}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="رقم فاتورة المورد" 
                                            Binding="{Binding SupplierInvoiceNo}" 
                                            Width="150" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="الإجمالي" 
                                            Binding="{Binding TotalAmount, StringFormat=N2}" 
                                            Width="140" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="0,0,12,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="الحالة" Width="120" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="2"> <!-- Posted -->
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="1"> <!-- Draft -->
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="3"> <!-- Cancelled -->
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="2">
                                                            <Setter Property="Text" Value="مرحلة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Text" Value="مسودة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Text" Value="ملغاة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📦" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                        <TextBlock Text="لا توجد فواتير شراء حالياً" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="سجل عمليات الشراء من الموردين لزيادة المخزون وإدارة فواتيرك هنا" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="➕ إضافة فاتورة شراء" Command="{Binding NewCommand}" Margin="0,24,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource FooterBarStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="عدد الفواتير: " Style="{StaticResource FooterBarTextStyle}" Opacity="0.8"/>
                <TextBlock Text="{Binding Invoices.Count, FallbackValue=0}" Style="{StaticResource FooterBarTextStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل الفواتير..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>

