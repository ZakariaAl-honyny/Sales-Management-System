<Window x:Class="SalesSystem.DesktopPWF.Views.Purchases.PurchaseInvoiceEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="فاتورة شراء"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="1000"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <Style x:Key="ValidationTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ValidationComboBoxStyle" TargetType="ComboBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F3" Command="{Binding SearchProductCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Scrollable Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Path Data="{StaticResource IconInvoice}" Fill="White" Width="20" Height="20" Margin="0,0,12,0" Stretch="Uniform"/>
                    <TextBlock Text="📥  تحرير فاتورة شراء" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{StaticResource PrimaryLightBrush}" CornerRadius="6" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="المعرف: " Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding InvoiceId, FallbackValue='جديد'}" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- Main: Items -->
                <ColumnDefinition Width="320"/>    <!-- Side: Info, Totals, Notes -->
            </Grid.ColumnDefinitions>

            <!-- Main Panel (Right side) -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Barcode Search -->
                    <RowDefinition Height="*"/>    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <!-- Barcode Search -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Background="#F1F5F9" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍 البحث بالباركود" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Grid.Column="1" Text="{Binding BarcodeSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernTextBox}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ProcessBarcodeCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <!-- Green button: opens continuous product selection window -->
                        <Button Grid.Column="2" Content="إضافة" Command="{Binding SearchProductCommand}"
                                Style="{StaticResource SuccessButton}" Margin="6,0,0,0" Width="80" ToolTip="البحث عن منتج وإضافته للقائمة"/>
                        <!-- Separator -->
                        <Separator Grid.Column="3" Width="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>
                        <TextBlock Grid.Column="4" Text="مسح الباركود يضيف الصنف تلقائياً" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Items Grid -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋 قائمة الأصناف" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Padding="8,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Items.Count}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Content="+ إضافة صنف" Command="{Binding AddLineCommand}"
                                        Style="{StaticResource SecondaryButton}" Padding="8,0" FontSize="11" ToolTip="إضافة سطر جديد للفاتورة"/>
                            </Grid>
                        </Border>

                        <DataGrid ItemsSource="{Binding Items}" Style="{StaticResource ModernDataGrid}" BorderThickness="0" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="المنتج" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox ItemsSource="{Binding AvailableProducts}" SelectedItem="{Binding SelectedProduct, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                                          DisplayMemberPath="Name" IsEditable="True" Style="{StaticResource ValidationComboBoxStyle}"/>
                                                <Button Grid.Column="1" Content="🔍" Command="{Binding DataContext.SearchProductSingleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}" Width="28" Height="24" Margin="2,0" ToolTip="فتح نافذة بحث متقدم عن المنتجات"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="الوحدة" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding ProductUnitOptions}"
                                                      SelectedValue="{Binding ProductUnitId, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Value"
                                                      DisplayMemberPath="Display"
                                                      BorderThickness="0" Background="Transparent"
                                                      ToolTip="اختر الوحدة المناسبة للصنف"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="الكمية" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N3}" 
                                                     Style="{StaticResource ValidationTextBoxStyle}" BorderThickness="0" Background="Transparent"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Unit Cost with sync indicator -->
                                <DataGridTemplateColumn Header="التكلفة" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBox Text="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}" 
                                                         Style="{StaticResource ValidationTextBoxStyle}" BorderThickness="0" Background="Transparent"/>
                                                <!-- Sync warning — only shows when cost differs from DB -->
                                                <TextBlock Text="{Binding PriceDifferenceIndicator}"
                                                           FontSize="10"
                                                           Foreground="#E65100"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding CostChangedFromDatabase,
                                                                        Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الخصم" Binding="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                                <DataGridTemplateColumn Header="ملاحظات" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=LostFocus}"
                                                     BorderThickness="0" Background="Transparent"
                                                     ToolTip="إضافة ملاحظة على هذا السطر"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, StringFormat=N2}" Width="100" IsReadOnly="True" FontWeight="Bold"/>
                                <DataGridTemplateColumn Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}" Foreground="{StaticResource ErrorBrush}" BorderBrush="Transparent" ToolTip="حذف هذا السطر من الفاتورة">
                                                <Path Data="{StaticResource IconClose}" Fill="{StaticResource ErrorBrush}" Width="8" Height="8" Stretch="Uniform"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Side Panel (Left side) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Info Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="ℹ️ تفاصيل الفاتورة" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

                            <TextBlock Text="رقم الفاتورة *" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding InvoiceNo, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="رقم الفاتورة — يمكنك إدخال أي رقم تريده"
                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,6"/>

                            <!-- Currency -->
                            <TextBlock Text="العملة" Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding Currencies}"
                                          SelectedValue="{Binding SelectedCurrencyId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource ModernComboBox}"
                                          ToolTip="اختر عملة الفاتورة — العملة الأساسية هي الريال السعودي"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrencyName, StringFormat='({0})'}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </Grid>

                            <TextBlock Text="سعر الصرف" Style="{StaticResource LabelStyle}"
                                       Visibility="{Binding IsBaseCurrency, Converter={StaticResource InverseBoolToVisibility}}"/>
                            <TextBox Text="{Binding ExchangeRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,6"
                                     Visibility="{Binding IsBaseCurrency, Converter={StaticResource InverseBoolToVisibility}}"
                                     ToolTip="سعر صرف العملة مقابل الريال السعودي — للعملات الأجنبية فقط"/>

                            <TextBlock Text="الإجمالي بالريال" Style="{StaticResource LabelStyle}"
                                       Visibility="{Binding IsBaseCurrency, Converter={StaticResource InverseBoolToVisibility}}"/>
                            <TextBlock Text="{Binding ImportTotalInBaseCurrency, StringFormat=N2}"
                                       Margin="0,0,0,8" FontWeight="Bold"
                                       Visibility="{Binding IsBaseCurrency, Converter={StaticResource InverseBoolToVisibility}}"/>

                            <TextBlock Text="المورد" Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Suppliers}" SelectedValue="{Binding SelectedSupplierId}" 
                                          SelectedValuePath="Id" DisplayMemberPath="Name"/>
                                <Button Grid.Column="1" Content="🔍" Command="{Binding SearchSupplierCommand}"
                                        Style="{StaticResource SecondaryButton}" Width="28" Margin="4,0,0,0" ToolTip="البحث عن مورد"/>
                            </Grid>

                            <TextBlock Text="رقم فاتورة المورد" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SupplierInvoiceNo}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,6"/>

                            <TextBlock Text="المستودع" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Warehouses}" SelectedValue="{Binding SelectedWarehouseId}" 
                                      SelectedValuePath="Id" DisplayMemberPath="Name" Margin="0,0,0,6"/>

                            <TextBlock Text="طريقة الدفع" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding PaymentTypeOptions}" SelectedValue="{Binding SelectedPaymentType}" 
                                      SelectedValuePath="Value" DisplayMemberPath="Display" Margin="0,0,0,6"/>

                            <TextBlock Text="الصندوق النقدي *" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding CashBoxes}"
                                      SelectedItem="{Binding SelectedCashBox}"
                                      DisplayMemberPath="BoxName"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,6"
                                      ToolTip="اختر الصندوق النقدي الذي سيتم إيداع المبلغ المدفوع فيه"/>

                            <TextBlock Text="المرفقات" Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding AttachmentFileName}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Visibility="{Binding HasAttachment, Converter={StaticResource BoolToVisibility}}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="📎" Command="{Binding UploadAttachmentCommand}"
                                            Style="{StaticResource SecondaryButton}" MinWidth="28" Height="24" Padding="4,0"
                                            ToolTip="اختيار ملف مرفق (PDF أو صورة)"/>
                                    <Button Content="✕" Command="{Binding RemoveAttachmentCommand}"
                                            Style="{StaticResource SecondaryButton}" MinWidth="24" Height="24" Margin="4,0,0,0" Padding="4,0"
                                            Visibility="{Binding HasAttachment, Converter={StaticResource BoolToVisibility}}"
                                            ToolTip="إزالة المرفق"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Notes}" Height="50" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="8,4"/>
                        </StackPanel>
                    </Border>

                    <!-- Financial Summary Card -->
                    <Border Style="{StaticResource CardStyle}" Background="#F8FAFC" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,4,0">
                        <StackPanel>
                            <TextBlock Text="💰 الملخص المالي" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                            
                            <CheckBox Content="شامل الضريبة" IsChecked="{Binding IsTaxInclusive}" Margin="0,0,0,8"/>
                            
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="الضريبة (%)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding TaxRate, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Right" TextAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="مبلغ" IsChecked="{Binding SelectedDiscountType, Converter={StaticResource DiscountTypeConverter}, ConverterParameter=0}" GroupName="DiscountType" Margin="0,0,12,0"/>
                                    <RadioButton Content="نسبة" IsChecked="{Binding SelectedDiscountType, Converter={StaticResource DiscountTypeConverter}, ConverterParameter=1}" GroupName="DiscountType"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="خصم إضافي" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding InvoiceDiscount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100" HorizontalAlignment="Right" TextAlignment="Left"
                                         Visibility="{Binding SelectedDiscountType, Converter={StaticResource DiscountTypeToVisibilityConverter}, ConverterParameter=0}"/>
                                <TextBox Text="{Binding DiscountRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="70" HorizontalAlignment="Right" TextAlignment="Left" Margin="0,0,30,0"
                                         Visibility="{Binding SelectedDiscountType, Converter={StaticResource DiscountTypeToVisibilityConverter}, ConverterParameter=1}"/>
                                <TextBlock Text="%" HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center"
                                           Visibility="{Binding SelectedDiscountType, Converter={StaticResource DiscountTypeToVisibilityConverter}, ConverterParameter=1}"/>
                            </Grid>

                            <TextBlock Text="الرسوم الإضافية" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding AdditionalFees}" Margin="0,0,0,6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Description}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=N2}"
                                                       HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                            <Button Grid.Column="2" Content="✕" Command="{Binding DataContext.RemoveFeeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}" MinWidth="20" Height="20" Padding="0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="+ إضافة رسم" Command="{Binding AddFeeCommand}"
                                    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="8,2"
                                    HorizontalAlignment="Left" Margin="0,0,0,8"
                                    ToolTip="إضافة رسم إضافي (نقل، جمارك، تأمين، ...)"/>

                            <Separator Margin="0,8"/>

                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="المجموع الفرعي" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SubTotal, StringFormat=N2}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="قيمة الضريبة" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding TaxAmount, StringFormat=N2}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="إجمالي الفاتورة" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="{Binding TotalAmount, StringFormat=N2}" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>

                            <Separator Margin="0,8"/>

                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="المبلغ المدفوع" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110" HorizontalAlignment="Right" FontWeight="Bold" Background="#F0F9FF" BorderBrush="#7DD3FC"/>
                            </Grid>

                            <Border Background="#FEF2F2" Padding="8,6" CornerRadius="4">
                                <Grid>
                                    <TextBlock Text="المبلغ المتبقي" FontWeight="Bold" Foreground="#DC2626"/>
                                    <TextBlock Text="{Binding DueAmount, StringFormat=N2}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="15" Foreground="#DC2626"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="✅ ترحيل نهائي" 
                            Command="{Binding PostCommand}" 
                            Style="{StaticResource PrimaryButton}" 
                            Width="140" 
                            IsDefault="True" 
                            TabIndex="11"
                            Margin="0,0,12,0"
                            ToolTip="ترحيل العملية نهائياً — سيتم تحديث المخزون والرصيد"/>

                    <Button Content="💾 حفظ مسودة" 
                            Command="{Binding SaveCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            Width="120" 
                            Margin="0,0,8,0" 
                            TabIndex="13"
                            ToolTip="حفظ كمسودة دون ترحيل"/>

                    <Button Content="📄 A4" 
                            Command="{Binding PrintA4Command}" 
                            Style="{StaticResource SecondaryButton}" 
                            Margin="0,0,8,0" 
                            TabIndex="14" 
                            ToolTip="طباعة فاتورة بصيغة A4"/>

                    <Button Content="🧾 وصل" 
                            Command="{Binding PrintThermalCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            Margin="0,0,4,0" 
                            TabIndex="15" 
                            ToolTip="طباعة إيصال حراري"/>

                    <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>

                    <Button Content="🚫 إلغاء" 
                            Command="{Binding CancelCommand}" 
                            Style="{StaticResource SecondaryButton}" 
                            TabIndex="15"
                            ToolTip="إلغاء العملية (للحالات غير المرحلة)"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap" 
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري معالجة الفاتورة..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
