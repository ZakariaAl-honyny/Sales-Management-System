<Window x:Class="SalesSystem.DesktopPWF.Views.Purchases.PurchaseOrderEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="أمر شراء"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="1000"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <Style x:Key="ValidationTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Path Data="{StaticResource IconInvoice}" Fill="White" Width="20" Height="20" Margin="0,0,12,0" Stretch="Uniform"/>
                    <TextBlock Text="📋  تحرير أمر شراء" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{StaticResource PrimaryLightBrush}" CornerRadius="6" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="رقم الأمر: " Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding OrderNo, FallbackValue='جديد'}" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Main Panel -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar above grid -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Background="#F1F5F9" Padding="10">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="➕ إضافة صنف" Command="{Binding AddLineCommand}"
                                Style="{StaticResource SuccessButton}" Padding="10,4" FontSize="12"
                                ToolTip="إضافة سطر جديد لأمر الشراء"/>
                        <Button Content="🔍 بحث منتج" Command="{Binding SearchProductCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="10,4" FontSize="12"
                                ToolTip="فتح نافذة البحث عن المنتجات وإضافتها"/>
                        <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>
                        <TextBlock Text="أدخل الكمية والتكلفة لكل صنف" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Items DataGrid -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋 قائمة الأصناف" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Padding="8,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Items.Count}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid ItemsSource="{Binding Items}" Style="{StaticResource ModernDataGrid}" BorderThickness="0" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="المنتج" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox ItemsSource="{Binding AvailableProducts}" SelectedItem="{Binding SelectedProduct, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                                          DisplayMemberPath="Name" IsEditable="True" Style="{StaticResource ModernComboBox}"
                                                          ToolTip="اختر المنتج من القائمة"/>
                                                <Button Grid.Column="1" Content="🔍" Command="{Binding DataContext.SearchProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        Style="{StaticResource SecondaryButton}" Width="28" Height="24" Margin="2,0"
                                                        ToolTip="فتح نافذة بحث متقدم عن المنتجات"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الوحدة" Binding="{Binding ProductUnitId, Converter={x:Null}}" Width="80" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="الكمية" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N3}"
                                                     Style="{StaticResource ValidationTextBoxStyle}" BorderThickness="0" Background="Transparent"
                                                     ToolTip="كمية الصنف المطلوبة"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="تكلفة الوحدة" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat=N2}"
                                                     Style="{StaticResource ValidationTextBoxStyle}" BorderThickness="0" Background="Transparent"
                                                     ToolTip="تكلفة شراء الوحدة الواحدة"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="ملاحظات" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=LostFocus}"
                                                     BorderThickness="0" Background="Transparent"
                                                     ToolTip="إضافة ملاحظة على هذا السطر"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, StringFormat=N2}" Width="100" IsReadOnly="True" FontWeight="Bold"/>
                                <DataGridTemplateColumn Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}" Foreground="{StaticResource ErrorBrush}" BorderBrush="Transparent"
                                                    ToolTip="حذف هذا السطر من الأمر">
                                                <Path Data="{StaticResource IconClose}" Fill="{StaticResource ErrorBrush}" Width="8" Height="8" Stretch="Uniform"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Side Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Order Info Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="ℹ️ تفاصيل الأمر" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

                            <TextBlock Text="رقم الأمر" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding OrderNo, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="رقم أمر الشراء — يمكنك إدخال رقم مخصص أو تركه للتوليد التلقائي"
                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,6"/>

                            <TextBlock Text="المورد *" Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Suppliers}" SelectedValue="{Binding SelectedSupplierId}"
                                          SelectedValuePath="Id" DisplayMemberPath="Name" Style="{StaticResource ModernComboBox}"
                                          ToolTip="اختر المورد الذي سيتم الشراء منه"/>
                                <Button Grid.Column="1" Content="🔍" Command="{Binding SearchSupplierCommand}"
                                        Style="{StaticResource SecondaryButton}" Width="28" Margin="4,0,0,0"
                                        ToolTip="البحث عن مورد"/>
                            </Grid>

                            <TextBlock Text="المستودع *" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Warehouses}" SelectedValue="{Binding SelectedWarehouseId}"
                                      SelectedValuePath="Id" DisplayMemberPath="Name" Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,6"
                                      ToolTip="اختر المستودع الذي سيتم استلام البضاعة فيه"/>

                            <TextBlock Text="تاريخ الأمر" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding OrderDate}" Style="{StaticResource ModernDatePicker}"
                                        Margin="0,0,0,6"
                                        ToolTip="تاريخ إنشاء أمر الشراء"/>

                            <TextBlock Text="تاريخ التسليم المتوقع" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding ExpectedDate}" Style="{StaticResource ModernDatePicker}"
                                        Margin="0,0,0,6"
                                        ToolTip="التاريخ المتوقع لاستلام البضاعة (اختياري)"/>

                            <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Notes}" Height="50" AcceptsReturn="True"
                                     VerticalContentAlignment="Top" Padding="8,4"
                                     ToolTip="ملاحظات إضافية على أمر الشراء"/>
                        </StackPanel>
                    </Border>

                    <!-- Financial Summary Card -->
                    <Border Style="{StaticResource CardStyle}" Background="#F8FAFC" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,4,0">
                        <StackPanel>
                            <TextBlock Text="💰 الملخص المالي" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="المجموع الفرعي" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SubTotal, StringFormat=N2}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>

                            <Separator Margin="0,8"/>

                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="إجمالي الأمر" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="{Binding TotalAmount, StringFormat=N2}" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="✅ اعتماد"
                            Command="{Binding PostCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="120"
                            IsDefault="True"
                            Margin="0,0,12,0"
                            ToolTip="اعتماد أمر الشراء — سيتم تأكيد الأمر ويمكن استخدامه لاستلام البضاعة"/>

                    <Button Content="💾 حفظ مسودة"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="110"
                            Margin="0,0,8,0"
                            ToolTip="حفظ كمسودة دون اعتماد"/>

                    <Button Content="🚫 إلغاء"
                            Command="{Binding CancelOrderCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            ToolTip="إلغاء أمر الشراء (للأمر غير المعتمد)"/>

                    <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>

                    <Button Content="إغلاق"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="إغلاق نافذة تحرير أمر الشراء"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري معالجة أمر الشراء..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
