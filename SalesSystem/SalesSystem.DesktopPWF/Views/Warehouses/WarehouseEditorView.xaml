<Window x:Class="SalesSystem.DesktopPWF.Views.WarehouseEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="450" Width="500"
        MinHeight="400" MinWidth="450"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Premium Header with Gradient -->
        <Border Grid.Row="0" Padding="16,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1E293B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🏭" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White"/>
                    <TextBlock Text="أدخل بيانات المستودع الرئيسي أو الفرعي" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- Name -->
                <TextBlock Text="اسم المستودع *" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}"
                         Tag="أدخل اسم المستودع (مثلاً: المستودع الرئيسي)" 
                         TabIndex="1"
                         helpers:FocusHelper.AdvanceOnEnter="True"
                         AutomationProperties.AutomationId="TxtWarehouseName"
                             ToolTip="أدخل اسماً فريداً للمستودع — هذا الحقل مطلوب ولا يمكن أن يكون فارغاً"/>
                <TextBlock Text="اسم مميز يساعدك في التعرف على المخزن" Style="{StaticResource HelperTextStyle}"/>
                <TextBlock Text="{Binding NameError}" Foreground="{StaticResource ErrorBrush}" FontSize="12" Margin="4,4,0,0" Visibility="{Binding HasNameError, Converter={StaticResource BoolToVisibility}}"/>
                
                <Border Height="24"/>

                <!-- Location -->
                <TextBlock Text="الموقع / العنوان" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}"
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         VerticalContentAlignment="Top" 
                         Tag="مثال: صنعاء - شارع الستين - بجوار بنك التضامن"
                         TabIndex="2"
                         helpers:FocusHelper.AdvanceOnEnter="True"
                         AutomationProperties.AutomationId="TxtWarehouseLocation"/>
                <TextBlock Text="وصف دقيق يساعد السائقين أو عمال التوصيل" Style="{StaticResource HelperTextStyle}"/>
                
                <Border Height="24"/>

                <!-- Status -->
                <Border Padding="16" Background="#F8FAFC" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0">
                    <CheckBox Content="مستودع نشط (جاهز للعمليات)" IsChecked="{Binding IsActive}" FontWeight="SemiBold" TabIndex="3" AutomationProperties.AutomationId="ChkWarehouseActive"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Premium Footer -->
        <Border Grid.Row="2" Background="#F8FAFC" Padding="24,20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="150"
                            IsDefault="True"
                            TabIndex="4"
                            Margin="0,0,12,0"
                            AutomationProperties.AutomationId="BtnSaveWarehouse"
                            ToolTip="حفظ البيانات المدخلة">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSave}" Fill="White" Width="16" Height="16" Margin="0,0,10,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="حفظ البيانات" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            TabIndex="5"
                            ToolTip="إلغاء وإغلاق النافذة"/>
                </StackPanel>

                <TextBlock Grid.Row="1" 
                           Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CCFFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                CornerRadius="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="180" Height="4" Background="#E2E8F0" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" FontWeight="SemiBold" Margin="0,16,0,0" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

