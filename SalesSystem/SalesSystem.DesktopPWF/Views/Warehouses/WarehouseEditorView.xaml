<Window x:Class="SalesSystem.DesktopPWF.Views.WarehouseEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="{Binding Title}"
        MinHeight="350" Width="500"
        MinWidth="450"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Premium Header with Gradient -->
        <Border Grid.Row="0" Padding="12,6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1E293B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🏭" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource HeaderStyle}" Foreground="White"/>
                    <TextBlock Text="أدخل بيانات المستودع" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- Name -->
                <TextBlock Text="اسم المستودع *" Style="{StaticResource LabelStyle}" Margin="4,0,0,8"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         Style="{StaticResource ModernTextBox}"
                         Tag="أدخل اسم المستودع (مثلاً: المستودع الرئيسي)" 
                         TabIndex="1"
                         helpers:FocusHelper.AdvanceOnEnter="True"
                         AutomationProperties.AutomationId="TxtWarehouseName"
                         ToolTip="أدخل اسماً فريداً للمستودع — هذا الحقل مطلوب ولا يمكن أن يكون فارغاً"/>
                <TextBlock Text="اسم مميز يساعدك في التعرف على المخزن" Style="{StaticResource HelperTextStyle}"/>

                <!-- Type -->
                <TextBlock Text="نوع المستودع *" Style="{StaticResource LabelStyle}" Margin="4,0,0,6"/>
                <ComboBox ItemsSource="{Binding TypeList}"
                          SelectedValue="{Binding SelectedType}"
                          SelectedValuePath="Key"
                          DisplayMemberPath="Value"
                          Style="{StaticResource ModernComboBox}"
                          TabIndex="2"
                          AutomationProperties.AutomationId="CboWarehouseType"
                          ToolTip="اختر نوع المستودع — رئيسي، فرعي، صالة عرض، أو تالف"/>

                <!-- Location -->
                <TextBlock Text="الموقع / العنوان" Style="{StaticResource LabelStyle}" Margin="4,0,0,6"/>
                <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         Style="{StaticResource ModernTextBox}"
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         VerticalContentAlignment="Top" 
                         Tag="مثال: صنعاء - شارع الستين - بجوار بنك التضامن"
                         TabIndex="3"
                         helpers:FocusHelper.AdvanceOnEnter="True"
                         AutomationProperties.AutomationId="TxtWarehouseLocation"
                         ToolTip="الموقع الجغرافي للمستودع — اختياري"/>
                <TextBlock Text="وصف دقيق يساعد السائقين أو عمال التوصيل" Style="{StaticResource HelperTextStyle}"/>

                <!-- Phone -->
                <TextBlock Text="رقم الهاتف" Style="{StaticResource LabelStyle}" Margin="4,0,0,6"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Style="{StaticResource ModernTextBox}"
                         TabIndex="4"
                         AutomationProperties.AutomationId="TxtWarehousePhone"
                         ToolTip="رقم هاتف المستودع — اختياري، بحد أقصى 20 حرفاً"/>

                <!-- Address -->
                <TextBlock Text="العنوان التفصيلي" Style="{StaticResource LabelStyle}" Margin="4,0,0,6"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Style="{StaticResource ModernTextBox}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         TabIndex="5"
                         AutomationProperties.AutomationId="TxtWarehouseAddress"
                         ToolTip="العنوان الكامل للمستودع — اختياري"/>

                <!-- Manager Name -->
                <TextBlock Text="مدير المستودع" Style="{StaticResource LabelStyle}" Margin="4,0,0,6"/>
                <TextBox Text="{Binding ManagerName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Style="{StaticResource ModernTextBox}"
                         TabIndex="6"
                         AutomationProperties.AutomationId="TxtWarehouseManager"
                         ToolTip="اسم مدير المستودع المسؤول — اختياري"/>

                <!-- Notes -->
                <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}" Margin="4,0,0,6"/>
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Style="{StaticResource ModernTextBox}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         MinHeight="60"
                         TabIndex="7"
                         AutomationProperties.AutomationId="TxtWarehouseNotes"
                         ToolTip="ملاحظات إضافية عن المستودع — اختياري"/>

                <!-- Status Section -->
                <Border Padding="12,8" Background="#F8FAFC" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Margin="0,8,0,0">
                    <StackPanel>
                        <CheckBox Content="مستودع افتراضي" IsChecked="{Binding IsDefault}" FontWeight="SemiBold" TabIndex="8"
                                  AutomationProperties.AutomationId="ChkWarehouseDefault"
                                  ToolTip="تعيين هذا المستودع كمستودع افتراضي للعمليات"/>
                        <CheckBox Content="مستودع نشط (جاهز للعمليات)" IsChecked="{Binding IsActive}" FontWeight="SemiBold" TabIndex="9"
                                  Margin="0,6,0,0"
                                  AutomationProperties.AutomationId="ChkWarehouseActive"
                                  ToolTip="إلغاء التعطيل إذا كان المستودع غير جاهز للاستخدام"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Premium Footer -->
        <Border Grid.Row="2" Background="#F8FAFC" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="150"
                            IsDefault="True"
                            TabIndex="4"
                            Margin="0,0,12,0"
                            AutomationProperties.AutomationId="BtnSaveWarehouse"
                            ToolTip="حفظ بيانات المستودع — سيتم التحقق من صحة البيانات قبل الحفظ">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSave}" Fill="White" Width="16" Height="16" Margin="0,0,10,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="حفظ البيانات" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            TabIndex="5"
                            ToolTip="إلغاء التغييرات وإغلاق نافذة التحرير"/>
                </StackPanel>

                <TextBlock Grid.Row="1" 
                           Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CCFFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                CornerRadius="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="180" Height="4" Background="#E2E8F0" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="جاري المعالجة..." FontSize="14" FontWeight="SemiBold" Margin="0,16,0,0" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

