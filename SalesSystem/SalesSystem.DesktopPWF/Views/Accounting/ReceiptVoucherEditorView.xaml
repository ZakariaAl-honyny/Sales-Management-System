<UserControl x:Class="SalesSystem.DesktopPWF.Views.Accounting.ReceiptVoucherEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Accounting"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:ReceiptVoucherEditorViewModel, IsDesignTimeCreatable=False}"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="📄  سند قبض جديد"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="TitleAddReceiptVoucher"
                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="0"
                   Text="📄  تعديل سند قبض"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="TitleEditReceiptVoucher"
                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12"/>

        <!-- Main Content Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16,0,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Error Message -->
                <Border Grid.Row="0"
                        Background="{StaticResource ErrorLightBrush}"
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        CornerRadius="6"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="16"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorTextBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable Form Fields -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,6">

                        <!-- Voucher Date -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="تاريخ السند *" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding VoucherDate}"
                                        Style="{StaticResource ModernDatePicker}"
                                        IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBool}}"
                                        AutomationProperties.AutomationId="DtVoucherDate"
                                        ToolTip="تاريخ سند القبض — هذا الحقل إلزامي"/>
                        </StackPanel>

                        <!-- Cash Box -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="الصندوق *" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding CashBoxes}"
                                      SelectedItem="{Binding SelectedCashBox}"
                                      DisplayMemberPath="BoxName"
                                      Style="{StaticResource ModernComboBox}"
                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBool}}"
                                      AutomationProperties.AutomationId="CmbCashBox"
                                      ToolTip="اختيار الصندوق النقدي المستلم — هذا الحقل إلزامي"/>
                        </StackPanel>

                        <!-- Account -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="الحساب المحاسبي *" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount}"
                                      DisplayMemberPath="NameAr"
                                      Style="{StaticResource ModernComboBox}"
                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBool}}"
                                      AutomationProperties.AutomationId="CmbAccount"
                                      ToolTip="اختيار الحساب المحاسبي الدائن — هذا الحقل إلزامي"/>
                        </StackPanel>

                        <!-- Currency -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="العملة *" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Currencies}"
                                      SelectedItem="{Binding SelectedCurrency}"
                                      DisplayMemberPath="Code"
                                      Style="{StaticResource ModernComboBox}"
                                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBool}}"
                                      AutomationProperties.AutomationId="CmbCurrency"
                                      ToolTip="اختيار عملة سند القبض — هذا الحقل إلزامي"/>
                        </StackPanel>

                        <!-- Total Amount -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="المبلغ *" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding TotalAmount, UpdateSourceTrigger=PropertyChanged, StringFormat='N2'}"
                                     Style="{StaticResource ModernTextBox}"
                                     IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBool}}"
                                     AutomationProperties.AutomationId="TxtTotalAmount"
                                     ToolTip="مبلغ سند القبض — يجب أن يكون أكبر من صفر"/>
                        </StackPanel>

                        <!-- Notes -->
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="البيان" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="80"
                                     IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBool}}"
                                     AutomationProperties.AutomationId="TxtNotes"
                                     ToolTip="بيان سند القبض — وصف لعملية القبض (اختياري)"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        AutomationProperties.AutomationId="BtnSaveReceiptVoucher"
                        ToolTip="حفظ سند القبض">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="حفظ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="4,0,0,0"
                        AutomationProperties.AutomationId="BtnCancelReceiptVoucher"
                        ToolTip="إلغاء الأمر والعودة للقائمة">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري حفظ البيانات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
