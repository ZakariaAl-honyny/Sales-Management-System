<Page x:Class="SalesSystem.DesktopPWF.Views.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SalesSystem.DesktopPWF.Views"
      xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      FlowDirection="RightToLeft"
      Title="تسجيل الدخول">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <!-- Centered Card Container -->
        <Border Style="{StaticResource CardStyle}" 
                Width="480" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <StackPanel>
                <!-- Logo & Branding -->
                <StackPanel Margin="0,0,0,40">
                    <Grid Width="80" Height="80" Margin="0,0,0,20">
                        <Border CornerRadius="12" Background="Transparent">
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                                  Fill="{DynamicResource PrimaryBrush}" 
                                  Stretch="Uniform" 
                                  Margin="20"/>
                        </Border>
                    </Grid>

                    <TextBlock Text="نظام إدارة المبيعات" 
                               Style="{StaticResource HeaderStyle}" 
                               HorizontalAlignment="Center" 
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource PrimaryBrush}"/>

                    <TextBlock Text="يرجى تسجيل الدخول للوصول إلى النظام" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" 
                               FontSize="15"/>
                </StackPanel>

                <!-- Login Form -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Username Label -->
                        <RowDefinition Height="Auto"/>
                        <!-- Username Input -->
                        <RowDefinition Height="Auto"/>
                        <!-- Password Label -->
                        <RowDefinition Height="Auto"/>
                        <!-- Password Input -->
                        <RowDefinition Height="Auto"/>
                        <!-- Remember Me -->
                        <RowDefinition Height="50"/>
                        <!-- Error Message (Fixed height to prevent shift) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Login Button -->
                    </Grid.RowDefinitions>

                    <!-- Username -->
                    <TextBlock Grid.Row="0" Text="اسم المستخدم" Style="{StaticResource LabelStyle}" Margin="0,0,0,10"/>
                    <TextBox Grid.Row="1" 
                             x:Name="UsernameTextBox"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,25"
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True"
                             AutomationProperties.AutomationId="UsernameInput"/>

                    <!-- Password -->
                    <TextBlock Grid.Row="2" Text="كلمة المرور" Style="{StaticResource LabelStyle}" Margin="0,0,0,10"/>
                    <PasswordBox Grid.Row="3" 
                                 x:Name="PasswordBox"
                                 helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,20"
                                 TabIndex="2"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="PasswordInput"/>

                    <!-- Remember Me -->
                    <CheckBox Grid.Row="4" 
                              Content="تذكر بياناتي على هذا الجهاز"
                              IsChecked="{Binding RememberMe}"
                              Margin="0,0,0,10"
                              FontSize="13"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TabIndex="3"/>

                    <!-- Error Message Area (Static height to prevent jumping) -->
                    <Border Grid.Row="5" Padding="5">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   AutomationProperties.AutomationId="LoginErrorMessage"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"/>
                    </Border>

                    <!-- Submit Button -->
                    <Button ToolTip="تسجيل الدخول إلى النظام" Grid.Row="5"
                            Content="تسجيل الدخول"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="50"
                            FontSize="16"
                            IsDefault="True"
                            TabIndex="4"
                            AutomationProperties.AutomationId="LoginSubmitButton" HorizontalAlignment="Left" Margin="0,50,0,0" Grid.RowSpan="2" Width="460">
                        <Button.Triggers>
                            <!-- Optional: Add animations if needed -->
                        </Button.Triggers>
                    </Button>
                </Grid>

                <!-- Footer / Support -->
                <TextBlock Margin="0,30,0,0" 
                           Text="الدعم الفني: 92000XXXX" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center" 
                           FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
