<UserControl x:Class="SalesSystem.DesktopPWF.Views.Sessions.UserSessionListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      FlowDirection="RightToLeft"
      Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24,24,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="🔐  جلسات المستخدمين"
                   Style="{StaticResource HeaderStyle}"
                   AutomationProperties.AutomationId="SessionsPageTitle"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- User Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <TextBlock Text="المستخدم" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUserFilter}"
                              DisplayMemberPath="FullName"
                              Width="200"
                              Style="{StaticResource ModernComboBox}"
                              ToolTip="تصفية الجلسات حسب مستخدم معين"/>
                </StackPanel>

                <!-- Status Filter Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                    <CheckBox Content="عرض الجلسات الملغاة" 
                              IsChecked="{Binding IncludeRevoked}" 
                              VerticalAlignment="Center" 
                              FontSize="12"
                              ToolTip="إظهار الجلسات السابقة التي تم إلغاؤها"/>
                </StackPanel>

                <!-- Actions Group -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                    <Button Command="{Binding RevokeCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            ToolTip="إلغاء الجلسة المختارة — سيتم طرد المستخدم من النظام">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚫" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلغاء الجلسة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RevokeAllCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                            ToolTip="إلغاء جميع الجلسات النشطة — سيتم طرد جميع المستخدمين">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلغاء الكل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"
                            ToolTip="تحديث قائمة الجلسات">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding SessionsView}"
                          SelectedItem="{Binding SelectedSession}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          AutomationProperties.AutomationId="DgSessions">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المعرف" 
                                            Binding="{Binding Id}" 
                                            Width="80" 
                                            CellStyle="{StaticResource DataGridCellCenterStyle}"/>
                        
                        <DataGridTextColumn Header="المستخدم" 
                                            Binding="{Binding UserName}" 
                                            Width="*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="وقت الدخول" 
                                            Binding="{Binding CreatedAt, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}" 
                                            Width="1.5*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="آخر نشاط" 
                                            Binding="{Binding LastActivityAt, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}" 
                                            Width="1.5*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>
                        
                        <DataGridTextColumn Header="عنوان IP" 
                                            Binding="{Binding IpAddress}" 
                                            Width="1.5*" 
                                            CellStyle="{StaticResource DataGridCellStyle}"/>

                        <DataGridTemplateColumn Header="الحالة" Width="120" CellStyle="{StaticResource DataGridCellCenterStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                    <Setter Property="Text" Value="نشطة"/>
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text" Value="ملغاة"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🔐" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.3"/>
                        <TextBlock Text="لا توجد جلسات حالياً" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="الجلسات النشطة والمغلقة للمستخدمين ستظهر هنا" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Panel.ZIndex="1000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="جاري تحميل الجلسات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
