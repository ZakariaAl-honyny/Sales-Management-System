<Window x:Class="SalesSystem.DesktopPWF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SalesSystem.DesktopPWF"
        xmlns:helpers="clr-namespace:SalesSystem.DesktopPWF.Helpers"
        mc:Ignorable="d"
        Title="تسجيل الدخول - نظام إدارة المبيعات"
        Height="650" Width="480"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <!-- Background Shadow/Blur Effect -->
        <Border Margin="20" Background="{StaticResource BackgroundBrush}" CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>
            
            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Close Button -->
                    <RowDefinition Height="Auto"/> <!-- Logo & Title -->
                    <RowDefinition Height="*"/>    <!-- Form -->
                    <RowDefinition Height="Auto"/> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Custom Title Bar / Close Button -->
                <Button Grid.Row="0" 
                        Content="✕" 
                        HorizontalAlignment="Right" 
                        Style="{StaticResource SecondaryButton}" 
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderThickness="0"/>

                <!-- Logo & Branding -->
                <StackPanel Grid.Row="1" Margin="0,0,0,40">
                    <Grid Width="80" Height="80" Margin="0,0,0,20">
                        <Border CornerRadius="12" Background="{StaticResource PrimaryBrush}">
                            <TextBlock Text="🏪" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    
                    <TextBlock Text="نظام إدارة المبيعات" 
                               Style="{StaticResource HeaderStyle}" 
                               HorizontalAlignment="Center" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    
                    <TextBlock Text="يرجى تسجيل الدخول للوصول إلى النظام" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Login Form -->
                <StackPanel Grid.Row="2">
                    <!-- Username -->
                    <TextBlock Text="اسم المستخدم" Style="{StaticResource LabelStyle}" Margin="0,0,0,10"/>
                    <TextBox x:Name="UsernameTextBox"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,25"
                             TabIndex="1"
                             helpers:FocusHelper.AdvanceOnEnter="True"
                             AutomationProperties.AutomationId="UsernameInput"/>

                    <!-- Password -->
                    <TextBlock Text="كلمة المرور" Style="{StaticResource LabelStyle}" Margin="0,0,0,10"/>
                    <PasswordBox x:Name="PasswordBox"
                                 helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,20"
                                 TabIndex="2"
                                 helpers:FocusHelper.AdvanceOnEnter="True"
                                 AutomationProperties.AutomationId="PasswordInput"/>

                    <!-- Remember Me -->
                    <CheckBox Content="تذكر بياناتي على هذا الجهاز"
                              IsChecked="{Binding RememberMe}"
                              Margin="0,0,0,10"
                              FontSize="13"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              TabIndex="3"/>

                    <!-- Error Message Area -->
                    <Border MinHeight="40" Margin="0,0,0,10" Padding="5" 
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Submit Button -->
                    <Button Content="تسجيل الدخول"
                            Command="{Binding LoginCommand}"
                            IsDefault="True"
                            TabIndex="4"
                            AutomationProperties.AutomationId="LoginSubmitButton"/>
                </StackPanel>

                <!-- Loading Overlay -->
                <Border Grid.Row="0" Grid.RowSpan="4"
                        Background="#80FFFFFF"
                        CornerRadius="20"
                        Panel.ZIndex="1000"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E3E8EE" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="جاري التحقق من البيانات..." FontSize="14" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <TextBlock Grid.Row="3" Margin="0,20,0,0" 
                           Text="الدعم الفني: 92000XXXX" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center" 
                           FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>