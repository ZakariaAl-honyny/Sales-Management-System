        MinHeight="600" MinWidth="900"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="F3" Command="{Binding NavigateToProductsCommand}"/>
        <KeyBinding Key="F4" Command="{Binding NavigateToCustomersCommand}"/>
        <KeyBinding Key="F5" Command="{Binding NavigateToPurchasesCommand}"/>
        <KeyBinding Key="F8" Command="{Binding NavigateToReportsCommand}"/>
    </Window.InputBindings>

