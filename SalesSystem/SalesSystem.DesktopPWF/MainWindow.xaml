                                             ToolTip="عرض تقرير المبيعات اليومية — المبيعات والإيرادات والمقبوضات لكل يوم"/>
                                    <Button Content="المبيعات حسب العميل"
                                             Command="{Binding NavigateToSalesByCustomerCommand}"
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavSalesByCustomer"
                                             ToolTip="عرض تقرير المبيعات حسب العميل — إجمالي المبيعات وعدد الفواتير لكل عميل"/>
                                    <Button Content="المبيعات حسب المنتج"
                                             Command="{Binding NavigateToSalesByProductCommand}"
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavSalesByProduct"
                                             ToolTip="عرض تقرير المبيعات حسب المنتج — كمية وقيمة المبيعات لكل منتج"/>
                                    <Button Content="المبيعات حسب التصنيف"
                                             Command="{Binding NavigateToSalesByCategoryCommand}"
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavSalesByCategory"
                                             ToolTip="عرض تقرير المبيعات حسب التصنيف — توزيع المبيعات على تصنيفات المنتجات"/>
                                    <Separator Margin="16,4"/>
                                    <!-- Purchases Reports -->
                                    <Button Content="المشتريات حسب المورد"
                                             Command="{Binding NavigateToPurchasesBySupplierCommand}"
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavPurchasesBySupplier"
                                             ToolTip="عرض تقرير المشتريات حسب المورد — إجمالي المشتريات وعدد الفواتير لكل مورد"/>
                                    <Button Content="المشتريات حسب المنتج"
                                             Command="{Binding NavigateToPurchasesByProductCommand}"
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavPurchasesByProduct"
                                             ToolTip="عرض تقرير المشتريات حسب المنتج — كمية وقيمة المشتريات لكل منتج"/>
                                    <Separator Margin="16,4"/>
                                    <!-- Cash Reports -->
                                    <Button Content="ملخص الخزينة"
                                             Command="{Binding NavigateToCashBoxSummaryCommand}"
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavCashBoxSummary"
                                             ToolTip="عرض ملخص الخزينة — حركات الصندوق والإيرادات والمصروفات والأرصدة"/>
                                    <Separator Margin="16,4"/>
                                    <!-- Activity Reports -->
                                    <Button Content="سجل الدخول"
                                             Command="{Binding NavigateToLoginHistoryCommand}"
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavLoginHistory"
                                             ToolTip="عرض سجل الدخول — محاولات تسجيل الدخول الناجحة والفاشلة للمستخدمين"/>
                                    <Button Content="نشاط المستخدمين"
                                             Command="{Binding NavigateToUserActivityCommand}"
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavUserActivity"
                                             ToolTip="عرض نشاط المستخدمين — سجل الإجراءات والعمليات التي قام بها كل مستخدم"/>
                                </StackPanel>
                            </Expander>

                            <!-- Products Expander -->
                            <Expander Header="الأصناف" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderProducts"
                                      Visibility="{Binding HasInventoryAccess, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>

                                    <Button Content="الأصناف" 
                                            Command="{Binding NavigateToProductsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavProducts"
                                            ToolTip="إدارة قائمة الأصناف والمنتجات والأسعار والباركود"/>
                                    <Button Content="وحدات الصنف" 
                                            Command="{Binding NavigateToProductUnitsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavProductUnits"
                                            ToolTip="إدارة وحدات القياس لكل صنف — إضافة وتعديل وحدات البيع والتخزين"/>
                                    <Button Content="أسعار البيع" 
                                            Command="{Binding NavigateToProductPricesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavProductPrices"
                                            ToolTip="إدارة أسعار البيع متعددة العملات — تحديد سعر التجزئة والجملة لكل وحدة"/>
                                    <Button Content="استيراد Excel" 
                                            Command="{Binding NavigateToProductImportCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavProductImport"
                                            ToolTip="استيراد الأصناف والمنتجات من ملف Excel — إضافة أو تحديث الكميات والأسعار"/>
                                    <Button Content="مجموعات الأصناف" 
                                            Command="{Binding NavigateToProductCategoriesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavProductCategories"
                                            ToolTip="إدارة مجموعات التصنيف — إضافة وتعديل مجموعات الأصناف لتنظيم المنتجات"/>
                                </StackPanel>
                            </Expander>

                            <!-- Settings Expander -->
                            <Expander Header="الإعدادات" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderSettings">
                                <StackPanel>
                                    <Button Content="العملاء" 
                                            Command="{Binding NavigateToCustomersCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCustomers"
                                            ToolTip="إدارة بيانات العملاء والحسابات وتاريخ المعاملات"/>
                                    <Button Content="الموردين" 
                                            Command="{Binding NavigateToSuppliersCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSuppliers"
                                            ToolTip="إدارة بيانات الموردين ومتابعة المستحقات المالية"/>
                                    <Button Content="المستودعات" 
                                            Command="{Binding NavigateToWarehousesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavWarehouses"
                                            ToolTip="إدارة الفروع والمستودعات ومواقع تخزين المنتجات"/>
                                    <Button Content="المستخدمين" 
                                             Command="{Binding NavigateToUsersCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavUsers"
                                             ToolTip="إدارة حسابات الموظفين والصلاحيات وبيانات الدخول"/>
                                    <Button Content="الأدوار والصلاحيات" 
                                             Command="{Binding NavigateToRolesCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavRoles"
                                             ToolTip="إدارة أدوار المستخدمين — إضافة وتعديل الأدوار وتعيين الصلاحيات"/>
                                    <Button Content="جلسات المستخدمين" 
                                             Command="{Binding NavigateToSessionsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavSessions"
                                             ToolTip="عرض وإدارة جلسات المستخدمين النشطة — إلغاء جلسات المخالفين"/>
                                    <Button Content="الإعدادات" 
                                             Command="{Binding NavigateToSettingsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavSettings"
                                             ToolTip="إعدادات النظام والعملات والضرائب وتهيئة الطابعات"/>
                                    <Button Content="إعدادات النظام" 
                                            Command="{Binding NavigateToSystemSettingsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSystemSettings"
                                            ToolTip="إدارة جميع إعدادات النظام المخزنة — المخزون والمبيعات والمشتريات والباركود"/>
                                    <Button Content="النسخ الاحتياطي" 
                                             Command="{Binding NavigateToBackupCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavBackup"
                                             ToolTip="إدارة النسخ الاحتياطي — إنشاء واستعادة النسخ الاحتياطية لقاعدة البيانات"/>
                                    <Button Content="سجل أحداث النظام" 
                                             Command="{Binding NavigateToSystemLogsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavSystemLogs"
                                             ToolTip="عرض سجل أحداث النظام — أخطاء النظام وسجلات التشغيل والتحذيرات"/>
                                    <Button Content="الضرائب" 
                                            Command="{Binding NavigateToTaxesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavTaxes"
                                            ToolTip="إدارة الضرائب — إضافة وتعديل نسب الضريبة"/>
                                    <Button Content="دليل الحسابات" 
                                             Command="{Binding NavigateToChartOfAccountsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavChartOfAccounts"
                                             ToolTip="إدارة دليل الحسابات — عرض وتعديل الحسابات المحاسبية"
                                             Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <Button Content="حسابات النظام" 
                                             Command="{Binding NavigateToSystemAccountMappingsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavSystemAccountMappings"
                                             ToolTip="ربط العمليات التجارية بالحسابات المحاسبية — تعيين الحسابات الافتراضية للمبيعات والمشتريات والنقد"
                                             Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <Button Content="التصنيفات المحاسبية" 
                                             Command="{Binding NavigateToAccountCategoriesCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavAccountCategories"
                                             ToolTip="إدارة تصنيفات دليل الحسابات — تصنيف الحسابات حسب طبيعة النشاط"
                                             Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <Separator Margin="16,4"/>
                                    <Button Content="إعدادات الشركة" 
                                             Command="{Binding NavigateToCompanySettingsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavCompanySettings"
                                             ToolTip="تعديل اسم الشركة وبيانات الاتصال والعملة الافتراضية — تظهر هذه المعلومات في الفواتير والتقارير"/>
                                    <Button Content="تسلسل المستندات" 
                                             Command="{Binding NavigateToDocumentSequencesCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavDocumentSequences"
                                             ToolTip="عرض وإعادة تعيين أرقام المستندات التلقائية — التحكم في تسلسل ترقيم الفواتير"/>
                                    <Button Content="نقل المخزون" 
                                             Command="{Binding NavigateToWarehouseTransfersCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavWarehouseTransfers"
                                             ToolTip="إدارة عمليات نقل البضائع بين المستودعات"/>
                                    <Button Content="المخزون" 
                                             Command="{Binding NavigateToInventoryCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavInventory"
                                             ToolTip="عرض حركة المخزون وإدارة الأصناف في المستودعات"/>
                                    <Button Content="حركات المخزون" 
                                             Command="{Binding NavigateToInventoryTransactionsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavInventoryTransactions"
                                             ToolTip="عرض تاريخ حركات المخزون — الإضافات والخصم والتحويلات مع تفاصيل التشغيلة والصلاحية"/>
                                    <Button Content="جرد المخزون" 
                                             Command="{Binding NavigateToInventoryCountsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavInventoryCounts"
                                             ToolTip="إدارة وإجراء جرد المخزون الدوري — مطابقة الكميات الفعلية مع المسجلة"/>
                                    <Button Content="تسويات المخزون" 
                                             Command="{Binding NavigateToInventoryAdjustmentsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavInventoryAdjustments"
                                             ToolTip="إضافة وتعديل تسويات المخزون — إضافة أو خصم الكميات"/>
                                    <Separator Margin="16,4"/>
                                    <Button Content="الإشعارات" 
                                             Command="{Binding NavigateToNotificationsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavNotifications"
                                             ToolTip="عرض إشعارات النظام والتنبيهات والتذكيرات"/>
                                    <Button Content="المرفقات" 
                                             Command="{Binding NavigateToAttachmentsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavAttachments"
                                             ToolTip="عرض وإدارة الملفات المرفقة المرتبطة بالمعاملات"/>
                                </StackPanel>
                            </Expander>

                            <!-- Organization Management Expander -->
                            <Expander Header="إدارة المنشأة" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderOrgMgmt"
                                      Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <Button Content="الفروع" 
                                            Command="{Binding NavigateToBranchesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavBranches"
                                            ToolTip="إدارة الفروع — إضافة وتعديل وعرض الفروع"/>
                                    <Button Content="الأقسام" 
                                            Command="{Binding NavigateToDepartmentsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavDepartments"
                                            ToolTip="إدارة الأقسام — إضافة وتعديل وعرض الأقسام"/>
                                    <Button Content="الموظفين" 
                                            Command="{Binding NavigateToEmployeesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavEmployees"
                                            ToolTip="إدارة الموظفين — إضافة وتعديل وعرض الموظفين"/>
                                    <Button Content="البنوك" 
                                            Command="{Binding NavigateToBanksCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavBanks"
                                            ToolTip="إدارة البنوك — إضافة وتعديل بيانات البنوك والحسابات"/>
                                    <Button Content="المصروفات" 
                                            Command="{Binding NavigateToExpensesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavExpenses"
                                            ToolTip="إدارة المصروفات — إضافة وتعديل وعرض المصروفات"/>
                                </StackPanel>
                            </Expander>

                            <!-- Currencies Expander -->
                            <Expander Header="العملات" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderCurrencies"
                                      Visibility="{Binding HasCurrenciesAccess, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <Button Content="العملات" 
                                            Command="{Binding NavigateToCurrenciesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCurrencies"
                                            ToolTip="إدارة العملات — إضافة وتعديل العملات وتعيين العملة الأساسية"/>
                                    <Button Content="أسعار العملات" 
                                            Command="{Binding NavigateToCurrencyRatesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCurrencyRates"
                                            ToolTip="إدارة أسعار صرف العملات — عرض وتحديث أسعار الصرف اليومية"/>
                                </StackPanel>
                            </Expander>

                            <!-- Inventory Operations Expander -->
                            <Expander Header="عمليات المخزون" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderInventoryOps"
                                      Visibility="{Binding HasInventoryAccess, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <Button Content="صرف مخزني" 
                                            Command="{Binding NavigateToInventoryIssueCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavInventoryIssue"
                                            ToolTip="صرف أصناف من المخزون بدون فاتورة بيع"/>
                                    <Button Content="توريد مخزني" 
                                            Command="{Binding NavigateToInventoryReceiptCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavInventoryReceipt"
                                            ToolTip="إضافة أصناف إلى المخزون بدون فاتورة شراء"/>
                                    <Button Content="تالف وهالك" 
                                            Command="{Binding NavigateToInventoryDamageCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavInventoryDamage"
                                            ToolTip="تسجيل الأصناف التالفة والمنتهية الصلاحية"/>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- المنطقة الرئيسية - عرض المحتوى -->
            <ContentControl Content="{Binding CurrentViewModel}" Grid.Column="1" Margin="8" />
        </Grid>

        <!-- شريط الحالة Status Bar -->
        <StatusBar Grid.Row="2" Style="{StaticResource StatusBarStyle}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <!-- Avatar indicator -->
                    <Border Width="24" Height="24" CornerRadius="12"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,6,0">
                        <TextBlock Text="👤" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="المستخدم: " Margin="0,0,3,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtUserName" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="الدور: " Margin="0,0,3,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Border x:Name="RoleBadge" CornerRadius="4" Padding="6,1">
                        <TextBlock x:Name="TxtUserRole" FontWeight="Bold" FontSize="11"/>
                    </Border>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="الفرع:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding UserBranches}"
                              SelectedItem="{Binding SelectedUserBranch}"
                              DisplayMemberPath="Name"
                              Style="{StaticResource ModernComboBox}"
                              MinWidth="120"
                              ToolTip="اختيار الفرع النشط"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <Button x:Name="BtnChangePassword"
                        Content="🔑"
                        Style="{StaticResource SecondaryButton}"
                        Padding="6,2"
                        ToolTip="فتح نافذة تغيير كلمة المرور"
                        Click="BtnChangePassword_Click"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="CurrentDateText" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button x:Name="BtnLogoutStatus"
                            Content="🚪 خروج"
                            Style="{StaticResource SecondaryButton}"
                            Padding="8,2"
                            Margin="8,0,0,0"
                            ToolTip="تسجيل الخروج من النظام"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
