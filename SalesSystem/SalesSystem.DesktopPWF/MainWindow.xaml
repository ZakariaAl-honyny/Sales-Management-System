    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- شريط القوائم Menu Bar -->
        <Menu Grid.Row="0" Background="White" Padding="3">
            <MenuItem Header="ملف" ToolTip="قائمة الملف">
                <MenuItem Header="الملف الشخصي" ToolTip="عرض معلومات المستخدم الحالي" Click="ProfileMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="فحص التحديثات" ToolTip="التحقق من وجود إصدار جديد للنظام" Click="CheckForUpdatesMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="تسجيل الخروج" ToolTip="تسجيل الخروج من النظام" Click="BtnLogout_Click"/>
            </MenuItem>
            <MenuItem Header="المبيعات" ToolTip="قائمة المبيعات">
                <MenuItem Header="فواتير البيع" ToolTip="عرض وإدارة فواتير البيع" Click="SalesInvoicesMenuItem_Click"/>
                <MenuItem Header="عروض السعر" ToolTip="عرض وإدارة عروض الأسعار للعملاء" Click="SalesQuotationsMenuItem_Click"/>
                <MenuItem Header="إرجاع المبيعات" ToolTip="إدارة مرتجعات المبيعات" Click="SalesReturnsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="فتح نافذة مبيعات جديدة" ToolTip="فتح نافذة مبيعات مستقلة في نافذة منفصلة" Click="OpenNewSalesWindow_Click"/>
            </MenuItem>
            <MenuItem Header="المشتريات" ToolTip="قائمة المشتريات">
                <MenuItem Header="فواتير الشراء" ToolTip="عرض وإدارة فواتير الشراء" Click="PurchaseInvoicesMenuItem_Click"/>
                <MenuItem Header="أوامر الشراء" ToolTip="عرض وإدارة أوامر الشراء" Click="PurchaseOrdersMenuItem_Click"/>
                <MenuItem Header="إرجاع المشتريات" ToolTip="إدارة مرتجعات المشتريات" Click="PurchaseReturnsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="تسديد ديون الموردين" ToolTip="تسجيل المبالغ المدفوعة للموردين" Click="SupplierPaymentsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="فتح نافذة مشتريات جديدة" ToolTip="فتح نافذة مشتريات مستقلة في نافذة منفصلة" Click="OpenNewPurchasesWindow_Click"/>
                <MenuItem Header="فتح نافذة أوامر شراء جديدة" ToolTip="فتح نافذة أوامر شراء مستقلة في نافذة منفصلة" Click="OpenNewPurchaseOrdersWindow_Click"/>
            </MenuItem>
            <MenuItem Header="المستودعات" ToolTip="قائمة المستودعات">
                <MenuItem Header="إدارة المستودعات" ToolTip="إدارة الفروع والمستودعات" Click="WarehousesMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="نقل المخزون" ToolTip="إدارة عمليات نقل البضائع بين المستودعات" Click="WarehouseTransfersMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="فتح نافذة مستودعات جديدة" ToolTip="فتح نافذة مستودعات مستقلة في نافذة منفصلة" Click="OpenNewWarehousesWindow_Click"/>
            </MenuItem>
            <MenuItem Header="التقارير" ToolTip="قائمة التقارير">
                <MenuItem Header="تقرير المبيعات" ToolTip="عرض تقارير المبيعات" Tag="Reports" Click="ReportMenuItem_Click"/>
                <MenuItem Header="تقرير المشتريات" ToolTip="عرض تقارير المشتريات" Tag="Reports" Click="ReportMenuItem_Click"/>
                <MenuItem Header="تقرير المخزون" ToolTip="عرض تقارير المخزون" Tag="Inventory" Click="ReportMenuItem_Click"/>
                <MenuItem Header="تقرير الأرباح والخسائر" ToolTip="عرض تقارير الأرباح والخسائر" Tag="Reports" Click="ReportMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="المنتجات المنتهية" ToolTip="إدارة وترحيل المنتجات المنتهية الصلاحية" Tag="ExpiredProducts" Click="ReportMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="قائمة الدخل" ToolTip="عرض قائمة الدخل — الإيرادات والتكاليف وصافي الربح" Tag="Reports" Click="ReportMenuItem_Click"
                          Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="التدفق النقدي" ToolTip="عرض تقرير التدفق النقدي — الإيرادات والمصروفات والأرصدة" Tag="Reports" Click="ReportMenuItem_Click"
                          Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="ضريبة القيمة المضافة" ToolTip="عرض تقرير ضريبة القيمة المضافة — تفصيل الفواتير والضريبة" Tag="Reports" Click="ReportMenuItem_Click"
                          Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="كشف حساب" ToolTip="عرض كشف حساب عميل أو مورد — الحركات المدينة والدائنة" Tag="Reports" Click="ReportMenuItem_Click"
                          Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="كشف رصيد المخازن" Command="{Binding NavigateToStockBalanceReportCommand}" ToolTip="عرض المخزون الحالي والقيمة الإجمالية لكل منتج في المستودعات"/>
                <MenuItem Header="حركة المخازن" Command="{Binding NavigateToWarehouseMovementReportCommand}" ToolTip="عرض تاريخ حركات المخزون مع التصفية حسب المستودع والفترة"/>
                <Separator/>
                <MenuItem Header="التقارير المالية" ToolTip="التقارير المالية — الميزانية وميزان المراجعة وكشف الحساب"
                          Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVisibility}}">
                    <MenuItem Header="الميزانية العمومية" ToolTip="عرض الميزانية العمومية — الأصول والخصوم وحقوق الملكية" Tag="BalanceSheet" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="ميزان المراجعة" ToolTip="عرض ميزان المراجعة — أرصدة الحسابات مدينة/دائنة" Tag="TrialBalance" Click="ReportMenuItem_Click"/>
