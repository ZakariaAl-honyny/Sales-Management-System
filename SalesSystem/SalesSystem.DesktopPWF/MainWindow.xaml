            <DataTemplate DataType="{x:Type vmRoles:RoleListViewModel}">
                <viewsRoles:RoleListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSessions:UserSessionListViewModel}">
                <viewsSessions:UserSessionListView />
