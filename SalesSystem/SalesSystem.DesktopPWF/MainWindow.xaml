                                            Command="{Binding NavigateToSalesReturnsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSalesReturns"
                                            ToolTip="إدارة مرتجعات المبيعات وإعادة الأصناف للمخزون"/>
                                </StackPanel>
                            </Expander>

                            <!-- Purchases Expander -->
                            <Expander Header="المشتريات" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderPurchases"
                                      Visibility="{Binding HasPurchasesAccess, Converter={StaticResource BoolToVisibility}}">
