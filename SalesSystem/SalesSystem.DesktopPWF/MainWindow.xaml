<Window x:Class="SalesSystem.DesktopPWF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SalesSystem.DesktopPWF"
        xmlns:viewmodels="clr-namespace:SalesSystem.DesktopPWF.ViewModels"
        xmlns:views="clr-namespace:SalesSystem.DesktopPWF.Views"
        xmlns:viewsSales="clr-namespace:SalesSystem.DesktopPWF.Views.Sales"
        xmlns:viewsReturns="clr-namespace:SalesSystem.DesktopPWF.Views.Returns"
        xmlns:viewsPurchases="clr-namespace:SalesSystem.DesktopPWF.Views.Purchases"
        xmlns:viewsPayments="clr-namespace:SalesSystem.DesktopPWF.Views.Payments"
        xmlns:viewsCashBoxes="clr-namespace:SalesSystem.DesktopPWF.Views.CashBoxes"
        xmlns:viewsReports="clr-namespace:SalesSystem.DesktopPWF.Views.Reports"
        xmlns:viewsInventory="clr-namespace:SalesSystem.DesktopPWF.Views.Inventory"
        xmlns:viewsProducts="clr-namespace:SalesSystem.DesktopPWF.Views.Products"
        xmlns:viewsCustomers="clr-namespace:SalesSystem.DesktopPWF.Views.Customers"
        xmlns:viewsSuppliers="clr-namespace:SalesSystem.DesktopPWF.Views.Suppliers"
        xmlns:viewsCategories="clr-namespace:SalesSystem.DesktopPWF.Views.Categories"
        xmlns:viewsUnits="clr-namespace:SalesSystem.DesktopPWF.Views.Units"
        xmlns:viewsUsers="clr-namespace:SalesSystem.DesktopPWF.Views.Users"
        xmlns:viewsTransfers="clr-namespace:SalesSystem.DesktopPWF.Views.Transfers"
             xmlns:viewsSettings="clr-namespace:SalesSystem.DesktopPWF.Views.Settings"
             xmlns:vmSettings="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Settings"
             xmlns:vmSales="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Sales"
        xmlns:vmReturns="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Returns"
        xmlns:vmPurchases="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Purchases"
        xmlns:vmPayments="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Payments"
        xmlns:vmCashBoxes="clr-namespace:SalesSystem.DesktopPWF.ViewModels.CashBoxes"
        xmlns:vmReports="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Reports"
        xmlns:vmInventory="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Inventory"
        xmlns:vmProducts="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Products"
        xmlns:vmCustomers="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Customers"
        xmlns:vmSuppliers="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Suppliers"
        xmlns:vmCategories="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Categories"
        xmlns:vmUnits="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Units"
        xmlns:vmUsers="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Users"
        xmlns:vmTaxes="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Taxes"
        xmlns:viewsTaxes="clr-namespace:SalesSystem.DesktopPWF.Views.Taxes"
             xmlns:vmCurrencies="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Currencies"
             xmlns:viewsCurrencies="clr-namespace:SalesSystem.DesktopPWF.Views.Currencies"
             xmlns:vmAccounts="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Accounts"
             xmlns:vmJournalEntries="clr-namespace:SalesSystem.DesktopPWF.ViewModels.JournalEntries"
             xmlns:viewsJournalEntries="clr-namespace:SalesSystem.DesktopPWF.Views.JournalEntries"
             xmlns:viewsAccounts="clr-namespace:SalesSystem.DesktopPWF.Views.Accounts"
         xmlns:vmTransfers="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Transfers"
         xmlns:audit="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Audit"
         xmlns:perms="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Permissions"
         xmlns:viewsAudit="clr-namespace:SalesSystem.DesktopPWF.Views.Audit"
          xmlns:viewsPerms="clr-namespace:SalesSystem.DesktopPWF.Views.Permissions"
          xmlns:viewsWarehouses="clr-namespace:SalesSystem.DesktopPWF.Views.Warehouses"
            xmlns:vmWarehouses="clr-namespace:SalesSystem.DesktopPWF.ViewModels.Warehouses"
            xmlns:viewsInventoryOps="clr-namespace:SalesSystem.DesktopPWF.Views.InventoryOperations"
           xmlns:vmInventoryOps="clr-namespace:SalesSystem.DesktopPWF.ViewModels.InventoryOperations"
           mc:Ignorable="d"
        Title="نظام إدارة المبيعات"
        Height="700" Width="1200"
        MinHeight="600" MinWidth="900"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- DataTemplates for ViewModel → View mapping -->
            <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSales:TouchPosViewModel}">
                <viewsSales:TouchPosView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSales:SalesInvoiceListViewModel}">
                <viewsSales:SalesInvoicesListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReturns:SalesReturnListViewModel}">
                <viewsReturns:SalesReturnsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmPurchases:PurchaseInvoiceListViewModel}">
                <viewsPurchases:PurchaseInvoicesListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmPurchases:PurchaseOrderListViewModel}">
                <viewsPurchases:PurchaseOrdersListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReturns:PurchaseReturnListViewModel}">
                <viewsReturns:PurchaseReturnsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmPayments:CustomerPaymentsListViewModel}">
                <viewsPayments:CustomerPaymentsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmPayments:SupplierPaymentsListViewModel}">
                <viewsPayments:SupplierPaymentsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCashBoxes:CashBoxesListViewModel}">
                <viewsCashBoxes:CashBoxesListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:ReportsViewModel}">
                <viewsReports:ReportsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmInventory:LowStockViewModel}">
                <viewsInventory:LowStockView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:ExpiredProductsReportViewModel}">
                <viewsReports:ExpiredProductsReportView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:IncomeStatementViewModel}">
                <viewsReports:IncomeStatementView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:CashFlowReportViewModel}">
                <viewsReports:CashFlowReportView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:VatReportViewModel}">
                <viewsReports:VatReportView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:AccountStatementViewModel}">
                <viewsReports:AccountStatementView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:StockBalanceReportViewModel}">
                <viewsReports:StockBalanceReportView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:WarehouseMovementReportViewModel}">
                <viewsReports:WarehouseMovementReportView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmProducts:ProductListViewModel}">
                <viewsProducts:ProductsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmProducts:ProductPricesListViewModel}">
                <viewsProducts:ProductPricesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmProducts:ProductImagesViewModel}">
                <viewsProducts:ProductImagesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmProducts:BillOfMaterialsListViewModel}">
                <viewsProducts:BillOfMaterialsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmWarehouses:InventoryBatchesViewModel}">
                <viewsWarehouses:InventoryBatchesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCustomers:CustomerListViewModel}">
                <viewsCustomers:CustomersListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCustomers:CustomerGroupListViewModel}">
                <viewsCustomers:CustomerGroupsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSuppliers:SupplierListViewModel}">
                <viewsSuppliers:SuppliersListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:WarehouseListViewModel}">
                <views:WarehousesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCategories:CategoryListViewModel}">
                <viewsCategories:CategoriesListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmUnits:UnitListViewModel}">
                <viewsUnits:UnitsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmUsers:UserListViewModel}">
                <viewsUsers:UsersListView />
            </DataTemplate>
             <DataTemplate DataType="{x:Type vmInventoryOps:InventoryOperationListViewModel}">
                 <viewsInventoryOps:InventoryOperationListView />
             </DataTemplate>
             <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
                <viewsSettings:SettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSettings:SystemSettingsViewModel}">
                <viewsSettings:SystemSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSettings:BackupViewModel}">
                <viewsSettings:BackupView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmTransfers:StockTransfersListViewModel}">
                <viewsTransfers:StockTransfersListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmInventory:InventoryViewModel}">
                <viewsInventory:InventoryView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmTaxes:TaxesListViewModel}">
                <viewsTaxes:TaxesListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCurrencies:CurrenciesListViewModel}">
                <viewsCurrencies:CurrenciesListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCurrencies:CurrencyEditorViewModel}">
                <viewsCurrencies:CurrencyEditorView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCurrencies:CurrencyRatesViewModel}">
                <viewsCurrencies:CurrencyRatesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmAccounts:AccountsListViewModel}">
                <viewsAccounts:AccountsListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmJournalEntries:JournalEntriesListViewModel}">
                <viewsJournalEntries:JournalEntriesListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmAccounts:AccountEditorViewModel}">
                <viewsAccounts:AccountEditorView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type audit:AuditLogListViewModel}">
                <viewsAudit:AuditLogListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type perms:PermissionManagementViewModel}">
                <viewsPerms:PermissionManagementView />
            </DataTemplate>

            <!-- Phase 31 — Report View DataTemplates -->
            <DataTemplate DataType="{x:Type vmReports:BalanceSheetViewModel}">
                <viewsReports:BalanceSheetView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:TrialBalanceViewModel}">
                <viewsReports:TrialBalanceView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:GeneralLedgerViewModel}">
                <viewsReports:GeneralLedgerView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:SalesByCustomerViewModel}">
                <viewsReports:SalesByCustomerView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:SalesByProductViewModel}">
                <viewsReports:SalesByProductView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:SalesByCategoryViewModel}">
                <viewsReports:SalesByCategoryView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:DailySalesViewModel}">
                <viewsReports:DailySalesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:PurchasesBySupplierViewModel}">
                <viewsReports:PurchasesBySupplierView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:PurchasesByProductViewModel}">
                <viewsReports:PurchasesByProductView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:CashBoxSummaryViewModel}">
                <viewsReports:CashBoxSummaryView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:DailyClosureReportViewModel}">
                <viewsReports:DailyClosureReportView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:UserActivityViewModel}">
                <viewsReports:UserActivityView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmReports:LoginHistoryViewModel}">
                <viewsReports:LoginHistoryView />
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- شريط القوائم Menu Bar -->
        <Menu Grid.Row="0" Background="White" Padding="3">
            <MenuItem Header="ملف" ToolTip="قائمة الملف">
                <MenuItem Header="الملف الشخصي" ToolTip="عرض معلومات المستخدم الحالي" Click="ProfileMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="فحص التحديثات" ToolTip="التحقق من وجود إصدار جديد للنظام" Click="CheckForUpdatesMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="تسجيل الخروج" ToolTip="تسجيل الخروج من النظام" Click="BtnLogout_Click"/>
            </MenuItem>
            <MenuItem Header="المبيعات" ToolTip="قائمة المبيعات">
                <MenuItem Header="فواتير البيع" ToolTip="عرض وإدارة فواتير البيع" Click="SalesInvoicesMenuItem_Click"/>
                <MenuItem Header="عروض الأسعار" ToolTip="إدارة عروض الأسعار وتحويلها إلى فواتير" Click="SalesQuotationsMenuItem_Click"/>
                <MenuItem Header="إرجاع المبيعات" ToolTip="إدارة مرتجعات المبيعات" Click="SalesReturnsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="تسديد ديون العملاء" ToolTip="تسجيل المبالغ المستلمة من العملاء" Click="CustomerPaymentsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="فتح نافذة مبيعات جديدة" ToolTip="فتح نافذة مبيعات مستقلة في نافذة منفصلة" Click="OpenNewSalesWindow_Click"/>
            </MenuItem>
            <MenuItem Header="المشتريات" ToolTip="قائمة المشتريات">
                <MenuItem Header="فواتير الشراء" ToolTip="عرض وإدارة فواتير الشراء" Click="PurchaseInvoicesMenuItem_Click"/>
                <MenuItem Header="أوامر الشراء" ToolTip="عرض وإدارة أوامر الشراء" Click="PurchaseOrdersMenuItem_Click"/>
                <MenuItem Header="إرجاع المشتريات" ToolTip="إدارة مرتجعات المشتريات" Click="PurchaseReturnsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="تسديد ديون الموردين" ToolTip="تسجيل المبالغ المدفوعة للموردين" Click="SupplierPaymentsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="فتح نافذة مشتريات جديدة" ToolTip="فتح نافذة مشتريات مستقلة في نافذة منفصلة" Click="OpenNewPurchasesWindow_Click"/>
                <MenuItem Header="فتح نافذة أوامر شراء جديدة" ToolTip="فتح نافذة أوامر شراء مستقلة في نافذة منفصلة" Click="OpenNewPurchaseOrdersWindow_Click"/>
            </MenuItem>
            <MenuItem Header="المستودعات" ToolTip="قائمة المستودعات">
                <MenuItem Header="إدارة المستودعات" ToolTip="إدارة الفروع والمستودعات" Click="WarehousesMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="نقل المخزون" ToolTip="إدارة عمليات نقل البضائع بين المستودعات" Click="StockTransfersMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="فتح نافذة مستودعات جديدة" ToolTip="فتح نافذة مستودعات مستقلة في نافذة منفصلة" Click="OpenNewWarehousesWindow_Click"/>
            </MenuItem>
            <MenuItem Header="التقارير" ToolTip="قائمة التقارير">
                <MenuItem Header="تقرير المبيعات" ToolTip="عرض تقارير المبيعات" Tag="Reports" Click="ReportMenuItem_Click"/>
                <MenuItem Header="تقرير المشتريات" ToolTip="عرض تقارير المشتريات" Tag="Reports" Click="ReportMenuItem_Click"/>
                <MenuItem Header="تقرير المخزون" ToolTip="عرض تقارير المخزون" Tag="Inventory" Click="ReportMenuItem_Click"/>
                <MenuItem Header="تقرير الأرباح والخسائر" ToolTip="عرض تقارير الأرباح والخسائر" Tag="Reports" Click="ReportMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="المنتجات المنتهية" ToolTip="إدارة وترحيل المنتجات المنتهية الصلاحية" Tag="ExpiredProducts" Click="ReportMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="قائمة الدخل" ToolTip="عرض قائمة الدخل — الإيرادات والتكاليف وصافي الربح" Tag="Reports" Click="ReportMenuItem_Click"/>
                <MenuItem Header="التدفق النقدي" ToolTip="عرض تقرير التدفق النقدي — الإيرادات والمصروفات والأرصدة" Tag="Reports" Click="ReportMenuItem_Click"/>
                <MenuItem Header="ضريبة القيمة المضافة" ToolTip="عرض تقرير ضريبة القيمة المضافة — تفصيل الفواتير والضريبة" Tag="Reports" Click="ReportMenuItem_Click"/>
                <MenuItem Header="كشف حساب" ToolTip="عرض كشف حساب عميل أو مورد — الحركات المدينة والدائنة" Tag="Reports" Click="ReportMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="كشف رصيد المخازن" Command="{Binding NavigateToStockBalanceReportCommand}" ToolTip="عرض المخزون الحالي والقيمة الإجمالية لكل منتج في المستودعات"/>
                <MenuItem Header="حركة المخازن" Command="{Binding NavigateToWarehouseMovementReportCommand}" ToolTip="عرض تاريخ حركات المخزون مع التصفية حسب المستودع والفترة"/>
                <Separator/>
                <MenuItem Header="التقارير المالية" ToolTip="التقارير المالية — الميزانية وميزان المراجعة وكشف الحساب">
                    <MenuItem Header="الميزانية العمومية" ToolTip="عرض الميزانية العمومية — الأصول والخصوم وحقوق الملكية" Tag="BalanceSheet" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="ميزان المراجعة" ToolTip="عرض ميزان المراجعة — أرصدة الحسابات مدينة/دائنة" Tag="TrialBalance" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="كشف حساب عام" ToolTip="عرض كشف حساب عام معاملات قيد يومية تفصيلية" Tag="GeneralLedger" Click="ReportMenuItem_Click"/>
                </MenuItem>
                <MenuItem Header="تقارير المبيعات" ToolTip="تقارير المبيعات — حسب العميل والمنتج والفئة واليومي">
                    <MenuItem Header="المبيعات حسب العميل" ToolTip="عرض تقرير المبيعات مُجمَّع حسب العميل" Tag="SalesByCustomer" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="المبيعات حسب المنتج" ToolTip="عرض تقرير المبيعات مع تحليل الربح حسب المنتج" Tag="SalesByProduct" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="المبيعات حسب الفئة" ToolTip="عرض تقرير المبيعات مُجمَّع حسب فئة المنتج" Tag="SalesByCategory" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="ملخص المبيعات اليومي" ToolTip="عرض ملخص المبيعات اليومي — الإجمالي والخصم والصافي" Tag="DailySales" Click="ReportMenuItem_Click"/>
                </MenuItem>
                <MenuItem Header="تقارير المشتريات" ToolTip="تقارير المشتريات — حسب المورد والمنتج">
                    <MenuItem Header="المشتريات حسب المورد" ToolTip="عرض تقرير المشتريات مُجمَّع حسب المورد" Tag="PurchasesBySupplier" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="المشتريات حسب المنتج" ToolTip="عرض تقرير المشتريات مُجمَّع حسب المنتج" Tag="PurchasesByProduct" Click="ReportMenuItem_Click"/>
                </MenuItem>
                <MenuItem Header="تقارير الخزينة" ToolTip="تقارير الخزينة — ملخص الصندوق والإغلاق اليومي">
                    <MenuItem Header="ملخص الخزينة" ToolTip="عرض ملخص أرصدة الخزينة — الإيرادات والمصروفات" Tag="CashBoxSummary" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="الإغلاق اليومي" ToolTip="عرض تقارير الإغلاق اليومي للخزينة" Tag="DailyClosure" Click="ReportMenuItem_Click"/>
                </MenuItem>
                <MenuItem Header="تقارير النشاط" ToolTip="تقارير النشاط — سجل المستخدمين وسجل الدخول">
                    <MenuItem Header="نشاط المستخدمين" ToolTip="عرض سجل نشاط المستخدمين — الإجراءات والوقت" Tag="UserActivity" Click="ReportMenuItem_Click"/>
                    <MenuItem Header="سجل الدخول" ToolTip="عرض سجل تسجيل الدخول — وقت الدخول والنجاح/الفشل" Tag="LoginHistory" Click="ReportMenuItem_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="الإعدادات" ToolTip="قائمة الإعدادات" x:Name="SettingsMenuItem">
                <MenuItem Header="إدارة المنتجات" ToolTip="إدارة قائمة المنتجات والأسعار" Click="ProductsMenuItem_Click"/>
                <MenuItem Header="المكونات (BOM)" Command="{Binding NavigateToBillOfMaterialsCommand}" ToolTip="إدارة قائمة المكونات للمنتجات المُجمَّعة — تحديد المكونات والكميات والوحدات"/>
                <MenuItem Header="إدارة العملاء" ToolTip="إدارة بيانات العملاء" Click="CustomersMenuItem_Click"/>
                <MenuItem Header="مجموعات العملاء" Command="{Binding NavigateToCustomerGroupsCommand}" ToolTip="تصنيف وترتيب العملاء في مجموعات للتقرير والتحليل"/>
                <MenuItem Header="إدارة الموردين" ToolTip="إدارة بيانات الموردين" Click="SuppliersMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="إدارة المستخدمين" ToolTip="إدارة حسابات المستخدمين والصلاحيات" Click="UsersMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="الضرائب" ToolTip="إدارة الضرائب — إضافة وتعديل نسب الضريبة" Click="TaxesMenuItem_Click"/>
                <MenuItem Header="العملات" Command="{Binding NavigateToCurrenciesCommand}" ToolTip="إدارة العملات وأسعار الصرف"/>
                <MenuItem Header="دليل الحسابات" Command="{Binding NavigateToChartOfAccountsCommand}" ToolTip="إدارة دليل الحسابات — عرض وتعديل الحسابات المحاسبية"/>
                <MenuItem Header="القيود اليومية" Command="{Binding NavigateToJournalEntriesCommand}" ToolTip="عرض القيود اليومية المحاسبية — جميع حركات الحسابات المدينة والدائنة"/>
                <MenuItem Header="السنوات المالية" Command="{Binding NavigateToFiscalYearsCommand}" ToolTip="إدارة السنوات المالية — إنشاء وفتح وإغلاق السنوات"/>
                <MenuItem Header="النسخ الاحتياطي" 
                          Command="{Binding NavigateToBackupCommand}"
                          ToolTip="إنشاء واستعادة النسخ الاحتياطية لقاعدة البيانات"/>
                <MenuItem Header="فتح نافذة منتجات جديدة" ToolTip="فتح نافذة منتجات مستقلة في نافذة منفصلة" Click="OpenNewProductsWindow_Click"/>
                <MenuItem Header="فتح نافذة عملاء جديدة" ToolTip="فتح نافذة عملاء مستقلة في نافذة منفصلة" Click="OpenNewCustomersWindow_Click"/>
                <MenuItem Header="فتح نافذة موردين جديدة" ToolTip="فتح نافذة موردين مستقلة في نافذة منفصلة" Click="OpenNewSuppliersWindow_Click"/>
            </MenuItem>
        </Menu>

        <!-- المحتوى الرئيسي -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- الجانب الأيمن - قائمة التنقل (Sidebar) -->
            <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" Width="200" BorderThickness="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- App Brand/Logo Area -->
                        <RowDefinition Height="*"/>    <!-- Navigation Items -->
                    </Grid.RowDefinitions>

                    <!-- App Branding -->
                    <Border Grid.Row="0" Padding="12,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" FontSize="22" Margin="0,0,8,0"/>
                            <TextBlock Text="نظام المبيعات" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       AutomationProperties.AutomationId="SidebarBrandText"/>
                        </StackPanel>
                    </Border>

                    <!-- Navigation Menu with Expander Groups -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Background="#1E293B">

                            <!-- Sales Expander -->
                            <Expander Header="المبيعات" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderSales">
                                <StackPanel>
                                    <Button Content="نقطة البيع" 
                                            Command="{Binding NavigateToPosCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavPos"
                                            ToolTip="شاشة البيع المباشر وإتمام عمليات البيع للعملاء"/>
                                    <Button Content="فواتير البيع" 
                                            Command="{Binding NavigateToSalesInvoicesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSalesInvoices"
                                            ToolTip="عرض وإدارة فواتير البيع بجميع حالاتها"/>
                                    <Button Content="عروض الأسعار" 
                                            Command="{Binding NavigateToSalesQuotationsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSalesQuotations"
                                            ToolTip="إدارة عروض الأسعار وتحويلها إلى فواتير"/>
                                    <Button Content="مرتجعات المبيعات" 
                                            Command="{Binding NavigateToSalesReturnsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSalesReturns"
                                            ToolTip="إدارة مرتجعات المبيعات وإعادة الأصناف للمخزون"/>
                                </StackPanel>
                            </Expander>

                            <!-- Purchases Expander -->
                            <Expander Header="المشتريات" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderPurchases">
                                <StackPanel>
                                    <Button Content="فواتير الشراء" 
                                            Command="{Binding NavigateToPurchasesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavPurchaseInvoices"
                                            ToolTip="عرض وإدارة فواتير الشراء من الموردين"/>
                                    <Button Content="أوامر الشراء"
                                            Command="{Binding NavigateToPurchaseOrdersCommand}"
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavPurchaseOrders"
                                            ToolTip="عرض وإدارة أوامر الشراء — قيد الانتظار والمستلمة والملغية"/>
                                    <Button Content="مرتجعات المشتريات" 
                                            Command="{Binding NavigateToPurchaseReturnsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavPurchaseReturns"
                                            ToolTip="إدارة مرتجعات المشتريات وإعادة البضائع للموردين"/>
                                </StackPanel>
                            </Expander>

                            <!-- Finance Expander -->
                            <Expander Header="المالية" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderFinance">
                                <StackPanel>
                                    <Button Content="مدفوعات العملاء" 
                                            Command="{Binding NavigateToCustomerPaymentsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCustomerPayments"
                                            ToolTip="تسجيل المبالغ المستلمة من العملاء لتسوية المديونيات"/>
                                    <Button Content="مدفوعات الموردين" 
                                            Command="{Binding NavigateToSupplierPaymentsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSupplierPayments"
                                            ToolTip="تسجيل المبالغ المدفوعة للموردين لتسوية الحسابات"/>
                                    <Button Content="الخزينة" 
                                            Command="{Binding NavigateToCashBoxesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCashBoxes"
                                            ToolTip="إدارة الصناديق النقدية ومتابعة الأرصدة والحركات"/>
                                    <Button Content="القيود اليومية" 
                                            Command="{Binding NavigateToJournalEntriesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavJournalEntries"
                                            ToolTip="عرض القيود اليومية المحاسبية — جميع حركات الحسابات المدينة والدائنة"/>
                                    <Button Content="السنوات المالية"
                                            Command="{Binding NavigateToFiscalYearsCommand}"
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavFiscalYears"
                                            ToolTip="إدارة السنوات المالية — إنشاء وفتح وإغلاق السنوات"/>
                                </StackPanel>
                            </Expander>

                            <!-- Reports Expander -->
                            <Expander Header="التقارير" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderReports">
                                <StackPanel>
                                    <Button Content="التقارير" 
                                            Command="{Binding NavigateToReportsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavReports"
                                            ToolTip="توليد وعرض التقارير المالية والمبيعات والمخزون"/>
                                    <Button Content="نواقص المخزون" 
                                            Command="{Binding NavigateToLowStockCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavLowStock"
                                            ToolTip="عرض الأصناف التي وصلت للحد الأدنى للمخزون مع مقترحات الطلب"/>
                                    <Button Content="المنتجات المنتهية" 
                                            Command="{Binding NavigateToExpiredProductsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavExpiredProducts"
                                            ToolTip="عرض المنتجات منتهية الصلاحية وإدارة إتلافها"/>
                                    <Separator Margin="16,4"/>
                                    <Button Content="قائمة الدخل" 
                                            Command="{Binding NavigateToIncomeStatementCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavIncomeStatement"
                                            ToolTip="عرض قائمة الدخل — الإيرادات والتكاليف وصافي الربح"/>
                                    <Button Content="التدفق النقدي" 
                                            Command="{Binding NavigateToCashFlowReportCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCashFlow"
                                            ToolTip="عرض تقرير التدفق النقدي — الإيرادات والمصروفات والأرصدة"/>
                                    <Button Content="ضريبة القيمة المضافة" 
                                            Command="{Binding NavigateToVatReportCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavVatReport"
                                            ToolTip="عرض تقرير ضريبة القيمة المضافة — تفصيل الفواتير والضريبة"/>
                                    <Button Content="كشف حساب" 
                                            Command="{Binding NavigateToAccountStatementCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavAccountStatement"
                                            ToolTip="عرض كشف حساب عميل أو مورد — الحركات المدينة والدائنة"/>
                                    <Separator Margin="16,4"/>
                                    <Button Content="كشف رصيد المخازن" 
                                            Command="{Binding NavigateToStockBalanceReportCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavStockBalanceReport"
                                            ToolTip="عرض كشف رصيد المخازن — المخزون الحالي والقيمة الإجمالية لكل منتج في المستودعات"/>
                                    <Button Content="حركة المخازن" 
                                            Command="{Binding NavigateToWarehouseMovementReportCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavWarehouseMovementReport"
                                            ToolTip="عرض تقرير حركة المخازن — تاريخ حركات المخزون مع التصفية حسب المستودع والفترة"/>
                                </StackPanel>
                            </Expander>

                            <!-- Settings Expander -->
                            <Expander Header="الإعدادات" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderSettings">
                                <StackPanel>
                                    <Button Content="المنتجات" 
                                            Command="{Binding NavigateToProductsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavProducts"
                                            ToolTip="إدارة قائمة المنتجات والأسعار والباركود"/>
                                    <Button Content="أسعار المنتجات" 
                                            Command="{Binding NavigateToProductPricesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavProductPrices"
                                            ToolTip="إدارة أسعار المنتجات متعددة العملات — تحديد سعر التجزئة والجملة والمزيد لكل عملة"/>
                                    <Button Content="صور المنتجات" 
                                            Command="{Binding NavigateToProductImagesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavProductImages"
                                            ToolTip="إدارة صور المنتجات — إضافة وعرض صور متعددة لكل منتج"/>
                                    <Button Content="المكونات (BOM)" 
                                            Command="{Binding NavigateToBillOfMaterialsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavBillOfMaterials"
                                            ToolTip="إدارة قائمة المكونات — تحديد المكونات اللازمة لتصنيع المنتجات المُجمَّعة"/>
                                    <Button Content="الدفعات المخزنية" 
                                            Command="{Binding NavigateToInventoryBatchesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavInventoryBatches"
                                            ToolTip="إدارة دفعات المخزون — تتبع الكميات حسب التاريخ وتاريخ انتهاء الصلاحية"/>
                                    <Button Content="العملاء" 
                                            Command="{Binding NavigateToCustomersCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCustomers"
                                            ToolTip="إدارة بيانات العملاء والحسابات وتاريخ المعاملات"/>
                                    <Button Content="مجموعات العملاء" 
                                            Command="{Binding NavigateToCustomerGroupsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCustomerGroups"
                                            ToolTip="إدارة مجموعات العملاء — تصنيف العملاء في مجموعات للتقارير والتحليلات"/>
                                    <Button Content="الموردين" 
                                            Command="{Binding NavigateToSuppliersCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSuppliers"
                                            ToolTip="إدارة بيانات الموردين ومتابعة المستحقات المالية"/>
                                    <Button Content="المستودعات" 
                                            Command="{Binding NavigateToWarehousesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavWarehouses"
                                            ToolTip="إدارة الفروع والمستودعات ومواقع تخزين المنتجات"/>
                                    <Button Content="التصنيفات" 
                                            Command="{Binding NavigateToCategoriesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCategories"
                                            ToolTip="إدارة التصنيفات الرئيسية والفرعية للأصناف والمنتجات"/>
                                    <Button Content="الوحدات" 
                                            Command="{Binding NavigateToUnitsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavUnits"
                                            ToolTip="إدارة وحدات القياس المستخدمة في المخزون والفواتير"/>
                                    <Button Content="المستخدمين" 
                                            Command="{Binding NavigateToUsersCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavUsers"
                                            ToolTip="إدارة حسابات الموظفين والصلاحيات وبيانات الدخول"/>
                                    <Button Content="الإعدادات" 
                                            Command="{Binding NavigateToSettingsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSettings"
                                            ToolTip="إعدادات النظام والعملات والضرائب وتهيئة الطابعات"/>
                                    <Button Content="إعدادات النظام" 
                                            Command="{Binding NavigateToSystemSettingsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavSystemSettings"
                                            ToolTip="إدارة جميع إعدادات النظام المخزنة — المخزون والمبيعات والمشتريات والباركود"/>
                                    <Button Content="النسخ الاحتياطي" 
                                            Command="{Binding NavigateToBackupCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavBackup"
                                            ToolTip="إدارة النسخ الاحتياطي — إنشاء واستعادة النسخ الاحتياطية لقاعدة البيانات"/>
                                    <Button Content="الضرائب" 
                                            Command="{Binding NavigateToTaxesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavTaxes"
                                            ToolTip="إدارة الضرائب — إضافة وتعديل نسب الضريبة"/>
                                    <Button Content="دليل الحسابات" 
                                            Command="{Binding NavigateToChartOfAccountsCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavChartOfAccounts"
                                            ToolTip="إدارة دليل الحسابات — عرض وتعديل الحسابات المحاسبية"/>
                                    <Button Content="العمليات المخزنية" 
                                             Command="{Binding NavigateToInventoryOperationsCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavInventoryOperations"
                                             ToolTip="إدارة عمليات الصرف والإستلام والتسوية المخزنية"/>
                                    <Button Content="نقل المخزون" 
                                             Command="{Binding NavigateToStockTransfersCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavStockTransfers"
                                             ToolTip="إدارة عمليات نقل البضائع بين المستودعات"/>
                                    <Button Content="المخزون" 
                                             Command="{Binding NavigateToInventoryCommand}" 
                                             Style="{StaticResource SidebarSubMenuButtonStyle}"
                                             AutomationProperties.AutomationId="NavInventory"
                                             ToolTip="عرض حركة المخزون وإدارة الأصناف في المستودعات"/>
                                </StackPanel>
                            </Expander>

                            <!-- Currencies Expander -->
                            <Expander Header="العملات" Style="{StaticResource SidebarExpanderStyle}"
                                      AutomationProperties.AutomationId="SidebarExpanderCurrencies">
                                <StackPanel>
                                    <Button Content="العملات" 
                                            Command="{Binding NavigateToCurrenciesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCurrencies"
                                            ToolTip="إدارة العملات — إضافة وتعديل العملات وتعيين العملة الأساسية"/>
                                    <Button Content="أسعار العملات" 
                                            Command="{Binding NavigateToCurrencyRatesCommand}" 
                                            Style="{StaticResource SidebarSubMenuButtonStyle}"
                                            AutomationProperties.AutomationId="NavCurrencyRates"
                                            ToolTip="إدارة أسعار صرف العملات — عرض وتحديث أسعار الصرف اليومية"/>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- المنطقة الرئيسية - عرض المحتوى -->
            <ContentControl Content="{Binding CurrentViewModel}" Grid.Column="1" Margin="8" />
        </Grid>

        <!-- شريط الحالة Status Bar -->
        <StatusBar Grid.Row="2" Style="{StaticResource StatusBarStyle}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <!-- Avatar indicator -->
                    <Border Width="24" Height="24" CornerRadius="12"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,6,0">
                        <TextBlock Text="👤" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="المستخدم: " Margin="0,0,3,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtUserName" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="الدور: " Margin="0,0,3,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Border x:Name="RoleBadge" CornerRadius="4" Padding="6,1">
                        <TextBlock x:Name="TxtUserRole" FontWeight="Bold" FontSize="11"/>
                    </Border>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <Button x:Name="BtnChangePassword"
                        Content="🔑"
                        Style="{StaticResource SecondaryButton}"
                        Padding="6,2"
                        ToolTip="فتح نافذة تغيير كلمة المرور"
                        Click="BtnChangePassword_Click"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="CurrentDateText" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button x:Name="BtnLogoutStatus"
                            Content="🚪 خروج"
                            Style="{StaticResource SecondaryButton}"
                            Padding="8,2"
                            Margin="8,0,0,0"
                            ToolTip="تسجيل الخروج من النظام"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
